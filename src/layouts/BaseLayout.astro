---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import StructuredData from '../components/StructuredData.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileBar from '../components/MobileBar.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Trusted HVAC technicians serving the Phoenix Valley since 2010. AC repair, heating, heat pumps, mini-splits, IAQ. 24/7 emergency. Licensed & insured.',
  image,
  noindex = false,
} = Astro.props;

const organizationData = {
  name: "Skyhooked on Comfort",
  phone: "(480) 123-4567",
  url: Astro.site?.href,
  logo: new URL('/images/logo.png', Astro.site).href,
  address: {
    addressLocality: "Phoenix",
    addressRegion: "AZ",
    addressCountry: "US",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preconnect to font origins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Poppins (display) + Inter (body) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon set -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Slate brand theme-color -->
    <meta name="theme-color" content="#2B3A4A" />

    <SEOHead
      title={title}
      description={description}
      image={image}
      noindex={noindex}
    />

    <StructuredData type="Organization" data={organizationData} />
  </head>
  <body class="font-body text-neutral-900 bg-neutral-50 antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <MobileBar />
  </body>
</html>
