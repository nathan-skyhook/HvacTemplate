const cities = [
  { name: 'Phoenix', slug: 'phoenix' },
  { name: 'Scottsdale', slug: 'scottsdale' },
  { name: 'Mesa', slug: 'mesa' },
  { name: 'Tempe', slug: 'tempe' },
  { name: 'Chandler', slug: 'chandler' },
  { name: 'Gilbert', slug: 'gilbert' },
  { name: 'Glendale', slug: 'glendale' },
  { name: 'Peoria', slug: 'peoria' },
  { name: 'Surprise', slug: 'surprise' },
  { name: 'Avondale', slug: 'avondale' },
  { name: 'Fountain Hills', slug: 'fountain-hills' },
  { name: 'Queen Creek', slug: 'queen-creek' },
];

const plans = [
  {
    name: 'Bronze',
    price: '$14.99',
    period: '/mo',
    popular: false,
    bullets: ['Annual AC tune-up', 'Priority scheduling', '10% off repairs'],
  },
  {
    name: 'Silver',
    price: '$24.99',
    period: '/mo',
    popular: true,
    bullets: ['Two tune-ups/year', 'Priority scheduling', '15% off repairs + 5-yr warranty'],
  },
  {
    name: 'Gold',
    price: '$39.99',
    period: '/mo',
    popular: false,
    bullets: ['Quarterly visits', 'Same-day priority dispatch', '20% off repairs + filters included'],
  },
];

const blogPosts = [
  {
    category: 'Buying Guides',
    title: 'Heat Pump vs Furnace + AC in Phoenix: A Licensed Tech\'s Honest Take',
    excerpt: 'We break down the real costs, efficiency numbers, and climate factors so you can choose without the sales pressure.',
    href: '/blog/heat-pump-vs-furnace-ac-phoenix',
  },
  {
    category: 'Tips & Advice',
    title: 'Why an Oversized AC Is Worse Than No AC at All',
    excerpt: 'Bigger isn\'t better when it comes to air conditioning. Here\'s what short-cycling actually costs you.',
    href: '/blog/oversized-ac-problems',
  },
  {
    category: 'Tax Credits & Rebates',
    title: 'How to Claim the 30% Federal Heat Pump Tax Credit',
    excerpt: 'The IRA\'s 25C credit can put thousands back in your pocket. Here\'s exactly how to claim it.',
    href: '/blog/federal-heat-pump-tax-credit',
  },
];

const faqs = [
  {
    q: 'How fast can you get to my home?',
    a: 'Most Phoenix Valley calls are dispatched within 60 minutes. Emergency crews run 24/7, every day of the year including holidays.',
  },
  {
    q: 'Do you charge a service fee?',
    a: 'We charge a flat dispatch fee that is waived when you approve any work. You\'ll know the exact price before we lift a tool.',
  },
  {
    q: 'Are you licensed and insured?',
    a: 'Yes. Arizona Contractor License AZ ROC-312489, EPA Section 608 Universal certified, fully insured and bonded.',
  },
  {
