---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  { id: 'pricing', label: 'Pricing & Billing' },
  { id: 'scheduling', label: 'Scheduling' },
  { id: 'ac-heating', label: 'AC & Heating' },
  { id: 'heat-pumps', label: 'Heat Pumps' },
  { id: 'brands', label: 'Brands & Equipment' },
  { id: 'maintenance', label: 'Maintenance' },
  { id: 'permits', label: 'Permits & Code' },
  { id: 'warranties', label: 'Warranties' },
  { id: 'financing', label: 'Financing' },
  { id: 'commercial', label: 'Commercial' },
  { id: 'about', label: 'About Us' },
];

const faqSections = [
  {
    id: 'pricing',
    title: 'Pricing & Billing',
    faqs: [
      {
        q: 'How much do you charge for a service call?',
        a: 'We charge a flat dispatch fee that is waived when you approve any repair or service work. You\'ll receive a written, flat-rate quote before any work starts — no surprise charges after the fact.',
      },
      {
        q: 'Do you offer free estimates?',
        a: 'For installation projects and major replacements, yes — we provide free in-home consultations. For diagnostic service calls, we charge a flat dispatch fee that is credited toward any approved repair.',
      },
      {
        q: 'Are there any hidden fees?',
        a: 'No. Flat-rate pricing means travel, parts, labor, permits (when required), and haul-away are all included in the quoted price. What we quote is what you pay.',
      },
      {
        q: 'What payment methods do you accept?',
        a: 'All major credit cards, checks, cash, and financing through our partners GoodLeap and Synchrony. Financing is available for qualifying projects over $500 — apply in 90 seconds with a soft credit pull.',
      },
    ],
  },
  {
    id: 'scheduling',
    title: 'Scheduling & Emergencies',
    faqs: [
      {
        q: 'How fast can you get to my home in Phoenix?',
        a: 'Most Phoenix Valley calls are dispatched within 60 minutes. Emergency crews run 24/7, 365 days a year including all holidays. We dispatch from Phoenix and can reach most Valley locations in under an hour.',
      },
      {
        q: 'Is there an extra charge for after-hours or weekend service?',
        a: 'No. Flat-rate pricing applies day, night, weekend, and holiday. No overtime fees, no surcharges, ever. If it was $200 on Tuesday afternoon, it\'s $200 on Sunday at 2am.',
      },
      {
        q: 'Can I get same-day service?',
        a: 'Yes on most calls. Book by noon for the best chance of same-day service. Comfort Plan members receive same-day priority dispatch even during peak Phoenix summer season when demand is highest.',
      },
      {
        q: 'Do real people answer the phone?',
        a: 'Yes. A real person at our Phoenix office answers every call, every hour of every day. No voicemail after hours, no national call center, no automated answering system.',
      },
    ],
  },
  {
    id: 'ac-heating',
    title: 'AC & Heating Service',
    faqs: [
      {
        q: 'What HVAC brands do you service?',
        a: 'All major brands: Carrier, Trane, Lennox, Goodman, Rheem, American Standard, York, Bryant, Mitsubishi, Daikin, LG, Fujitsu, Bosch, and more. If it has refrigerant and a compressor, we work on it.',
      },
      {
        q: 'Should I repair or replace my system?',
        a: 'If your system is 10+ years old, has had multiple recent repairs, uses the old R-22 refrigerant (now phased out), or has a repair cost over 50% of replacement cost, replacement usually wins on 5-year total cost. We lay out the math for your specific situation with no pressure either way.',
      },
      {
        q: 'What is a Manual J load calculation?',
        a: 'A Manual J is a real heat-loss and heat-gain calculation for your home — measuring insulation levels, window area, orientation, infiltration, and local climate data to determine the correct system size. It\'s required by Arizona code for new installs and by the federal heat pump tax credit. We perform a Manual J on every installation.',
      },
      {
        q: 'Why is one room in my house always hot or cold?',
        a: 'The most common causes are undersized supply ducts, a blocked or closed register, a leaky duct in the attic, an imbalanced system, or a damper issue. We diagnose this as part of a tune-up or service call.',
      },
      {
        q: 'Why is my AC freezing up?',
        a: 'The four most common causes are low refrigerant (usually a slow leak), restricted airflow from a dirty filter or coil, a failing blower motor, or running the AC below 60°F outdoor temperature. Turn the system off, let it thaw, and call us — running a frozen system damages the compressor.',
      },
    ],
  },
  {
    id: 'heat-pumps',
    title: 'Heat Pumps & Tax Credits',
    faqs: [
      {
        q: 'Do heat pumps work in Phoenix\'s climate?',
        a: 'Absolutely. Phoenix is actually ideal for heat pumps — mild winters mean the system rarely needs to work hard for heating, and modern heat pumps are extremely efficient in both cooling and moderate-heat modes. Even on the coldest Phoenix nights (mid-20s°F on rare occasions), a standard heat pump handles it without backup heat.',
      },
      {
        q: 'How does the 30% federal heat pump tax credit work?',
        a: 'The IRA Section 25C tax credit covers 30% of equipment and installation costs, up to $2,000 per year, through 2032. The heat pump must meet CEE Tier 2 efficiency requirements — most of what we install qualifies. We provide the AHRI certificate and all documentation; your CPA files it with your return.',
      },
      {
        q: 'Can I stack the federal tax credit with SRP or APS rebates?',
        a: 'Yes. Most Phoenix homeowners qualify for both — the federal 25C credit (up to $2,000) and a utility rebate through SRP or APS (typically $500–$2,000 depending on SEER2 rating). Combined savings often exceed $3,000 on a qualifying installation. We file the rebate paperwork for you.',
      },
      {
        q: 'Should I keep my gas furnace as a backup for a heat pump?',
        a: 'It depends on your priorities. A dual-fuel hybrid setup pairs a heat pump with your existing gas furnace — the heat pump handles most heating, and the furnace kicks in below about 20°F for maximum efficiency. A straight heat pump is simpler, fully electric, and eliminates gas costs. We model both options for your home.',
      },
      {
        q: 'How long does a heat pump installation take?',
        a: 'Most standard replacements take one day. If ductwork modifications or electrical panel upgrades are needed, plan for two days. We schedule and confirm the timeline before we start.',
      },
    ],
  },
  {
    id: 'brands',
    title: 'Brands & Equipment',
    faqs: [
      {
        q: 'Carrier, Trane, or Lennox — which is best?',
        a: 'All three are excellent at the top of their respective lines. The more important factors are local parts depot availability (warranty response speed), your installer\'s certification level with that brand, and the specific model within each brand\'s lineup. We help you pick based on your home, budget, and which manufacturer supports best locally.',
      },
      {
        q: 'Mitsubishi or Daikin for ductless mini-splits?',
        a: 'Both are top-tier Japanese manufacturers with excellent engineering. Mitsubishi has the stronger US dealer network and faster local parts support in Phoenix. Daikin owns more of the engineering stack and offers excellent value. We install both and can give you a side-by-side comparison for your specific application.',
      },
      {
        q: 'Is variable-speed worth the premium?',
        a: 'For most Phoenix homes, yes. Variable-speed compressors run quieter, dehumidify significantly better (important in monsoon season), and use 30–50% less electricity than single-stage at partial loads. The premium typically pays back in energy savings within 5–8 years for most Phoenix installations.',
      },
      {
        q: 'What is SEER2 and why does it matter?',
        a: 'SEER2 is the updated seasonal efficiency rating for AC and heat pump systems (replaced old SEER in 2023). Higher SEER2 means lower operating costs. In Phoenix where cooling season runs 8+ months, every SEER2 point translates to real annual savings. Minimum legal SEER2 in Arizona is 14.3; we typically recommend 16–18 SEER2 for the Phoenix climate.',
      },
    ],
  },
  {
    id: 'maintenance',
    title: 'Maintenance',
    faqs: [
      {
        q: 'How often should I get an HVAC tune-up?',
        a: 'Twice a year — a spring AC tune-up (before Phoenix cooling season begins) and a fall heating tune-up (before heating season). This schedule is required by most manufacturer warranties to keep coverage valid.',
      },
      {
        q: 'What does a 22-point tune-up include?',
        a: 'Condenser and evaporator coil inspection and cleaning, refrigerant pressure check, capacitor and contactor test, electrical connection inspection and tightening, condensate drain line flush, thermostat calibration, filter replacement, blower motor and belt check, lubrication of moving parts, gas pressure and combustion analysis (on furnaces), and a full system run test. You receive a written report at the end.',
      },
      {
        q: 'How often should I change my air filter?',
        a: 'Standard 1-inch filters: every 1–3 months in Phoenix (more during high-dust monsoon season and when running system heavily). Premium 4–5 inch media filters: every 6–12 months. A dirty filter restricts airflow, can freeze the coil, raises energy use, and shortens equipment life.',
      },
      {
        q: 'What is the Skyhooked Comfort Plan?',
        a: 'Our annual maintenance membership starting at $14.99/month. Includes both annual tune-ups, priority scheduling, 10–20% off all repairs, no overtime fees, extended workmanship warranties, and more depending on the tier. Most members save more than the plan costs on their first repair.',
      },
    ],
  },
  {
    id: 'permits',
    title: 'Permits & Code',
    faqs: [
      {
        q: 'Do you pull permits for HVAC work?',
        a: 'Always, when required. New AC installs, heat pump installs, furnace replacements, ductwork modifications, and gas line work all require permits in most Phoenix Valley jurisdictions. We pull the permit, schedule the inspection, and handle all AHJ (Authority Having Jurisdiction) correspondence.',
      },
      {
        q: 'Why do I need a permit for HVAC work?',
        a: 'Permits confirm that work was performed to code and inspected by a licensed inspector. They appear on your property record, are required by most homeowner\'s insurance policies, and are required by the federal heat pump tax credit. Unpermitted HVAC work can void your insurance coverage and create complications when you sell.',
      },
      {
        q: 'How long does it take to get a permit in Phoenix?',
        a: 'Most residential HVAC permits in Phoenix, Scottsdale, and surrounding cities are pulled same-day or next-day through the city\'s online portal. We factor permit timeline into your project schedule so it never causes delays.',
      },
    ],
  },
  {
    id: 'warranties',
    title: 'Warranties',
    faqs: [
      {
        q: 'What workmanship warranty do you offer?',
        a: '1-year workmanship warranty on every job. Comfort Plan Silver members receive a 3-year extended workmanship warranty; Gold members receive 5-year. If something we did causes a problem within the warranty period, we fix it at no charge.',
      },
      {
        q: 'What are the manufacturer parts warranties?',
        a: 'Standard manufacturer warranties run 10 years on compressors and major parts for most brands, and 20 years on heat exchangers (with registration). We register every piece of equipment we install so your warranty is active from day one — you don\'t have to do anything.',
      },
      {
        q: 'What if I\'m not satisfied with the work?',
        a: 'We come back at no charge and make it right. If we still can\'t resolve the issue to your satisfaction, we refund your money. This isn\'t fine print — it\'s how we\'ve operated since Marcus founded the company in 2010.',
      },
    ],
  },
  {
    id: 'financing',
    title: 'Financing',
    faqs: [
      {
        q: 'Do you offer financing?',
        a: 'Yes. We partner with GoodLeap and Synchrony for home improvement financing. Options include 0% APR for 12, 18, and 60 months for qualified buyers, plus extended low-APR terms up to 84 months for larger projects. See /financing for details.',
      },
      {
        q: 'Will applying for financing affect my credit score?',
        a: 'Pre-qualification uses a soft credit pull — no impact on your credit score. A hard pull only occurs if you accept a loan offer. You can check your options without any credit consequence.',
      },
      {
        q: 'Can I stack financing with the federal heat pump tax credit?',
        a: 'Yes. Finance the installation now; the 30% federal 25C tax credit comes back to you when you file your taxes. You receive the tax credit regardless of how you financed the project.',
      },
    ],
  },
  {
    id: 'commercial',
    title: 'Commercial',
    faqs: [
      {
        q: 'Do you bid commercial HVAC projects?',
        a: 'Yes. We handle commercial projects of all sizes across the Phoenix Valley. Site walks are typically within 48 hours, and you receive a detailed written bid with line-item pricing, schedule, permit handling, equipment cut sheets, and clear inclusions/exclusions.',
      },
      {
        q: 'Do you offer commercial maintenance contracts?',
        a: 'Yes. We build custom preventive maintenance plans for property managers, restaurant groups, healthcare facilities, retail, and industrial. Plans typically include quarterly tune-ups, filter changes, coil cleaning, refrigerant checks, and priority emergency dispatch. See /commercial/preventive-maintenance.',
      },
      {
        q: 'Do you service commercial refrigeration?',
        a: 'Yes — walk-in coolers and freezers, reach-in cases, and restaurant refrigeration equipment across the Phoenix Valley. See /commercial/commercial-refrigeration.',
      },
      {
        q: 'Can you work around our operating hours?',
        a: 'Yes. Restaurants get night and early-morning slots before service. Healthcare facilities get coordinated downtime windows. Offices and retail get weekends. Scheduled maintenance is always around your operation, not ours.',
      },
    ],
  },
  {
    id: 'about',
    title: 'About Skyhooked on Comfort',
    faqs: [
      {
        q: 'How long has Skyhooked on Comfort been in business?',
        a: 'Since 2010 — over 15 years serving the Phoenix Valley. We\'ve seen the HVAC market change significantly (heat pumps, variable-speed, smart thermostats, IRA tax credits) and have stayed ahead of each shift.',
      },
      {
        q: 'Is Skyhooked on Comfort family-owned?',
        a: 'Yes. Marcus Torres founded the company in 2010 and still runs it. Not a franchise, not a private equity rollup — a family business that answers its own phone and stands behind its own work.',
      },
      {
        q: 'Are you licensed and accredited?',
        a: 'Yes. Arizona Contractor License AZ ROC-312489 (active), EPA Section 608 Universal certified (every technician), BBB Accredited with A+ rating, ACCA member, fully insured and bonded. Certificates available on request.',
      },
      {
        q: 'Do your technicians go through background checks?',
        a: 'Every technician passes a thorough background check and drug test before they\'re allowed on a job site. No exceptions.',
      },
    ],
  },
];

// Build JSON-LD schema
const schemaFaqs = faqSections.flatMap(s => s.faqs.map(f => ({
  "@type": "Question",
  "name": f.q,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": f.a,
  }
})));

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": schemaFaqs,
};
---

<BaseLayout
  title="HVAC FAQs | Skyhooked on Comfort in Phoenix, AZ"
  description="Answers to common HVAC questions from Skyhooked on Comfort: pricing, brands, heat pumps, tax credits, maintenance, financing, warranties, permits, and more."
>

  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)}></script>
  </Fragment>

  <!-- Hero -->
  <section class="bg-charcoal py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl leading-tight mb-6">
        HVAC questions, answered.
      </h1>
      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed">
        The questions we hear every week, answered straight. Don't see yours? Call <a href="tel:4801234567" class="text-sky hover:underline">(480) 123-4567</a>.
      </p>
    </div>
  </section>


  <!-- Category Nav -->
  <section class="bg-white border-b border-neutral-100 py-5 sticky top-0 z-10">
    <div class="max-w-5xl mx-auto px-4">
      <nav aria-label="FAQ categories">
        <ul class="flex flex-wrap gap-2 justify-center" role="list">
          {categories.map(cat => (
            <li>
              <a
                href={`#${cat.id}`}
                class="font-body font-semibold text-xs px-3 py-1.5 rounded-full border border-neutral-200 text-neutral-600 hover:bg-charcoal hover:text-white hover:border-charcoal transition-colors"
              >
                {cat.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </section>


  <!-- FAQ Sections -->
  <div class="bg-charcoal-50 py-16">
    <div class="max-w-3xl mx-auto px-4 space-y-14">
      {faqSections.map((section) => (
        <section id={section.id} aria-labelledby={`${section.id}-heading`}>
          <h2 id={`${section.id}-heading`} class="font-display font-bold text-charcoal text-2xl sm:text-3xl mb-6 pt-2">
            {section.title}
          </h2>
          <div class="space-y-3">
            {section.faqs.map((faq, i) => (
              <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
                <button
                  class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors"
                  aria-expanded="false"
                  data-index={`${section.id}-${i}`}
                >
                  <span class="text-sm sm:text-base">{faq.q}</span>
                  <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <div class="faq-panel hidden px-5 pb-5">
                  <p class="font-body text-neutral-600 leading-relaxed text-sm">{faq.a}</p>
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>


  <!-- Bottom CTA -->
  <section class="bg-charcoal py-16">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-bold text-white text-3xl mb-4">Don't see your question?</h2>
      <p class="font-body text-charcoal-50 text-lg mb-8">Call us or send a message — we answer every question straight.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Send a Message →
        </a>
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-sm font-body">
        <a href="/maintenance-plans" class="text-charcoal-50 hover:text-white transition-colors">Maintenance Plans</a>
        <a href="/financing" class="text-charcoal-50 hover:text-white transition-colors">Financing</a>
        <a href="/about/why-us" class="text-charcoal-50 hover:text-white transition-colors">Why Choose Us</a>
        <a href="/emergency" class="text-charcoal-50 hover:text-white transition-colors">24/7 Emergency</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');

      // Only close others in same section
      const section = btn.closest('section');
      section?.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      section?.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      section?.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        panel.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
