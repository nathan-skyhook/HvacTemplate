      <!-- Author & meta -->
      <div class="flex flex-wrap items-center gap-4">
        <div class="flex items-center gap-3">
          <div class="w-11 h-11 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm flex-shrink-0">
            {author.split(' ').map((n: string) => n[0]).join('')}
          </div>
          <div>
            <p class="font-body font-semibold text-charcoal text-sm">{author}</p>
            <p class="font-body text-neutral-500 text-xs">{authorTitle} · {authorCredentials}</p>
          </div>
        </div>
        <div class="flex items-center gap-4 font-body text-neutral-500 text-sm border-l border-neutral-200 pl-4 ml-2">
          <span>{date}</span>
          <span>·</span>
          <span>{readTime}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Hero Image Placeholder -->
  <div class="max-w-3xl mx-auto px-4 mt-10">
    <div class="h-72 sm:h-96 bg-gradient-to-br from-charcoal to-charcoal-light rounded-2xl flex items-end p-8">
      <span class="inline-block bg-sky text-charcoal text-xs font-display font-bold px-3 py-1 rounded-full">
        {category}
      </span>
    </div>
  </div>

  <!-- Article Body -->
  <article class="max-w-3xl mx-auto px-4 py-12">

    <!-- Intro -->
    <div class="font-body text-neutral-700 text-lg leading-relaxed mb-10 prose-lg">
      <p>{content.intro}</p>
    </div>

    <!-- Body Sections -->
    {content.sections.map((section: { heading: string; body: string }) => (
      <div class="mb-10">
        <h2 class="font-display font-bold text-charcoal text-2xl sm:text-3xl mb-4">{section.heading}</h2>
        <div class="font-body text-neutral-700 leading-relaxed text-base">
          <p set:html={section.body}></p>
        </div>
      </div>
    ))}

    <!-- Pull Quote -->
    <blockquote class="my-12 border-l-4 border-sky pl-6 py-2">
      <p class="font-display font-semibold text-charcoal text-xl sm:text-2xl leading-snug italic">
        {content.pullQuote}
      </p>
    </blockquote>

    <!-- Conclusion -->
    <div class="mb-12">
      <h2 class="font-display font-bold text-charcoal text-2xl sm:text-3xl mb-4">Bottom Line</h2>
      <div class="font-body text-neutral-700 leading-relaxed text-base">
        <p set:html={content.conclusion}></p>
      </div>
    </div>

    <!-- Service CTA -->
    <div class="bg-charcoal rounded-2xl p-8 mb-12 text-center">
      <h3 class="font-display font-bold text-white text-xl sm:text-2xl mb-3">
        Have an HVAC question or issue?
      </h3>
      <p class="font-body text-charcoal-50 mb-6">
        We dispatch same-day across the Phoenix Valley. Real humans answer the phone, 24/7.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="tel:4801234567"
          class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold px-6 py-3 rounded-xl transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a
          href="/contact"
          class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold px-6 py-3 rounded-xl transition-colors"
        >
          Request a Quote →
        </a>
      </div>
    </div>

    <!-- Author Bio -->
    <div class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10 mb-12">
      <div class="flex items-start gap-5">
        <div class="w-14 h-14 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-lg flex-shrink-0">
          {author.split(' ').map((n: string) => n[0]).join('')}
        </div>
        <div>
          <p class="font-display font-bold text-charcoal text-base mb-0.5">{author}</p>
          <p class="font-body text-sky text-sm font-semibold mb-1">{authorTitle} · {authorYears}</p>
          <p class="font-body text-neutral-500 text-xs mb-3">{authorCredentials}</p>
          <p class="font-body text-neutral-600 text-sm leading-relaxed">{authorBio}</p>
        </div>
      </div>
    </div>

  </article>


  <!-- Related Posts -->
  <section class="bg-neutral-50 py-16 border-t border-neutral-100">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-8">Related articles</h2>
      <div class="grid sm:grid-cols-3 gap-5">
        {relatedPostsData.map(post => (
          <a href={`/blog/${post.slug}`} class="group bg-white rounded-2xl overflow-hidden border border-neutral-100 hover:shadow-lg transition-shadow">
            <div class="h-36 bg-gradient-to-br from-charcoal to-charcoal-light flex items-end p-4">
              <span class="inline-block bg-sky text-charcoal text-xs font-display font-bold px-2.5 py-1 rounded-full">
                {post.category}
              </span>
            </div>
            <div class="p-4">
              <h3 class="font-display font-bold text-charcoal text-sm mb-2 group-hover:text-charcoal-light transition-colors leading-snug">
                {post.title}
              </h3>
              <p class="font-body text-neutral-400 text-xs mb-2">{post.author} · {post.date}</p>
              <span class="font-body text-sky text-xs font-semibold">Read more →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
