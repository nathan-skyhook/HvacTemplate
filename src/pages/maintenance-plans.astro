---
import BaseLayout from '../layouts/BaseLayout.astro';

const plans = [
  {
    name: 'Bronze',
    price: '$14.99',
    period: '/mo',
    annual: '$149/year',
    popular: false,
    bullets: [
      'Spring AC precision tune-up (22-point inspection)',
      'Fall heating precision tune-up (22-point inspection)',
      'Priority scheduling — front of the queue',
      '10% off all repairs and parts',
      'No overtime / after-hours fees',
      'Standard 1" filter included at each visit',
      '1-year workmanship warranty on all covered work',
      'On-time guarantee — missed window = free service call',
    ],
  },
  {
    name: 'Silver',
    price: '$24.99',
    period: '/mo',
    annual: '$249/year',
    popular: true,
    bullets: [
      'Everything in Bronze, plus:',
      '3-year extended workmanship warranty',
      '15% off all repairs and parts',
      'Premium pleated filter included at each visit',
      'Free service call fee waiver — one per year',
      'Annual coil cleaning included (evaporator + condenser)',
      'Condensate line flush at every visit',
      'Written service report after every tune-up',
    ],
  },
  {
    name: 'Gold',
    price: '$39.99',
    period: '/mo',
    annual: '$399/year',
    popular: false,
    bullets: [
      'Everything in Silver, plus:',
      'Quarterly inspections — 4 visits per year',
      'Annual ductwork inspection + leak scan',
      '20% off all repairs and parts',
      '5-year extended workmanship warranty',
      'Locked-in pricing — no rate increases for 3 years',
      'Same-day priority dispatch — even in peak season',
      'Plan transfers if you move within Phoenix Valley',
    ],
  },
];

const faqs = [
  {
    q: 'Is there a contract? Can I cancel?',
    a: 'No contract. Cancel anytime. Annual plans are pro-rated — we refund the unused portion. No cancellation fees.',
  },
  {
    q: 'What exactly happens during a tune-up?',
    a: 'A 60–90 minute precision inspection: clean condenser coil, check refrigerant pressures, test capacitor and contactor, inspect and tighten electrical connections, clear condensate drain line, check thermostat calibration, replace filter, lubricate moving parts, run system through full heating and cooling cycle, and give you a written report at the end with any findings or recommendations.',
  },
  {
    q: 'Can I add a second property or unit to my plan?',
    a: 'Yes. Additional systems or properties on your account receive a discounted rate. Call (480) 123-4567 to add a property.',
  },
  {
    q: 'What if I just bought a home and inherited an older system?',
    a: 'Your Comfort Plan still covers you. Any pre-existing problems are noted at the first tune-up, and we\'ll quote any needed work before plan coverage kicks in. Nothing hidden.',
  },
  {
    q: 'Does the plan cover repairs, or just tune-ups?',
    a: 'The plan covers two annual tune-ups plus repair discounts (10–20% depending on tier). Actual repair parts and labor are discounted but not free. The plan also includes a service call fee waiver (Silver and above).',
  },
  {
    q: 'Does the plan transfer if I sell my home?',
    a: 'Gold plan members: yes, the plan transfers to a new owner at your address within the Phoenix Valley. Bronze and Silver plans are tied to the primary account holder.',
  },
];
---

<BaseLayout
  title="HVAC Maintenance Plans in Phoenix, AZ | Skyhooked on Comfort Comfort Plan"
  description="Join the Skyhooked on Comfort Comfort Plan. Two precision tune-ups a year, priority dispatch, 10–20% off repairs, and up to 5-year warranty. Starting at $14.99/month."
>

  <!-- Hero -->
  <section class="bg-charcoal py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">
        The Skyhooked Comfort Plan
      </div>
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl leading-tight mb-6">
        Two tune-ups a year. Priority dispatch.<br/>Stuff that fails doesn't.
      </h1>
      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-3xl mx-auto leading-relaxed">
        Spring AC tune-ups. Fall heating tune-ups. Priority dispatch when something does go wrong. Member-only pricing on everything. Most Comfort Plan members save more than the plan costs on their first repair.
      </p>
    </div>
  </section>


  <!-- Plan Tiers -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-4">Choose your plan.</h2>
        <p class="font-body text-neutral-600 text-lg">All plans include both spring and fall tune-ups. Cancel anytime.</p>
      </div>
      <div class="grid sm:grid-cols-3 gap-5 items-start">
        {plans.map(plan => (
          <div class={`relative rounded-2xl p-7 border-2 ${plan.popular ? 'border-sky bg-charcoal text-white shadow-xl scale-[1.02]' : 'border-neutral-200 bg-white'}`}>
            {plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-sky text-charcoal text-xs font-display font-bold px-4 py-1 rounded-full whitespace-nowrap">
                Most Popular
              </div>
            )}
            <h3 class={`font-display font-bold text-2xl mb-1 ${plan.popular ? 'text-white' : 'text-charcoal'}`}>{plan.name}</h3>
            <div class="flex items-baseline gap-1 mb-1">
              <span class={`font-display font-extrabold text-3xl ${plan.popular ? 'text-sky' : 'text-charcoal'}`}>{plan.price}</span>
              <span class={`font-body text-sm ${plan.popular ? 'text-charcoal-50' : 'text-neutral-500'}`}>{plan.period}</span>
            </div>
            <div class={`font-body text-xs mb-5 ${plan.popular ? 'text-charcoal-50' : 'text-neutral-500'}`}>or {plan.annual} — save 1 month</div>
            <ul class={`font-body text-sm space-y-2.5 mb-7 ${plan.popular ? 'text-charcoal-50' : 'text-neutral-600'}`}>
              {plan.bullets.map(b => (
                <li class="flex items-start gap-2">
                  <svg class={`w-4 h-4 mt-0.5 flex-shrink-0 ${plan.popular ? 'text-sky' : 'text-charcoal'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  {b}
                </li>
              ))}
            </ul>
            <a
              href="#signup"
              class={`block text-center font-display font-bold text-sm py-3 rounded-xl transition-colors ${plan.popular ? 'bg-sky hover:bg-sky-dark text-charcoal' : 'bg-charcoal hover:bg-charcoal-light text-white'}`}
            >
              Get Started — {plan.name}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ROI Callout -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-4">Why it's worth every penny.</h2>
        <p class="font-body text-neutral-600 text-lg max-w-2xl mx-auto">Prevention math always beats emergency math.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {[
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
            title: 'Members Save More Than the Plan Costs',
            body: 'The average Comfort Plan member calls us 2.3 times a year. With member pricing (10–20% off), most members save more on repairs alone than the plan costs — before counting two free tune-ups.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
            title: 'Front of the Line in Peak Season',
            body: 'When everyone\'s AC dies on the same July weekend, members get same-day dispatch. Non-members might wait 2–3 days in peak summer. In Phoenix, that\'s not a wait — that\'s a heat event.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>`,
            title: 'Tune-Ups Are Manufacturer-Required',
            body: 'Most equipment warranties require annual maintenance to remain valid. Comfort Plan tune-ups meet manufacturer requirements and protect your coverage.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>`,
            title: 'Catch Small Problems Early',
            body: 'A worn capacitor caught at a spring tune-up is a $25 part swap. The same capacitor failing on July 4th is a $300 emergency call plus a house that hits 90° before we arrive.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5"/>`,
            title: 'Equipment Lasts Longer',
            body: 'Properly maintained HVAC equipment lasts 20–30% longer than neglected systems. A heat pump or AC that lasts 18 years instead of 14 saves you a full system replacement — easily $6,000–$12,000.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>`,
            title: 'Locked-In Pricing (Gold)',
            body: 'Gold members lock in their repair rates for 3 years, insulated from price increases. In an inflationary environment, that\'s a real, quantifiable benefit.',
          },
        ].map(item => (
          <div class="bg-charcoal-50 rounded-2xl p-6 border border-charcoal/10">
            <div class="w-12 h-12 bg-sky/15 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true" set:html={item.icon}></svg>
            </div>
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{item.title}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Sign-Up Form -->
  <section id="signup" class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-white text-3xl sm:text-4xl mb-4">Join the Comfort Plan.</h2>
        <p class="font-body text-charcoal-50 text-lg">Cancel anytime. Pro-rated refund on unused annual plan.</p>
      </div>
      <form class="bg-white rounded-2xl p-8 space-y-5" action="/contact" method="POST">
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block font-body font-semibold text-charcoal text-sm mb-1.5" for="mp-name">Full Name *</label>
            <input id="mp-name" name="name" type="text" required class="w-full font-body text-charcoal border border-neutral-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-sky focus:ring-1 focus:ring-sky" placeholder="Your name" />
          </div>
          <div>
            <label class="block font-body font-semibold text-charcoal text-sm mb-1.5" for="mp-phone">Phone *</label>
            <input id="mp-phone" name="phone" type="tel" required class="w-full font-body text-charcoal border border-neutral-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-sky focus:ring-1 focus:ring-sky" placeholder="(480) 000-0000" />
          </div>
        </div>
        <div>
          <label class="block font-body font-semibold text-charcoal text-sm mb-1.5" for="mp-email">Email Address *</label>
          <input id="mp-email" name="email" type="email" required class="w-full font-body text-charcoal border border-neutral-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-sky focus:ring-1 focus:ring-sky" placeholder="you@example.com" />
        </div>
        <div>
          <label class="block font-body font-semibold text-charcoal text-sm mb-1.5" for="mp-address">Service Address *</label>
          <input id="mp-address" name="address" type="text" required class="w-full font-body text-charcoal border border-neutral-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-sky focus:ring-1 focus:ring-sky" placeholder="123 Main St, Phoenix, AZ 85001" />
        </div>
        <div>
          <label class="block font-body font-semibold text-charcoal text-sm mb-1.5" for="mp-plan">Plan Selection *</label>
          <select id="mp-plan" name="plan" required class="w-full font-body text-charcoal border border-neutral-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-sky focus:ring-1 focus:ring-sky">
            <option value="">Choose a plan...</option>
            <option>Bronze — $14.99/month</option>
            <option>Bronze — $149/year</option>
            <option>Silver — $24.99/month (Most Popular)</option>
            <option>Silver — $249/year</option>
            <option>Gold — $39.99/month</option>
            <option>Gold — $399/year</option>
          </select>
        </div>
        <div>
          <label class="block font-body font-semibold text-charcoal text-sm mb-1.5" for="mp-freq">Payment Frequency *</label>
          <select id="mp-freq" name="frequency" required class="w-full font-body text-charcoal border border-neutral-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-sky focus:ring-1 focus:ring-sky">
            <option value="">Select...</option>
            <option>Monthly</option>
            <option>Annual (save 1 month's cost)</option>
          </select>
        </div>
        <button type="submit" class="w-full bg-sky hover:bg-sky-dark text-charcoal font-display font-bold py-4 rounded-xl transition-colors text-lg">
          Start My Comfort Plan →
        </button>
        <p class="font-body text-neutral-500 text-xs text-center">A team member will follow up to confirm your plan and schedule your first tune-up. Cancel anytime — no fees.</p>
      </form>
    </div>
  </section>


  <!-- FAQ -->
  <section class="bg-white py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl text-center mb-10">Plan FAQs.</h2>
      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden">
            <button
              class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors"
              aria-expanded="false"
              data-index={i}
            >
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5">
              <p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Related Links -->
  <section class="bg-charcoal-50 py-12">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="font-body text-neutral-600 mb-4">Related services:</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/residential/tune-ups-maintenance" class="font-body font-semibold text-sky hover:underline text-sm">AC & Heating Tune-Ups</a>
        <a href="/financing" class="font-body font-semibold text-sky hover:underline text-sm">Financing Options</a>
        <a href="/promotions" class="font-body font-semibold text-sky hover:underline text-sm">Current Promotions</a>
        <a href="/about/why-us" class="font-body font-semibold text-sky hover:underline text-sm">Why Choose Us</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) {
        panel.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
