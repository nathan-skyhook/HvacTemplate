---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Skyhooked on Comfort | Phoenix HVAC Contractor | (480) 123-4567"
  description="Contact Skyhooked on Comfort for HVAC service in the Phoenix Valley. Call (480) 123-4567, text, email, or request a quote online. Real humans answer 24/7."
>

  <!-- Hero -->
  <section class="bg-charcoal py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl leading-tight mb-6">
        Get in touch with Skyhooked on Comfort.
      </h1>
      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-3xl mx-auto leading-relaxed">
        Call us, text us, or fill out the form below. A real person responds to every message — usually within 15 minutes during business hours and within the hour after hours.
      </p>
    </div>
  </section>


  <!-- Contact Method Cards -->
  <section class="bg-white py-16">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid sm:grid-cols-3 gap-6">

        <!-- Call -->
        <div class="bg-charcoal-50 rounded-2xl p-8 border border-charcoal/10 text-center hover:shadow-lg transition-shadow">
          <div class="w-14 h-14 bg-sky/15 rounded-xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <h2 class="font-display font-bold text-charcoal text-xl mb-2">Call Us</h2>
          <a href="tel:4801234567" class="font-display font-extrabold text-sky text-2xl hover:text-sky-dark transition-colors block mb-2">(480) 123-4567</a>
          <p class="font-body text-neutral-600 text-sm leading-relaxed">Answered 24/7 by a real person in Arizona. For emergencies, new service requests, quotes, or general questions.</p>
          <div class="mt-5">
            <a href="tel:4801234567" class="inline-flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-sm px-6 py-2.5 rounded-lg transition-colors">
              Call Now →
            </a>
          </div>
        </div>

        <!-- Text -->
        <div class="bg-charcoal-50 rounded-2xl p-8 border border-charcoal/10 text-center hover:shadow-lg transition-shadow">
          <div class="w-14 h-14 bg-sky/15 rounded-xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
          </div>
          <h2 class="font-display font-bold text-charcoal text-xl mb-2">Text Us</h2>
          <a href="sms:4801234567" class="font-display font-extrabold text-sky text-2xl hover:text-sky-dark transition-colors block mb-2">(480) 123-4567</a>
          <p class="font-body text-neutral-600 text-sm leading-relaxed">Same number for text. Good for non-urgent questions, appointment updates, or if you're somewhere you can't call. We respond during business hours.</p>
          <div class="mt-5">
            <a href="sms:4801234567" class="inline-flex items-center gap-2 bg-charcoal hover:bg-charcoal-light text-white font-display font-bold text-sm px-6 py-2.5 rounded-lg transition-colors">
              Send a Text →
            </a>
          </div>
        </div>

        <!-- Email -->
        <div class="bg-charcoal-50 rounded-2xl p-8 border border-charcoal/10 text-center hover:shadow-lg transition-shadow">
          <div class="w-14 h-14 bg-sky/15 rounded-xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          </div>
          <h2 class="font-display font-bold text-charcoal text-xl mb-2">Email Us</h2>
          <a href="mailto:service@skyhooked.com" class="font-body font-semibold text-sky text-base hover:text-sky-dark transition-colors block mb-2 break-all">service@skyhooked.com</a>
          <p class="font-body text-neutral-600 text-sm leading-relaxed">For non-urgent questions, bid requests, and documentation. We respond within 1 business day. For emergencies, please call.</p>
          <div class="mt-5">
            <a href="mailto:service@skyhooked.com" class="inline-flex items-center gap-2 bg-charcoal hover:bg-charcoal-light text-white font-display font-bold text-sm px-6 py-2.5 rounded-lg transition-colors">
              Send Email →
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- Quote Request Form -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-4">Request a Quote</h2>
        <p class="font-body text-neutral-600">Fill out the form and a team member will reach out within 15 minutes during business hours, or first thing in the morning if you submit after hours.</p>
      </div>
      <form class="bg-white rounded-2xl p-8 border border-charcoal/10 space-y-5" action="/contact" method="POST">
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block font-body font-semibold text-charcoal text-sm mb-1.5" for="c-name">Full Name *</label>
            <input id="c-name" name="name" type="text" required class="w-full font-body text-charcoal border border-neutral-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-sky focus:ring-1 focus:ring-sky" placeholder="Your name" />
          </div>
          <div>
            <label class="block font-body font-semibold text-charcoal text-sm mb-1.5" for="c-phone">Phone *</label>
            <input id="c-phone" name="phone" type="tel" required class="w-full font-body text-charcoal border border-neutral-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-sky focus:ring-1 focus:ring-sky" placeholder="(480) 000-0000" />
          </div>
        </div>
        <div>
          <label class="block font-body font-semibold text-charcoal text-sm mb-1.5" for="c-email">Email</label>
          <input id="c-email" name="email" type="email" class="w-full font-body text-charcoal border border-neutral-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-sky focus:ring-1 focus:ring-sky" placeholder="you@example.com" />
        </div>
        <div>
          <label class="block font-body font-semibold text-charcoal text-sm mb-1.5" for="c-zip">ZIP Code *</label>
          <input id="c-zip" name="zip" type="text" required maxlength="5" pattern="[0-9]{5}" class="w-full font-body text-charcoal border border-neutral-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-sky focus:ring-1 focus:ring-sky" placeholder="85001" />
        </div>
        <div>
          <label class="block font-body font-semibold text-charcoal text-sm mb-1.5" for="c-service">Service Needed *</label>
          <select id="c-service" name="service" required class="w-full font-body text-charcoal border border-neutral-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-sky focus:ring-1 focus:ring-sky">
            <option value="">Select a service...</option>
            <optgroup label="Residential">
              <option>Emergency HVAC</option>
              <option>AC Repair</option>
              <option>AC Installation / Replacement</option>
              <option>Heating Repair</option>
              <option>Heating Installation / Replacement</option>
              <option>Heat Pump Installation</option>
              <option>Ductless Mini-Split</option>
              <option>Indoor Air Quality</option>
              <option>Tune-Up / Maintenance</option>
              <option>Maintenance Plan Sign-Up</option>
              <option>Smart Thermostat</option>
              <option>Duct Cleaning or Sealing</option>
            </optgroup>
            <optgroup label="Commercial">
              <option>Commercial Emergency HVAC</option>
              <option>Commercial AC / Rooftop Unit</option>
              <option>Commercial Heating</option>
              <option>Commercial Maintenance Contract</option>
              <option>VRF / Chiller</option>
              <option>Commercial Refrigeration</option>
            </optgroup>
            <option>Other / Not Sure</option>
          </select>
        </div>
        <div>
          <label class="block font-body font-semibold text-charcoal text-sm mb-1.5" for="c-description">Brief Description *</label>
          <textarea id="c-description" name="description" rows="4" required class="w-full font-body text-charcoal border border-neutral-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-sky focus:ring-1 focus:ring-sky resize-none" placeholder="Tell us what's going on — brand of system, how old it is, what it's doing (or not doing)..."></textarea>
        </div>
        <div>
          <label class="block font-body font-semibold text-charcoal text-sm mb-1.5" for="c-time">Best Time to Reach You</label>
          <select id="c-time" name="best_time" class="w-full font-body text-charcoal border border-neutral-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-sky focus:ring-1 focus:ring-sky">
            <option value="">No preference</option>
            <option>Morning (7am–12pm)</option>
            <option>Afternoon (12pm–5pm)</option>
            <option>Evening (5pm–7pm)</option>
            <option>ASAP — emergency</option>
          </select>
        </div>
        <button type="submit" class="w-full bg-sky hover:bg-sky-dark text-charcoal font-display font-bold py-4 rounded-xl transition-colors text-lg">
          Submit Request →
        </button>
        <p class="font-body text-neutral-500 text-xs text-center">
          No auto-scheduling. A real team member will contact you within 15 minutes during business hours. For emergencies, call <a href="tel:4801234567" class="text-sky hover:underline font-semibold">(480) 123-4567</a> directly.
        </p>
      </form>
    </div>
  </section>


  <!-- Hours + Service Area -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid sm:grid-cols-2 gap-10">

        <!-- Hours Table -->
        <div>
          <h2 class="font-display font-bold text-charcoal text-2xl mb-6">Hours of operation.</h2>
          <div class="space-y-3">
            <div class="bg-charcoal-50 rounded-xl overflow-hidden border border-charcoal/10">
              <table class="w-full">
                <caption class="sr-only">Office hours and emergency availability</caption>
                <tbody class="font-body text-sm divide-y divide-charcoal/10">
                  {[
                    { day: 'Monday – Friday', hours: '7:00 AM – 7:00 PM' },
                    { day: 'Saturday', hours: '8:00 AM – 4:00 PM' },
                    { day: 'Sunday', hours: 'Emergency Dispatch Only' },
                  ].map(row => (
                    <tr>
                      <td class="px-5 py-3 font-semibold text-charcoal">{row.day}</td>
                      <td class="px-5 py-3 text-neutral-600 text-right">{row.hours}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <div class="bg-emergency/10 rounded-xl px-5 py-4 border border-emergency/20">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-emergency animate-pulse flex-shrink-0"></div>
                <div>
                  <div class="font-display font-bold text-charcoal text-sm">Emergency Dispatch: 24/7, 365 days</div>
                  <div class="font-body text-neutral-600 text-xs mt-0.5">Including all holidays. No overtime fees.</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Service Area -->
        <div>
          <h2 class="font-display font-bold text-charcoal text-2xl mb-6">Phoenix Valley service area.</h2>
          <p class="font-body text-neutral-600 text-sm leading-relaxed mb-4">
            Skyhooked on Comfort serves the entire Phoenix Valley from our Phoenix base. If you're in Maricopa County, we can typically be at your door the same day.
          </p>
          <div class="grid grid-cols-3 gap-2 mb-4">
            {['Phoenix', 'Scottsdale', 'Mesa', 'Tempe', 'Chandler', 'Gilbert', 'Glendale', 'Peoria', 'Surprise', 'Avondale', 'Fountain Hills', 'Queen Creek'].map(city => (
              <a
                href={`/service-areas/${city.toLowerCase().replace(' ', '-')}`}
                class="text-center font-body text-xs font-semibold bg-charcoal-50 hover:bg-charcoal hover:text-white text-charcoal py-2 px-2 rounded-lg border border-charcoal/10 hover:border-charcoal transition-colors"
              >
                {city}
              </a>
            ))}
          </div>
          <a href="/service-areas" class="font-body font-semibold text-sky text-sm hover:underline">View all service areas →</a>
        </div>

      </div>
    </div>
  </section>


  <!-- Bottom CTA -->
  <section class="bg-emergency py-16">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-bold text-white text-3xl mb-4">Need help right now?</h2>
      <p class="font-body text-white/80 text-lg mb-6">Real human answers every call, 24 hours a day.</p>
      <a
        href="tel:4801234567"
        class="inline-flex items-center gap-3 bg-white hover:bg-charcoal-50 text-emergency font-display font-extrabold text-2xl px-10 py-5 rounded-2xl transition-colors shadow-xl"
      >
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        (480) 123-4567
      </a>
    </div>
  </section>

</BaseLayout>
