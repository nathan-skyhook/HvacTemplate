---
import BaseLayout from '../../layouts/BaseLayout.astro';

const comparison = [
  { feature: 'Upfront flat-rate pricing', us: true, franchise: 'Sometimes', budget: false },
  { feature: 'Manual J load calc on every install', us: true, franchise: 'Rare', budget: 'Rare' },
  { feature: 'Permits pulled & inspections scheduled', us: 'Always', franchise: 'Sometimes', budget: 'Sometimes' },
  { feature: 'Same-day service, 24/7', us: true, franchise: 'Usually 1–3 days', budget: 'Often 3–5 day wait' },
  { feature: 'EPA 608 + NATE certified techs', us: 'Every tech', franchise: 'Varies', budget: 'Varies' },
  { feature: 'Multiple brand options on every install', us: true, franchise: 'Often one brand only', budget: 'Often one brand only' },
  { feature: 'Locally owned', us: 'Family, since 2010', franchise: 'Yes', budget: 'No' },
  { feature: '100% satisfaction guarantee, in writing', us: true, franchise: 'Sometimes', budget: 'Fine print' },
  { feature: 'Real human answers 24/7', us: true, franchise: 'Voicemail after hours', budget: 'Call center' },
];

const testimonials = [
  {
    quote: "I got four quotes for a heat pump install. The other three didn't even measure the house — they just looked at the old system and named a price. Skyhooked ran a full Manual J, came in at 2.5 tons instead of the 4 everyone else quoted, and saved me almost $4,000 upfront. The system runs perfectly.",
    name: 'Tom M.',
    location: 'Tempe',
    service: 'Heat Pump Install',
  },
  {
    quote: "Called two companies before Skyhooked when my AC went out in July. One wanted to schedule three days out. The other wanted to sell me a whole new system without even diagnosing. Skyhooked was here in 45 minutes, found a bad capacitor, had it fixed in 30 minutes, and charged exactly what they quoted.",
    name: 'Amanda K.',
    location: 'Chandler',
    service: 'Emergency AC Repair',
  },
  {
    quote: "Marcus came out himself to look at our commercial space in Scottsdale. He knew exactly what we needed, pulled the permit the same week, and had his crew in and out in two days. Every other contractor I talked to wanted two weeks and a change order for everything.",
    name: 'David L.',
    location: 'Scottsdale',
    service: 'Commercial HVAC Install',
  },
  {
    quote: "What got me is that they told me my old AC could last another two years with a repair instead of pushing me to replace. I've never had a contractor tell me to spend less money. They did the repair, and when I finally replaced it two years later, I called Skyhooked — obviously.",
    name: 'Patricia R.',
    location: 'Gilbert',
    service: 'AC Repair + Later Replacement',
  },
];

const guarantees = [
  {
    title: 'On-Time Guarantee',
    detail: 'If we miss the appointment window without advance notice, your service call fee is on us. Your time is valuable.',
  },
  {
    title: '1-Year Workmanship Warranty',
    detail: 'Every job is covered by a 1-year workmanship warranty. If something we did causes a problem within a year, we fix it at no charge. Comfort Plan members get 3- or 5-year coverage.',
  },
  {
    title: 'Property Protection Guarantee',
    detail: "If we damage your home — floors, walls, furniture, landscaping — we fix it on our dime, period. Our techs carry drop cloths and boot covers on every call for a reason.",
  },
  {
    title: 'Comfort Guarantee on Installs',
    detail: "If your new system doesn't meet the temperature performance we promised, we'll modify or remove and refund. We size systems with Manual J calculations so this almost never applies — but the guarantee is there.",
  },
];
---

<BaseLayout
  title="Why Choose Skyhooked on Comfort | Phoenix Valley's Top-Rated HVAC Contractor"
  description="See how Skyhooked on Comfort compares to big franchise HVAC companies and budget contractors. Flat-rate pricing, Manual J installs, same-day service, written guarantees."
>

  <!-- Hero -->
  <section class="bg-charcoal py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl leading-tight mb-6">
        You have options.<br/>Here's why the Phoenix Valley keeps choosing us.
      </h1>
      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-3xl mx-auto leading-relaxed">
        We won't tell you the others are terrible. Some aren't. But the differences below are real, they're consistent, and they're why 500+ customers have left us 4.9-star reviews.
      </p>
    </div>
  </section>


  <!-- Comparison Table -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-12">How we compare</h2>
      <div class="overflow-x-auto rounded-2xl border border-neutral-200 shadow-sm">
        <table class="w-full min-w-[640px]">
          <thead>
            <tr class="bg-charcoal">
              <th class="text-left font-display font-bold text-charcoal-50 text-sm px-6 py-4 w-1/3">What matters to you</th>
              <th class="text-center font-display font-bold text-sky text-sm px-4 py-4">Skyhooked on Comfort</th>
              <th class="text-center font-display font-bold text-neutral-400 text-sm px-4 py-4">Big Franchise</th>
              <th class="text-center font-display font-bold text-neutral-400 text-sm px-4 py-4">Budget Contractor</th>
            </tr>
          </thead>
          <tbody>
            {comparison.map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-charcoal-50'}>
                <td class="font-body text-charcoal text-sm font-semibold px-6 py-4">{row.feature}</td>
                <td class="text-center px-4 py-4">
                  {row.us === true ? (
                    <span class="inline-flex items-center justify-center w-6 h-6 bg-sky/20 rounded-full">
                      <svg class="w-4 h-4 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                    </span>
                  ) : (
                    <span class="font-body text-sky text-xs font-semibold">{row.us}</span>
                  )}
                </td>
                <td class="text-center px-4 py-4">
                  {row.franchise === true ? (
                    <span class="inline-flex items-center justify-center w-6 h-6 bg-neutral-100 rounded-full">
                      <svg class="w-4 h-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                    </span>
                  ) : row.franchise === false ? (
                    <span class="inline-flex items-center justify-center w-6 h-6 bg-neutral-100 rounded-full">
                      <svg class="w-4 h-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    </span>
                  ) : (
                    <span class="font-body text-neutral-500 text-xs">{row.franchise}</span>
                  )}
                </td>
                <td class="text-center px-4 py-4">
                  {row.budget === true ? (
                    <span class="inline-flex items-center justify-center w-6 h-6 bg-neutral-100 rounded-full">
                      <svg class="w-4 h-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                    </span>
                  ) : row.budget === false ? (
                    <span class="inline-flex items-center justify-center w-6 h-6 bg-neutral-100 rounded-full">
                      <svg class="w-4 h-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    </span>
                  ) : (
                    <span class="font-body text-neutral-500 text-xs">{row.budget}</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>


  <!-- Testimonials -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-4">What customers say after choosing us.</h2>
        <p class="font-body text-neutral-600 text-lg">These are real reviews from Phoenix Valley customers who considered alternatives.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {testimonials.map(review => (
          <blockquote class="bg-white rounded-2xl p-7 border border-charcoal/10 hover:shadow-lg transition-shadow">
            <div class="flex items-center gap-1 mb-4" aria-label="5 stars">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
              ))}
            </div>
            <p class="font-body text-neutral-700 leading-relaxed mb-5 text-sm">"{review.quote}"</p>
            <footer class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-xs">
                {review.name.split(' ').map((n: string) => n[0]).join('')}
              </div>
              <div>
                <cite class="font-body font-semibold text-charcoal not-italic text-sm">{review.name}</cite>
                <p class="font-body text-neutral-500 text-xs">{review.location} · {review.service}</p>
              </div>
            </footer>
          </blockquote>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/reviews" class="inline-flex items-center gap-2 font-display font-bold text-charcoal hover:text-charcoal-light transition-colors">
          Read all 500+ reviews →
        </a>
      </div>
    </div>
  </section>


  <!-- Guarantees -->
  <section class="bg-charcoal py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-white text-3xl sm:text-4xl mb-4">Our guarantees, in writing.</h2>
        <p class="font-body text-charcoal-50 text-lg max-w-2xl mx-auto">Not suggestions. Not aspirations. Written commitments on every job.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {guarantees.map(g => (
          <div class="bg-white/10 rounded-2xl p-7 border border-white/10">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-sky/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
              </div>
              <div>
                <h3 class="font-display font-bold text-white text-lg mb-2">{g.title}</h3>
                <p class="font-body text-charcoal-50 text-sm leading-relaxed">{g.detail}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Bottom CTA -->
  <section class="bg-white py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-4">Ready to see the difference?</h2>
      <p class="font-body text-neutral-600 text-lg mb-10">Call us or request a quote. No pressure, no upsell — just a straight diagnosis and honest pricing.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="flex items-center gap-2 bg-charcoal hover:bg-charcoal-light text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Request a Quote →
        </a>
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-sm font-body text-neutral-500">
        <a href="/about" class="hover:text-charcoal transition-colors">Our Story</a>
        <a href="/about/team" class="hover:text-charcoal transition-colors">Meet the Team</a>
        <a href="/reviews" class="hover:text-charcoal transition-colors">Reviews</a>
        <a href="/maintenance-plans" class="hover:text-charcoal transition-colors">Maintenance Plans</a>
      </div>
    </div>
  </section>

</BaseLayout>
