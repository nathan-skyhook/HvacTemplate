---
import BaseLayout from '../../layouts/BaseLayout.astro';

const acChecklist = [
  'Clean condenser coil (outdoor unit)',
  'Check refrigerant pressure and inspect for leaks',
  'Test capacitor and contactor',
  'Inspect and test contactor contacts',
  'Measure compressor amperage draw',
  'Clean evaporator coil (indoor unit)',
  'Clear condensate drain line',
  'Inspect and test blower motor and wheel',
  'Check all electrical connections and terminals',
  'Test thermostat calibration and operation',
  'Replace 1-inch air filter (or inspect 4–5 inch)',
  'Measure supply and return air temperatures (Delta-T)',
];

const heatingChecklist = [
  'Inspect heat exchanger for cracks (carbon monoxide hazard)',
  'Clean and inspect burners',
  'Test igniter and flame sensor',
  'Measure combustion efficiency (gas appliances)',
  'Inspect and clean blower motor and wheel',
  'Check all gas connections and valve operation',
  'Test limit switches and safety controls',
  'Inspect flue and venting for blockages',
  'Check all electrical connections and terminals',
  'Test thermostat operation in heating mode',
  'Replace 1-inch filter (or inspect larger)',
  'Measure temperature rise across heat exchanger',
];

const faqs = [
  { q: 'When should I schedule my AC tune-up in Phoenix?', a: 'March or April — before the heat arrives. By May, we\'re fully booked and emergency response times stretch. Spring is also when capacitors and contactors that degraded over last summer show up in diagnostics, before they fail on the hottest day of the year.' },
  { q: 'When should I schedule my heating tune-up?', a: 'September or October, before the first cold snap. Phoenix winters are mild but lows can hit the upper 30s in December and January — that\'s when you find out your furnace hasn\'t been serviced in three years.' },
  { q: 'Does my manufacturer warranty require annual tune-ups?', a: 'Yes. Most major manufacturers (Carrier, Trane, Lennox, Goodman, Rheem) require annual maintenance documented by a licensed contractor to honor the warranty on parts. We provide a written service report after every visit that satisfies this requirement.' },
  { q: 'What\'s the difference between a tune-up and a Comfort Plan?', a: 'A tune-up is a one-time service. The Comfort Plan includes both spring and fall tune-ups annually, plus priority scheduling, no overtime fees, 15% off all repairs, and extended warranty coverage. Most members save more than the plan costs on their first repair.' },
  { q: 'Can I get a tune-up if my system is old?', a: 'Absolutely. In fact, older systems need tune-ups more — not less. A 15-year-old AC with a failing capacitor costs $80 to fix during a tune-up. The same capacitor failing mid-July is a $300 emergency call. We\'ll also give you an honest assessment of whether repair or replacement makes more financial sense.' },
];
---

<BaseLayout
  title="AC & Heating Tune-Ups in Phoenix, AZ | Skyhooked on Comfort"
  description="Spring AC and fall heating tune-ups in Phoenix. 22-point inspection, flat-rate $79. Comfort Plan members get both included. Book before the rush. Call (480) 123-4567."
>
  <script type="application/ld+json" is:inline>
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "HVAC Maintenance Tune-Up", "provider": { "@type": "HVACBusiness", "name": "Skyhooked on Comfort", "telephone": "(480) 123-4567", "address": { "@type": "PostalAddress", "addressLocality": "Phoenix", "addressRegion": "AZ" } }, "areaServed": "Phoenix Valley, AZ", "offers": { "@type": "Offer", "price": "79", "priceCurrency": "USD", "description": "22-point HVAC tune-up" } }
  </script>

  <section class="relative py-24 lg:py-32 overflow-hidden" style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 60%, oklch(0.30 0.025 253) 100%);">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">Spring AC Tune-Up · Fall Heating Tune-Up</div>
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">HVAC Tune-Ups & Maintenance in <span class="text-sky">Phoenix, AZ</span></h1>
      <p class="font-body text-neutral-300 text-lg sm:text-xl max-w-2xl mx-auto mb-6">A capacitor caught in March costs $80. The same capacitor failing on July 4th is a $300 emergency call. Tune-ups are how we find the $80 problems before they become the $300 ones.</p>
      <div class="inline-flex items-center gap-3 bg-sky/20 border border-sky/30 text-sky rounded-xl px-6 py-3 mb-10">
        <span class="font-display font-extrabold text-2xl">$79</span>
        <span class="font-body text-sm">Spring AC Tune-Up Special — limited spots available</span>
      </div>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Book a Tune-Up →</a>
      </div>
    </div>
  </section>

  <!-- Checklists -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-12">What's in a 22-point tune-up</h2>
      <div class="grid sm:grid-cols-2 gap-8">
        <div>
          <h3 class="font-display font-bold text-charcoal text-xl mb-5 flex items-center gap-2">
            <span class="w-8 h-8 bg-sky/10 rounded-lg flex items-center justify-center text-sky text-sm">☀</span>
            Spring AC Tune-Up
          </h3>
          <ul class="space-y-2">
            {acChecklist.map(item => (
              <li class="flex items-start gap-2 font-body text-neutral-600 text-sm">
                <svg class="w-4 h-4 text-sky flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-display font-bold text-charcoal text-xl mb-5 flex items-center gap-2">
            <span class="w-8 h-8 bg-sky/10 rounded-lg flex items-center justify-center text-sky text-sm">❄</span>
            Fall Heating Tune-Up
          </h3>
          <ul class="space-y-2">
            {heatingChecklist.map(item => (
              <li class="flex items-start gap-2 font-body text-neutral-600 text-sm">
                <svg class="w-4 h-4 text-sky flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Comfort Plan callout -->
  <section class="bg-charcoal py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-2xl sm:text-3xl mb-3">Both tune-ups included with the Comfort Plan</h2>
      <p class="font-body text-neutral-300 text-lg mb-6">Starting at $24.99/month — two tune-ups, priority scheduling, 15% off all repairs, 5-year extended warranty, and no overtime fees. Most members save more than the plan costs on their first repair call.</p>
      <a href="/maintenance-plans" class="inline-flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold px-7 py-3.5 rounded-xl transition-colors">See Comfort Plan details →</a>
    </div>
  </section>

  <!-- Review -->
  <section class="bg-white py-20">
    <div class="max-w-3xl mx-auto px-4">
      <blockquote class="bg-charcoal-50 rounded-2xl p-8 border border-neutral-200">
        <div class="flex gap-1 mb-4">{Array(5).fill(null).map(() => <svg class="w-5 h-5 text-sky" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>)}</div>
        <p class="font-body text-neutral-700 text-lg leading-relaxed mb-5">"Book this in March. I waited until May and couldn't get an appointment for two weeks. The tech found a capacitor reading low — he replaced it for $85 on the spot. My neighbor waited, his capacitor failed in July during a 113°F stretch, and he paid $250 emergency rate. Same part, different timing."</p>
        <footer class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">DB</div>
          <div><cite class="font-body font-semibold text-charcoal not-italic text-sm">David B.</cite><p class="font-body text-neutral-500 text-xs">Mesa · Spring AC Tune-Up</p></div>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl text-center mb-10">Tune-up FAQ</h2>
      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors" aria-expanded="false" data-index={i}>
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5"><p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-4">Beat the summer rush.</h2>
      <p class="font-body text-neutral-300 text-lg mb-8">Spring slots fill up fast. Book your $79 AC tune-up now and head into summer knowing your system is ready.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Book Online →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) { panel.classList.remove('hidden'); chevron?.classList.add('rotate-180'); btn.setAttribute('aria-expanded', 'true'); }
    });
  });
</script>
