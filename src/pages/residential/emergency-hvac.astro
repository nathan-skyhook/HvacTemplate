---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqs = [
  {
    q: 'How fast can you actually be at my house?',
    a: 'Most Phoenix Valley emergency calls are dispatched within 30 minutes and on-site within 60 minutes. We run dedicated emergency crews 24 hours a day, 365 days a year — including Thanksgiving, Christmas, and July 4th.',
  },
  {
    q: 'Do you charge extra for nights or weekends?',
    a: 'No. Flat-rate pricing applies at 2pm on a Tuesday and 2am on a Sunday. No overtime fees, no holiday surcharges, no after-hours multipliers. You\'ll receive a written quote before any work starts.',
  },
  {
    q: 'Do you actually answer the phone at 3am?',
    a: 'Yes — a real human in Arizona, not a call center or voicemail. When you call (480) 123-4567, someone picks up. Every time. That\'s not a marketing line; it\'s how we\'ve operated since 2010.',
  },
  {
    q: 'What if I\'m not sure it\'s a real emergency?',
    a: 'Call us anyway. If your system is misbehaving in Phoenix\'s 110°+ heat or on a 35°F winter night, we\'d rather talk you through it for free than have you wait. We\'ll let you know if it can hold until morning.',
  },
  {
    q: 'Can I file the repair with my homeowner\'s insurance?',
    a: 'In many cases, yes — especially if the failure caused property damage (water, mold, frozen pipes). We provide detailed invoices and document the cause clearly. Check your policy and call your agent.',
  },
];
---

<BaseLayout
  title="24/7 Emergency HVAC Phoenix Valley | Skyhooked on Comfort"
  description="Emergency HVAC service across the Phoenix Valley, 24/7. No overtime fees. Real humans answer at 3am. Typical response under 60 minutes. Call (480) 123-4567."
>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Emergency HVAC Repair",
    "provider": {
      "@type": "HVACBusiness",
      "name": "Skyhooked on Comfort",
      "telephone": "(480) 123-4567",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Phoenix",
        "addressRegion": "AZ",
        "addressCountry": "US"
      }
    },
    "areaServed": {
      "@type": "Place",
      "name": "Phoenix Valley, AZ"
    },
    "description": "24/7 residential emergency HVAC service across the Phoenix Valley. No overtime fees. Real technicians dispatched within 60 minutes.",
    "availableChannel": {
      "@type": "ServiceChannel",
      "servicePhone": "+14801234567",
      "availableLanguage": "English"
    }
  }
  </script>

  <!-- ==========================================
       Hero — Emergency Red
       ========================================== -->
  <section class="bg-emergency py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-white"></span>
        </span>
        24/7 Emergency — Phoenix Valley
      </div>

      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        24/7 Emergency HVAC<br class="hidden sm:block"/>
        in the Phoenix Valley
      </h1>

      <p class="font-body text-white/90 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        Real humans answer the phone around the clock. Typical on-site response time across the Phoenix Valley: under 60 minutes. No overtime fees. No holiday surcharges. Just a flat-rate quote and a technician on the way.
      </p>

      <a
        href="tel:4801234567"
        class="inline-flex items-center gap-3 bg-sky hover:bg-sky-dark text-charcoal font-display font-extrabold text-2xl px-10 py-5 rounded-2xl transition-colors shadow-xl mb-4"
      >
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Call (480) 123-4567 Now
      </a>
      <p class="font-body text-white/80 text-sm">Available 24/7 · No overtime fees · Real humans answer</p>
    </div>
  </section>


  <!-- ==========================================
       What's Included
       ========================================== -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">
          What our emergency HVAC service includes
        </h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">
          Every emergency call is handled the same way a regular call is — diagnosis first, flat-rate quote, work only after you approve.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { heading: 'Full System Diagnosis', body: 'We don\'t just patch the symptom. The technician runs a complete diagnostic so you know exactly what failed and why.' },
          { heading: 'All Makes & Models', body: 'Carrier, Trane, Lennox, Goodman, Rheem, American Standard, Daikin, Mitsubishi, York — if it cools or heats, we service it.' },
          { heading: 'Parts On the Truck', body: 'Our emergency trucks are stocked with the most common failure parts — capacitors, contactors, motor start kits, igniters, blower motors — to fix most issues in one visit.' },
          { heading: 'Written Flat-Rate Quote', body: 'Before we turn a wrench, you get a written price. No hidden fees, no surprise add-ons, no after-hours markup. The price you approve is the price you pay.' },
          { heading: 'Refrigerant Leak Repair', body: 'EPA 608 Universal certified technicians handle refrigerant — R-22 (legacy systems), R-410A, and R-454B — safely and legally.' },
          { heading: '1-Year Workmanship Warranty', body: 'Every emergency repair is backed by our standard 1-year workmanship warranty. Comfort Plan members get extended coverage.' },
        ].map(item => (
          <div class="bg-charcoal-50 rounded-2xl p-6 border border-charcoal/10">
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{item.heading}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ==========================================
       Phoenix Heat Context
       ========================================== -->
  <section class="bg-charcoal py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display font-bold text-white text-3xl sm:text-4xl mb-6">
            No AC in Phoenix isn't uncomfortable — it's dangerous
          </h2>
          <p class="font-body text-charcoal-50 text-lg leading-relaxed mb-6">
            Phoenix experiences over 110 days per year above 100°F, with temperatures regularly topping 115°F in June, July, and August. When an AC fails in that environment, indoor temperatures can reach 100°F within hours — a genuine health emergency for seniors, children, and pets.
          </p>
          <p class="font-body text-charcoal-50 text-lg leading-relaxed mb-6">
            Phoenix's winters bring their own surprises too. Cold snaps can drive overnight lows into the low 30s, and homes that rely on heat strips rather than gas furnaces can get dangerously cold if the system fails or trips a breaker.
          </p>
          <p class="font-body text-charcoal-50 text-lg leading-relaxed">
            That's why we run emergency crews every hour of every day. We've been doing it since 2010, and we've never missed a call because "it was too late" or "it was a holiday."
          </p>
        </div>
        <div class="space-y-4">
          {[
            { stat: '110°F+', label: 'Peak summer days in Phoenix', sub: 'Regularly exceeded in June–August' },
            { stat: '< 60 min', label: 'Typical on-site response', sub: 'Across the Phoenix Valley' },
            { stat: '365 days', label: 'Emergency availability', sub: 'Including holidays and 3am' },
            { stat: '$0', label: 'Extra after-hours fee', sub: 'Flat-rate pricing, always' },
          ].map(item => (
            <div class="bg-charcoal-light/40 rounded-xl p-5 border border-white/10 flex items-center gap-5">
              <div class="font-display font-extrabold text-sky text-2xl min-w-[80px]">{item.stat}</div>
              <div>
                <div class="font-display font-bold text-white text-sm">{item.label}</div>
                <div class="font-body text-charcoal-50 text-xs">{item.sub}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ==========================================
       Our Process — 3 Steps
       ========================================== -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">
          What happens when you call
        </h2>
        <p class="font-body text-neutral-500 text-lg">From your call to cool air — here's how it works.</p>
      </div>

      <div class="grid sm:grid-cols-3 gap-6">
        {[
          { num: '01', heading: 'You Call — We Answer', body: 'A real human at (480) 123-4567 picks up 24/7. They\'ll ask a few quick questions about your system, confirm your address, and have a technician dispatched — typically within 30 minutes.' },
          { num: '02', heading: 'Tech Dispatched to You', body: 'You\'ll get a text with your technician\'s name, photo, EPA certifications, and live GPS ETA. Our emergency trucks carry the most common failure parts so most repairs are completed in a single visit.' },
          { num: '03', heading: 'Diagnosed, Quoted, Fixed', body: 'The technician diagnoses the issue, explains it to you in plain language, and gives you a written flat-rate quote. You approve it. He fixes it. You\'re comfortable again.' },
        ].map(step => (
          <div class="bg-white rounded-2xl p-7 border border-charcoal/10 hover:shadow-lg transition-shadow">
            <div class="font-display font-extrabold text-sky text-3xl mb-3">{step.num}</div>
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{step.heading}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ==========================================
       Reviews
       ========================================== -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-10">
        What Phoenix Valley homeowners say
      </h2>

      <div class="grid sm:grid-cols-2 gap-6">
        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4" aria-label="5 stars">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
            ))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "AC died on July 4th with the whole family in from out of town. I called four other companies — all voicemail. Skyhooked answered on the first ring. Tech was at our door in under an hour, replaced the capacitor, and we were back up before dinner. No holiday fee, no upsell, no drama."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">KT</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Karen T.</cite>
              <p class="font-body text-neutral-500 text-xs">Phoenix · Emergency AC — July 4th</p>
            </div>
          </footer>
        </blockquote>

        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4" aria-label="5 stars">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
            ))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "Furnace stopped working at 5:30am on a January morning when it was 34°F outside. Called Skyhooked, got a real person immediately. Tech arrived by 7am, replaced the igniter, and had the house warming before my kids woke up. Could have been a very bad day. These guys are the real deal."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">DB</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">David B.</cite>
              <p class="font-body text-neutral-500 text-xs">Mesa · Emergency Furnace Repair</p>
            </div>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>


  <!-- ==========================================
       FAQ
       ========================================== -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-10">
        Emergency HVAC — common questions
      </h2>

      <div class="space-y-3 mb-10">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button
              class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors"
              aria-expanded="false"
              data-index={i}
            >
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5">
              <p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ==========================================
       Related Services
       ========================================== -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-8 text-center">Related services</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          { href: '/residential/ac-repair', name: 'AC Repair', desc: 'Same-day diagnostic and flat-rate fix for any AC issue.' },
          { href: '/residential/heating-repair', name: 'Heating Repair', desc: 'Furnaces, heat pumps, heat strips — all brands repaired.' },
          { href: '/residential/tune-ups-maintenance', name: 'Tune-Ups & Maintenance', desc: 'Prevent emergencies with twice-yearly precision tune-ups.' },
        ].map(s => (
          <a href={s.href} class="group bg-charcoal-50 hover:bg-charcoal rounded-xl p-5 border border-charcoal/10 hover:border-charcoal transition-colors">
            <h3 class="font-display font-bold text-charcoal group-hover:text-white text-sm mb-1 transition-colors">{s.name}</h3>
            <p class="font-body text-neutral-500 group-hover:text-charcoal-50 text-xs transition-colors">{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- ==========================================
       Bottom CTA — Emergency Red
       ========================================== -->
  <section class="bg-emergency py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl lg:text-5xl mb-6 leading-tight">
        No cool in 115°?<br/>No heat on a cold night?<br/>
        <span class="text-sky">Call right now.</span>
      </h2>
      <a
        href="tel:4801234567"
        class="inline-flex items-center gap-3 bg-sky hover:bg-sky-dark text-charcoal font-display font-extrabold text-2xl px-10 py-5 rounded-2xl transition-colors shadow-xl mb-6"
      >
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Call (480) 123-4567 Now
      </a>
      <p class="font-body text-white/80 text-base">Available 24/7 · No overtime fees · Real humans answer</p>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) {
        panel.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
