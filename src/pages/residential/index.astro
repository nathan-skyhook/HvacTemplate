---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  {
    href: '/residential/emergency-hvac',
    name: 'Emergency HVAC',
    desc: 'No cool, no heat? We\'re 24/7, no overtime fees.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>`,
  },
  {
    href: '/residential/ac-repair',
    name: 'AC Repair',
    desc: 'Same-day diagnostic, flat-rate fix, all brands.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l5.653-4.655m5.585-5.586l3.497-3.497a.525.525 0 01.743.743l-3.497 3.497"/>`,
  },
  {
    href: '/residential/ac-installation',
    name: 'AC Installation',
    desc: 'High-efficiency systems, financing available.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>`,
  },
  {
    href: '/residential/heating-repair',
    name: 'Heating Repair',
    desc: 'Furnaces, boilers, heat pumps — all brands.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/>`,
  },
  {
    href: '/residential/heating-installation',
    name: 'Heating Installation',
    desc: 'New furnace, boiler, or heat pump installs.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>`,
  },
  {
    href: '/residential/heat-pump-installation',
    name: 'Heat Pump Installation',
    desc: '30% federal tax credit + utility rebates.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z"/>`,
  },
  {
    href: '/residential/ductless-mini-splits',
    name: 'Ductless Mini-Splits',
    desc: 'Mitsubishi, Daikin, LG, Fujitsu — single or multi-zone.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>`,
  },
  {
    href: '/residential/indoor-air-quality',
    name: 'Indoor Air Quality',
    desc: 'Filtration, UV-C, humidifiers, dehumidifiers, ERVs.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>`,
  },
  {
    href: '/residential/duct-cleaning-sealing',
    name: 'Duct Cleaning & Sealing',
    desc: 'Inspection, cleaning, Aeroseal sealing.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z"/>`,
  },
  {
    href: '/residential/smart-thermostats',
    name: 'Smart Thermostats',
    desc: 'Nest, ecobee, Honeywell Home — installed & configured.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 8.25h3m-3 3.75h3"/>`,
  },
  {
    href: '/residential/tune-ups-maintenance',
    name: 'Tune-Ups & Maintenance',
    desc: 'Spring AC + fall heating, 22-point inspection.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
  {
    href: '/residential/zoning-controls',
    name: 'Zoning Controls',
    desc: 'Multi-zone comfort for large homes and additions.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>`,
  },
];

const warningSigns = [
  'AC is running but not cooling, or short-cycling (turning on and off rapidly)',
  'Furnace won\'t ignite, runs cold, or keeps short-cycling',
  'Some rooms are significantly hotter or colder than others',
  'Energy bills are climbing with no other explanation',
  'Loud, grinding, rattling, or screeching noises from your indoor or outdoor unit',
  'Ice on the outdoor coil or indoor evaporator',
  'Water pooling around the indoor unit or drain pan',
  'System is 12+ years old and needs another expensive repair',
  'Humidity stays high even with the AC running',
  'CO detector triggered or you smell gas — call your gas utility immediately too',
];

const processSteps = [
  {
    num: '01',
    heading: 'Call or Book Online',
    body: 'A real human at our Phoenix office answers, asks a few quick questions about your system, and books your appointment window — same day on most calls.',
  },
  {
    num: '02',
    heading: 'On-the-Way Notification',
    body: 'You\'ll get a text with your technician\'s name, photo, certifications, and live ETA before we arrive.',
  },
  {
    num: '03',
    heading: 'Flat-Rate Quote Before Any Work',
    body: 'The tech inspects your system, explains the issue in plain language, and hands you a written flat-rate quote. Work starts only after you approve it.',
  },
  {
    num: '04',
    heading: 'Work Done Right, Guaranteed',
    body: 'EPA-certified technician does the work, permits pulled when required, inspection scheduled, area left cleaner than found, and a 1-year workmanship warranty in your inbox.',
  },
];
---

<BaseLayout
  title="Residential HVAC Services in Phoenix | Skyhooked on Comfort"
  description="Full-service residential HVAC in the Phoenix Valley. AC, heating, heat pumps, mini-splits, IAQ, ducts, smart thermostats, 24/7 emergency. Licensed and insured."
>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Residential HVAC Services",
    "provider": {
      "@type": "HVACBusiness",
      "name": "Skyhooked on Comfort",
      "telephone": "(480) 123-4567",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Phoenix",
        "addressRegion": "AZ",
        "addressCountry": "US"
      }
    },
    "areaServed": {
      "@type": "Place",
      "name": "Phoenix Valley, AZ"
    },
    "description": "Full-service residential HVAC including AC repair, AC installation, heating, heat pumps, mini-splits, indoor air quality, duct cleaning, smart thermostats, tune-ups, and zoning."
  }
  </script>

  <!-- ==========================================
       Hero
       ========================================== -->
  <section
    class="relative min-h-[60vh] flex flex-col justify-center bg-charcoal overflow-hidden"
    style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 60%, oklch(0.24 0.025 253) 100%);"
  >
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full opacity-10" style="background: radial-gradient(circle, oklch(0.58 0.13 233), transparent);"></div>
      <div class="absolute bottom-0 -left-20 w-80 h-80 rounded-full opacity-5" style="background: radial-gradient(circle, oklch(0.58 0.13 233), transparent);"></div>
    </div>

    <div class="relative max-w-5xl mx-auto px-4 py-24 lg:py-32 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
        </svg>
        Residential HVAC — Phoenix Valley
      </div>

      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        Residential HVAC Services<br class="hidden sm:block"/>
        for the <span class="text-sky">Phoenix Valley</span>
      </h1>

      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        From a quick AC tune-up to a full heat pump replacement, Skyhooked on Comfort handles every comfort project in your home — safe, efficient, right-sized, and guaranteed. Serving Phoenix homeowners since 2010.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="tel:4801234567"
          class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a
          href="/contact"
          class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors"
        >
          Request a Quote →
        </a>
      </div>
    </div>
  </section>


  <!-- ==========================================
       Services Grid — 12 cards
       ========================================== -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">
          Every residential HVAC service you need
        </h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">
          One call covers all of it — whether it's an emergency fix or a planned upgrade.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {services.map(service => (
          <a
            href={service.href}
            class="group bg-neutral-50 hover:bg-charcoal rounded-2xl p-6 transition-colors border border-neutral-100 hover:border-charcoal"
          >
            <div class="w-11 h-11 bg-sky/15 group-hover:bg-sky/20 rounded-xl flex items-center justify-center mb-4 transition-colors">
              <svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true" set:html={service.icon}></svg>
            </div>
            <h3 class="font-display font-bold text-charcoal group-hover:text-white text-base mb-1.5 transition-colors">{service.name}</h3>
            <p class="font-body text-neutral-500 group-hover:text-charcoal-50 text-sm mb-3 transition-colors">{service.desc}</p>
            <span class="font-body text-sky text-sm font-semibold">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- ==========================================
       When to Call Us
       ========================================== -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-4">
            When to call us
          </h2>
          <p class="font-body text-neutral-600 text-lg mb-8 leading-relaxed">
            Most HVAC problems get worse — and more expensive — the longer they wait. In Phoenix's 110°+ summers, a slow AC problem can become a safety issue overnight. Call us if you notice any of these signs:
          </p>
          <a href="tel:4801234567" class="inline-flex items-center gap-2 bg-charcoal hover:bg-charcoal-light text-white font-display font-bold px-6 py-3 rounded-lg transition-colors">
            Call (480) 123-4567 →
          </a>
        </div>
        <ul class="space-y-3">
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSign => warningSign}
          {warningSigns.map(sign => (
            <li class="flex items-start gap-3 font-body text-neutral-700">
              <svg class="w-5 h-5 text-sky flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
              </svg>
              {sign}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>


  <!-- ==========================================
       Our Process — 4-step flow
       ========================================== -->
  <section class="bg-charcoal py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-white text-3xl sm:text-4xl mb-3">
          Our process — simple from first call to final test
        </h2>
        <p class="font-body text-charcoal-50 text-lg max-w-xl mx-auto">
          No surprises, no pressure, no work without your approval.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {processSteps.map(step => (
          <div class="bg-charcoal-light/40 rounded-2xl p-6 border border-white/10">
            <div class="font-display font-extrabold text-sky text-3xl mb-3">{step.num}</div>
            <h3 class="font-display font-bold text-white text-base mb-2">{step.heading}</h3>
            <p class="font-body text-charcoal-50 text-sm leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ==========================================
       Reviews Snapshot
       ========================================== -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center gap-1 mb-3" aria-label="4.9 out of 5 stars">
          {[...Array(5)].map(() => (
            <svg class="w-6 h-6 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
          ))}
        </div>
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-2">
          4.9 ★★★★★ from 500+ Google reviews
        </h2>
        <p class="font-body text-neutral-500">Real Phoenix Valley homeowners. Real results.</p>
      </div>

      <div class="grid sm:grid-cols-2 gap-6 mb-10">
        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4" aria-label="5 stars">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
            ))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "AC died on a Saturday in July — 109° outside. Skyhooked picked up on the first ring and had a tech at our door in 55 minutes. He found a bad capacitor, had the part on the truck, and had us cooling again within the hour. Price was exactly what he quoted before touching anything."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">JL</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Jennifer L.</cite>
              <p class="font-body text-neutral-500 text-xs">Chandler · AC Repair</p>
            </div>
          </footer>
        </blockquote>

        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4" aria-label="5 stars">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
            ))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "Replaced our aging furnace + AC with a Carrier heat pump. Marcus's team handled the Manual J, the permit, and the IRA tax credit paperwork. The whole process was transparent — three equipment options with real pricing, no pressure. We ended up saving $1,800 after the federal credit."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">RG</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Robert G.</cite>
              <p class="font-body text-neutral-500 text-xs">Scottsdale · Heat Pump Installation</p>
            </div>
          </footer>
        </blockquote>
      </div>

      <div class="text-center">
        <a href="/reviews" class="inline-flex items-center gap-2 text-charcoal hover:text-charcoal-light font-display font-bold transition-colors">
          Read all 500+ reviews →
        </a>
      </div>
    </div>
  </section>


  <!-- ==========================================
       Financing Strip
       ========================================== -->
  <section class="bg-sky py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-charcoal text-3xl sm:text-4xl mb-4">
        New system? Pay over time.
      </h2>
      <p class="font-body text-charcoal/80 text-lg mb-8 max-w-xl mx-auto">
        We've partnered with GoodLeap and Synchrony for 0% APR financing options. Apply in 90 seconds — soft credit pull, decision in minutes.
      </p>
      <a href="/financing" class="inline-flex items-center gap-2 bg-charcoal hover:bg-charcoal-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
        See Financing Options →
      </a>
    </div>
  </section>


  <!-- ==========================================
       Service Areas
       ========================================== -->
  <section class="bg-charcoal-50 py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display font-bold text-charcoal text-2xl sm:text-3xl mb-4">
        Serving all of the Phoenix Valley
      </h2>
      <p class="font-body text-neutral-600 mb-6">
