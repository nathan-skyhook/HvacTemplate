---
import BaseLayout from '../../layouts/BaseLayout.astro';

const brands = [
  { name: 'Mitsubishi Electric', note: 'Hyper-Heat line handles Phoenix summers and cool winters. Diamond Contractor service available.' },
  { name: 'Daikin', note: 'Owns the engineering stack. Excellent efficiency ratings and wide product range.' },
  { name: 'LG', note: 'Strong multi-zone lineup. Great fit for larger homes needing 4+ zones.' },
  { name: 'Fujitsu', note: 'Compact indoor units, whisper-quiet operation. Popular for bedrooms and home offices.' },
];

const useCases = [
  { title: 'Room Additions & AZ Rooms', desc: 'Extending your home without extending your ductwork. Mini-splits are the right tool for new square footage.' },
  { title: 'Garages & Workshops', desc: 'Detached garages and workshops have no ductwork and often need dedicated climate control for comfort or equipment protection.' },
  { title: 'Guest Casitas', desc: 'Detached guest quarters need their own system. A single-zone mini-split is the cleanest solution.' },
  { title: 'Older Homes Without Ducts', desc: 'Many Phoenix-area homes built before 1980 have no ductwork. Multi-zone mini-splits deliver whole-home comfort without duct installation.' },
  { title: 'Hot or Cold Zones', desc: "If one room is always 10°F off the rest of the house, a dedicated zone solves the problem without rebalancing the whole system." },
  { title: 'Energy Savings by Zone', desc: 'Condition only the rooms in use. A home office mini-split running 8 hours a day costs far less than cooling the whole house.' },
];

const faqs = [
  { q: 'How much does a mini-split cost to install in Phoenix?', a: 'A single-zone mini-split (9,000–18,000 BTU) typically runs $2,800–$5,500 installed. Multi-zone systems start around $6,000 for two zones and scale up. Variable-speed inverter models are at the higher end but deliver the best long-term efficiency.' },
  { q: 'Do mini-splits work in Phoenix\'s extreme heat?', a: 'Yes — with proper equipment selection. We spec units rated for 115°F+ ambient operation. Standard mini-splits can derate at high outdoor temperatures; we verify AHRI ratings at 95°F and 115°F before recommending any unit.' },
  { q: 'Can I qualify for the federal tax credit on a mini-split?', a: 'Yes. Qualifying ductless heat pump mini-splits are eligible for the federal 25C tax credit — 30% of equipment and installation cost, up to $2,000. We install qualifying units and provide the AHRI certificate.' },
  { q: 'How long does installation take?', a: 'Most single-zone installations are completed in one day. Multi-zone systems (3–5 zones) typically take two days. No major construction required — the only wall penetration is a 3-inch hole for the line set.' },
  { q: 'Do mini-splits need regular maintenance?', a: 'Yes — filters should be cleaned monthly or as needed, and a professional tune-up once a year covers refrigerant pressure, coil cleaning, and electrical inspection. Comfort Plan members get this included.' },
];
---

<BaseLayout
  title="Ductless Mini-Split Installation in Phoenix, AZ | Skyhooked on Comfort"
  description="Ductless mini-split installation and service across the Phoenix Valley. Mitsubishi, Daikin, LG, Fujitsu. Single and multi-zone systems. 30% federal tax credit available. Call (480) 123-4567."
>
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Ductless Mini-Split Installation",
    "provider": { "@type": "HVACBusiness", "name": "Skyhooked on Comfort", "telephone": "(480) 123-4567", "address": { "@type": "PostalAddress", "addressLocality": "Phoenix", "addressRegion": "AZ" } },
    "areaServed": "Phoenix Valley, AZ"
  }
  </script>

  <!-- Hero -->
  <section class="relative bg-charcoal py-24 lg:py-32 overflow-hidden" style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 60%, oklch(0.30 0.025 253) 100%);">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">No Ductwork Required</div>
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        Ductless Mini-Split Installation<br class="hidden sm:block"/> in <span class="text-sky">Phoenix, AZ</span>
      </h1>
      <p class="font-body text-neutral-300 text-lg sm:text-xl max-w-2xl mx-auto mb-10">
        Cool or heat any room — garage, addition, casita, home office — without touching your existing ductwork. Mitsubishi, Daikin, LG, and Fujitsu systems installed by EPA-certified technicians with a 100% satisfaction guarantee.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Request a Quote →</a>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-4">Who needs a mini-split?</h2>
        <p class="font-body text-neutral-600 text-lg max-w-2xl mx-auto">Mini-splits solve specific comfort problems that central HVAC can't — or can't solve economically.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {useCases.map(u => (
          <div class="bg-charcoal-50 rounded-2xl p-6 border border-neutral-200">
            <h3 class="font-display font-bold text-charcoal text-lg mb-2">{u.title}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Brands -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-12">Brands we install</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {brands.map(b => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-200 text-center hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 bg-sky/10 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>
            </div>
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{b.name}</h3>
            <p class="font-body text-neutral-600 text-sm">{b.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tax credit callout -->
  <section class="bg-sky py-14">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-2xl sm:text-3xl mb-3">30% Federal Tax Credit on Qualifying Mini-Splits</h2>
      <p class="font-body text-white/90 text-lg mb-6">Ductless heat pump mini-splits qualify for the IRA 25C tax credit — 30% of equipment and installation, up to $2,000 per year. We install qualifying units and provide all documentation for your CPA.</p>
      <a href="/financing" class="inline-flex items-center gap-2 bg-white hover:bg-neutral-100 text-charcoal font-display font-bold px-7 py-3.5 rounded-xl transition-colors">See Financing & Incentives →</a>
    </div>
  </section>

  <!-- Process -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-12">Our installation process</h2>
      <div class="space-y-6">
        {[
          { step: '01', title: 'Site visit & sizing', desc: 'We visit the space, measure square footage and ceiling height, assess sun exposure and insulation, and select the correctly sized unit — never oversize a mini-split.' },
          { step: '02', title: 'Equipment selection', desc: 'We present 2–3 options across good/better/best tiers. You see capacity, SEER2, sound rating, warranty, and installed price side by side.' },
          { step: '03', title: 'Installation day', desc: 'We mount the indoor air handler, install the outdoor condenser, run the line set and electrical, and commission the system. Most single-zone jobs are done in one day.' },
          { step: '04', title: 'Comfort test & walkthrough', desc: 'We run the system through all modes, verify temperatures and airflow, and show you how to use the remote and app. We leave when it\'s working perfectly.' },
        ].map(s => (
          <div class="flex gap-5 items-start">
            <div class="w-12 h-12 bg-sky/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <span class="font-display font-bold text-sky text-sm">{s.step}</span>
            </div>
            <div>
              <h3 class="font-display font-bold text-charcoal text-lg mb-1">{s.title}</h3>
              <p class="font-body text-neutral-600 leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Review -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl text-center mb-10">What customers say</h2>
      <blockquote class="bg-white rounded-2xl p-8 border border-neutral-200 shadow-sm">
        <div class="flex gap-1 mb-4">{Array(5).fill(null).map(() => <svg class="w-5 h-5 text-sky" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>)}</div>
        <p class="font-body text-neutral-700 text-lg leading-relaxed mb-5">"We added a 300 SF Arizona room to our Chandler home and had no idea how to cool it. Skyhooked installed a Mitsubishi single-zone mini-split in one day. It keeps the room 72°F even when the main house thermostat is at 78°. The installation was cleaner than I expected — you can barely see the line set."</p>
        <footer class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">RN</div>
          <div><cite class="font-body font-semibold text-charcoal not-italic text-sm">Rachel N.</cite><p class="font-body text-neutral-500 text-xs">Chandler · Arizona Room Mini-Split</p></div>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl text-center mb-10">Mini-split FAQ</h2>
      <div class="space-y-3 mb-10">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden">
            <button class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors" aria-expanded="false" data-index={i}>
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5"><p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="bg-charcoal-50 py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-6 text-center">Related services</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          { title: 'AC Installation', href: '/residential/ac-installation', desc: 'Central AC replacement and new installs.' },
          { title: 'Heat Pump Installation', href: '/residential/heat-pump-installation', desc: 'Whole-home heat pump with 30% federal credit.' },
          { title: 'Indoor Air Quality', href: '/residential/indoor-air-quality', desc: 'Filtration, UV purifiers, and humidity control.' },
        ].map(r => (
          <a href={r.href} class="bg-white rounded-xl p-5 border border-neutral-200 hover:shadow-md transition-shadow">
            <h3 class="font-display font-bold text-charcoal text-base mb-1">{r.title}</h3>
            <p class="font-body text-neutral-500 text-sm">{r.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-4">Ready to cool that room?</h2>
      <p class="font-body text-neutral-300 text-lg mb-8">Free in-home consultation. We'll size the unit correctly and give you a flat-rate quote. No surprise fees.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Request a Quote →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) { panel.classList.remove('hidden'); chevron?.classList.add('rotate-180'); btn.setAttribute('aria-expanded', 'true'); }
    });
  });
</script>
