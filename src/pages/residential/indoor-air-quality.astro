---
import BaseLayout from '../../layouts/BaseLayout.astro';

const products = [
  { name: 'Whole-Home Air Filtration', desc: 'MERV-13 to MERV-16 media filters installed in-line with your existing system. Captures dust, pollen, mold spores, and fine PM2.5 particles — the kind Phoenix haboobs generate.' },
  { name: 'UV-C Air Purifiers', desc: 'Germicidal UV-C lamps installed inside the air handler destroy bacteria, viruses, and mold spores at the source before they circulate through your home.' },
  { name: 'Whole-Home Humidifiers', desc: 'Phoenix winters are dry. Bypass and fan-powered humidifiers maintain 35–50% relative humidity — the range where viruses spread less and wood furniture doesn\'t crack.' },
  { name: 'Whole-Home Dehumidifiers', desc: 'Monsoon season (July–September) drives indoor humidity above 60%. A dedicated dehumidifier keeps it under control when your AC alone can\'t keep up.' },
  { name: 'Energy Recovery Ventilators (ERVs)', desc: 'Fresh air exchange without the energy penalty. ERVs bring in outside air while capturing 70–80% of the conditioned air\'s energy — critical for tightly built homes.' },
  { name: 'Electronic Air Cleaners', desc: 'Polarized media and electronic filter systems catch particles too small for standard filters — down to 0.1 microns — without restricting airflow like dense HEPA media can.' },
];

const phoenixContext = [
  { title: 'Haboob Season (April–September)', desc: 'Phoenix dust storms can deposit inches of fine particulate matter across the Valley in minutes. A MERV-13+ filter system is the first line of defense for your home and your HVAC equipment.' },
  { title: 'Wildfire Smoke (June–July)', desc: 'Pre-monsoon winds carry smoke from Arizona and California wildfires across the Valley. PM2.5 levels spike — often reaching "Unhealthy for Sensitive Groups" AQI — for days at a time.' },
  { title: 'Monsoon Humidity (July–September)', desc: 'Relative humidity that sits at 10–20% all spring suddenly jumps to 50–70% during monsoon season. That moisture feeds mold growth in ducts and air handlers if left unmanaged.' },
  { title: 'Dry Winter Air', desc: 'From October through April, Phoenix outdoor air is extremely dry. Forced-air heating makes it worse. Low humidity irritates airways, dries out skin, and makes the air feel colder than it is.' },
];

const faqs = [
  { q: 'How do I know if I need an air purifier or better filtration?', a: 'Signs include increased dust on surfaces shortly after cleaning, allergy or asthma symptoms that worsen indoors, visible mold near vents, or recent wildfire smoke or dust storm intrusion. We\'ll assess your current setup during any service visit.' },
  { q: 'Will a better filter reduce my AC\'s airflow?', a: 'Improperly sized or overly restrictive filters absolutely can — a MERV-16 filter in a system designed for MERV-8 starves the blower of airflow, raises static pressure, and stresses the equipment. We select filters appropriate for your specific system\'s airflow specs.' },
  { q: 'Do UV lights really work?', a: 'Yes — for what they\'re designed for. Germicidal UV-C at the correct wavelength (254nm) and sufficient exposure time destroys DNA in bacteria, viruses, and mold cells. It works on biological contaminants; it doesn\'t filter out particles. The best setups combine UV with proper filtration.' },
  { q: 'How much does whole-home IAQ equipment cost?', a: 'Filtration upgrades start around $200–$600 installed. UV systems run $400–$900. Whole-home humidifiers are $600–$1,200 installed. ERVs range from $1,500–$3,000 installed. We\'ll recommend only what actually makes sense for your home and budget.' },
];
---

<BaseLayout
  title="Indoor Air Quality Services in Phoenix, AZ | Skyhooked on Comfort"
  description="Whole-home air filtration, UV purifiers, humidifiers, and dehumidifiers for Phoenix Valley homes. Protect your family from dust, wildfire smoke, and monsoon humidity. Call (480) 123-4567."
>
  <script type="application/ld+json" is:inline>
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Indoor Air Quality", "provider": { "@type": "HVACBusiness", "name": "Skyhooked on Comfort", "telephone": "(480) 123-4567", "address": { "@type": "PostalAddress", "addressLocality": "Phoenix", "addressRegion": "AZ" } }, "areaServed": "Phoenix Valley, AZ" }
  </script>

  <section class="relative bg-charcoal py-24 lg:py-32 overflow-hidden" style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 60%, oklch(0.30 0.025 253) 100%);">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">Filtration · UV · Humidity Control</div>
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        Indoor Air Quality for<br class="hidden sm:block"/> <span class="text-sky">Phoenix Valley Homes</span>
      </h1>
      <p class="font-body text-neutral-300 text-lg sm:text-xl max-w-2xl mx-auto mb-10">Phoenix has some of the most demanding air quality challenges in the country — haboobs, wildfire smoke, monsoon humidity, and bone-dry winters. We install the right combination of filtration, purification, and humidity control for your home.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Request a Quote →</a>
      </div>
    </div>
  </section>

  <!-- Phoenix air quality context -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-4">Phoenix's air quality challenges</h2>
        <p class="font-body text-neutral-600 text-lg max-w-2xl mx-auto">Our desert climate creates unique indoor air quality demands that most of the country doesn't face.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {phoenixContext.map(c => (
          <div class="bg-charcoal-50 rounded-2xl p-6 border border-neutral-200">
            <h3 class="font-display font-bold text-charcoal text-lg mb-2">{c.title}</h3>
            <p class="font-body text-neutral-600 leading-relaxed">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-12">IAQ solutions we install</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {products.map(p => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-200 hover:shadow-lg transition-shadow">
            <div class="w-11 h-11 bg-sky/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>
            </div>
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{p.name}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Review -->
  <section class="bg-white py-20">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl text-center mb-10">What customers say</h2>
      <blockquote class="bg-charcoal-50 rounded-2xl p-8 border border-neutral-200">
        <div class="flex gap-1 mb-4">{Array(5).fill(null).map(() => <svg class="w-5 h-5 text-sky" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>)}</div>
        <p class="font-body text-neutral-700 text-lg leading-relaxed mb-5">"Our son has severe dust allergies. After a particularly bad haboob season, we had Skyhooked install a MERV-13 filtration upgrade and a UV system. The difference was dramatic — our son's symptoms during dust storm season dropped significantly. The tech explained exactly what each component does and why. No upsell pressure."</p>
        <footer class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">LM</div>
          <div><cite class="font-body font-semibold text-charcoal not-italic text-sm">Linda M.</cite><p class="font-body text-neutral-500 text-xs">Peoria · Air Filtration + UV System</p></div>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl text-center mb-10">Common IAQ questions</h2>
      <div class="space-y-3 mb-10">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors" aria-expanded="false" data-index={i}>
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5"><p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-6 text-center">Related services</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          { title: 'Duct Cleaning & Sealing', href: '/residential/duct-cleaning-sealing', desc: 'Clean ducts deliver clean air.' },
          { title: 'Tune-Ups & Maintenance', href: '/residential/tune-ups-maintenance', desc: 'Includes coil and filter inspection.' },
          { title: 'Smart Thermostats', href: '/residential/smart-thermostats', desc: 'Monitor humidity and air quality remotely.' },
        ].map(r => (
          <a href={r.href} class="bg-charcoal-50 rounded-xl p-5 border border-neutral-200 hover:shadow-md transition-shadow">
            <h3 class="font-display font-bold text-charcoal text-base mb-1">{r.title}</h3>
            <p class="font-body text-neutral-500 text-sm">{r.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-4">Breathe easier this season.</h2>
      <p class="font-body text-neutral-300 text-lg mb-8">We'll assess your current setup and recommend only what makes sense for your home and family.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Request a Quote →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) { panel.classList.remove('hidden'); chevron?.classList.add('rotate-180'); btn.setAttribute('aria-expanded', 'true'); }
    });
  });
</script>
