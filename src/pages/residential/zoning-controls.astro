---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqs = [
  { q: 'How many zones can I add to my home?', a: 'Most residential zoning systems support 2–8 zones from a single air handler. The number depends on your system\'s blower capacity and duct design. We assess your existing system before recommending a zone count.' },
  { q: 'Does zoning work with my existing HVAC system?', a: 'Zoning requires a variable-speed or multi-stage system, or a bypass damper to manage excess air pressure when only some zones are calling. Many older single-stage systems need an equipment upgrade to zone properly. We\'ll tell you honestly whether your existing equipment is compatible.' },
  { q: 'How much does a zoning system cost?', a: 'A 2-zone upgrade on an existing compatible system typically runs $1,800–$3,500 installed. Additional zones add $400–$700 each. If equipment upgrade is needed, costs increase accordingly. We provide flat-rate quotes with no surprises.' },
  { q: 'Can zoning help with upstairs/downstairs temperature differences?', a: 'Yes — this is one of the most common reasons homeowners add zoning in Phoenix. Two-story homes with flat roofs and attic ductwork often have 8–12°F difference between floors. A two-zone system with separate thermostats gives each floor independent control.' },
];
---

<BaseLayout
  title="HVAC Zoning Systems in Phoenix, AZ | Skyhooked on Comfort"
  description="Multi-zone HVAC control for Phoenix homes. Stop fighting over the thermostat — cool the rooms you use, save energy on the ones you don't. Call (480) 123-4567."
>
  <script type="application/ld+json" is:inline>
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "HVAC Zoning System Installation", "provider": { "@type": "HVACBusiness", "name": "Skyhooked on Comfort", "telephone": "(480) 123-4567", "address": { "@type": "PostalAddress", "addressLocality": "Phoenix", "addressRegion": "AZ" } }, "areaServed": "Phoenix Valley, AZ" }
  </script>

  <section class="relative py-24 lg:py-32 overflow-hidden" style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 60%, oklch(0.30 0.025 253) 100%);">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">Multi-Zone Comfort Control</div>
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">HVAC Zoning Systems for <span class="text-sky">Phoenix Valley Homes</span></h1>
      <p class="font-body text-neutral-300 text-lg sm:text-xl max-w-2xl mx-auto mb-10">One thermostat can't serve a two-story house, a sun-drenched bonus room, and a shaded master bedroom equally. Zoning gives each space its own temperature control — and stops you from cooling rooms nobody's using.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Request a Quote →</a>
      </div>
    </div>
  </section>

  <!-- Who needs it -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-12">Who benefits from zoning</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { title: 'Two-Story Homes', desc: 'Heat rises — upstairs is almost always hotter in summer. Separate zones with individual thermostats solve this without fighting the physics.' },
          { title: 'Homes with Bonus Rooms', desc: 'Game rooms, sunrooms, and flex spaces with large windows and poor insulation get extreme heat gain. A dedicated zone handles them without overcooling the rest of the house.' },
          { title: 'Home Offices', desc: 'Working from home? Condition your workspace to your preference without conditioning the whole house during the day.' },
          { title: 'Master Suites', desc: 'Different sleep temperature preferences between partners can now be solved at the thermostat level, not the argument level.' },
          { title: 'Detached Garages & Casitas', desc: 'These spaces often have their own mini-split already — but for homes without, zoning can extend the main system.' },
          { title: 'Larger Homes (2,500+ SF)', desc: 'Single-thermostat control of 3,000+ SF means the system cycles based on one measurement point. Zoning matches output to actual demand across the whole home.' },
        ].map(u => (
          <div class="bg-charcoal-50 rounded-2xl p-6 border border-neutral-200">
            <h3 class="font-display font-bold text-charcoal text-lg mb-2">{u.title}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-12">How zoning works</h2>
      <div class="grid sm:grid-cols-3 gap-6 mb-8">
        {[
          { title: 'Zone Control Panel', desc: 'The brain of the system. Receives signals from all thermostats and coordinates damper operation and equipment staging.' },
          { title: 'Motorized Dampers', desc: 'Installed in your ductwork, these open and close based on which zones are calling. Divert conditioned air exactly where it\'s needed.' },
          { title: 'Zone Thermostats', desc: 'Each zone has its own thermostat — programmable or smart. You set different schedules and temperatures per zone independently.' },
        ].map(c => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-200 text-center">
            <div class="w-12 h-12 bg-sky/10 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{c.title}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed">{c.desc}</p>
          </div>
        ))}
      </div>
      <p class="font-body text-neutral-600 text-center max-w-2xl mx-auto">Important: zoning a system not designed for it can cause high static pressure problems. We assess your equipment and duct design before recommending any zoning approach — and will tell you if mini-splits are a better fit for your situation.</p>
    </div>
  </section>

  <!-- Review -->
  <section class="bg-white py-20">
    <div class="max-w-3xl mx-auto px-4">
      <blockquote class="bg-charcoal-50 rounded-2xl p-8 border border-neutral-200">
        <div class="flex gap-1 mb-4">{Array(5).fill(null).map(() => <svg class="w-5 h-5 text-sky" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>)}</div>
        <p class="font-body text-neutral-700 text-lg leading-relaxed mb-5">"We have a two-story 3,200 SF home in Gilbert. Upstairs was consistently 8–10 degrees hotter than down. Skyhooked installed a 2-zone system — separate thermostats up and down, bypass damper to protect the equipment. For the first time in 8 years the whole house is comfortable. Our APS bill actually dropped because we're not blasting cold air downstairs to eventually cool upstairs."</p>
        <footer class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">KP</div>
          <div><cite class="font-body font-semibold text-charcoal not-italic text-sm">Kevin P.</cite><p class="font-body text-neutral-500 text-xs">Gilbert · 2-Zone HVAC System</p></div>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl text-center mb-10">Zoning FAQ</h2>
      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors" aria-expanded="false" data-index={i}>
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5"><p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-4">Every room at the right temperature.</h2>
      <p class="font-body text-neutral-300 text-lg mb-8">We'll assess your home, tell you honestly if zoning is the right solution, and give you a flat-rate quote if it is.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Request a Quote →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) { panel.classList.remove('hidden'); chevron?.classList.add('rotate-180'); btn.setAttribute('aria-expanded', 'true'); }
    });
  });
</script>
