---
import BaseLayout from '../../layouts/BaseLayout.astro';

const brands = [
  { name: 'Carrier', note: 'Factory Authorized Dealer. Infinity variable-speed systems for ultimate efficiency.' },
  { name: 'Trane', note: 'Comfort Specialist dealer. XV and XR series — rock-solid reliability.' },
  { name: 'Lennox', note: 'Premier Dealer. XC21/SL28XCV — some of the highest SEER2 ratings available.' },
  { name: 'Goodman / Amana', note: 'Best-value tier with industry-leading 10-year parts warranty.' },
  { name: 'Rheem', note: 'Strong nationwide warranty support, excellent parts availability.' },
  { name: 'Daikin', note: 'Advanced inverter technology, excellent efficiency in Phoenix\'s climate.' },
];

const faqs = [
  {
    q: 'What SEER2 rating should I get for Phoenix?',
    a: 'With Phoenix\'s 4+ month cooling season, we recommend SEER2 18+ for most homes. The efficiency premium pays back quickly when your AC runs nearly year-round. Variable-speed systems (SEER2 18–28) also dehumidify better — a comfort advantage in Phoenix\'s monsoon season.',
  },
  {
    q: 'How long does a new AC installation take?',
    a: 'Most straightforward replacements (same-location, same-size ductwork) are completed in a single day. If ductwork modifications, electrical upgrades, or attic air handler work is required, plan for two days. We confirm the timeline before we start.',
  },
  {
    q: 'Do you do Manual J load calculations?',
    a: 'Yes — on every install. Manual J is a real heat-gain calculation for your home that accounts for insulation, windows, orientation, and occupancy. It\'s required by Arizona code for new equipment and required for the federal tax credit. A contractor who skips it is oversizing you.',
  },
  {
    q: 'Can I finance a new AC installation?',
    a: 'Yes. We partner with GoodLeap and Synchrony for 0% APR options on qualified buyers. Apply in 90 seconds on-site — soft credit pull only, decision in minutes. Heat pump installations also qualify for the 30% federal IRA tax credit (up to $2,000), which effectively reduces your out-of-pocket cost.',
  },
  {
    q: 'What happens to my old unit?',
    a: 'We disconnect, remove, and haul away your old system at no extra charge. Refrigerant is recovered by our EPA 608 certified technicians and handled in compliance with all environmental regulations.',
  },
];
---

<BaseLayout
  title="AC Installation in Phoenix, AZ | Skyhooked on Comfort"
  description="Licensed AC installation across the Phoenix Valley. High-efficiency SEER2 systems, Manual J sizing, all major brands. Financing available. Call (480) 123-4567."
>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "AC Installation",
    "provider": {
      "@type": "HVACBusiness",
      "name": "Skyhooked on Comfort",
      "telephone": "(480) 123-4567",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Phoenix",
        "addressRegion": "AZ",
        "addressCountry": "US"
      }
    },
    "areaServed": {
      "@type": "Place",
      "name": "Phoenix Valley, AZ"
    },
    "description": "Residential AC installation across the Phoenix Valley. High-efficiency systems, Manual J load calculation, all major brands, financing available."
  }
  </script>

  <!-- Hero -->
  <section
    class="relative min-h-[55vh] flex flex-col justify-center overflow-hidden"
    style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 60%, oklch(0.24 0.025 253) 100%);"
  >
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full opacity-10" style="background: radial-gradient(circle, oklch(0.58 0.13 233), transparent);"></div>
    </div>
    <div class="relative max-w-5xl mx-auto px-4 py-24 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">
        Financing Available · Manual J on Every Install
      </div>
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        AC Installation in Phoenix, AZ
      </h1>
      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        High-efficiency air conditioners right-sized for Phoenix's 4-month cooling season. Carrier, Trane, Lennox, Goodman, Rheem, and Daikin systems installed by EPA-certified technicians with a real Manual J load calculation on every project.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Free Consultation →
        </a>
      </div>
    </div>
  </section>


  <!-- What's Included -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">What's included in every installation</h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">One flat-rate price covers everything — no line-item surprises at the end.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          'In-home consultation and system assessment',
          'Manual J heat-gain load calculation',
          'Manual S equipment selection (right-size, not oversize)',
          'Removal and disposal of old system',
          'New AC installation — indoor air handler and outdoor condenser',
          'Refrigerant line set installation or reuse assessment',
          'Electrical disconnect and wiring',
          'Condensate drain and safety switch',
          'Thermostat installation or upgrade',
          'Permit pulled and inspection scheduled',
          'Full system commissioning and performance test',
          '10-year manufacturer warranty registration',
        ].map(item => (
          <div class="flex items-start gap-3 bg-charcoal-50 rounded-xl p-4">
            <svg class="w-5 h-5 text-sky flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
            <span class="font-body text-neutral-700 text-sm">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- SEER2 Explainer -->
  <section class="bg-charcoal py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display font-bold text-white text-3xl sm:text-4xl mb-6">
            SEER2 ratings — what they mean for Phoenix
          </h2>
          <p class="font-body text-charcoal-50 text-lg leading-relaxed mb-5">
            SEER2 is the updated efficiency standard for air conditioners (effective 2023). A higher number means lower operating cost — and in Phoenix, where your AC runs 8–10 months a year, efficiency pays off faster than in almost any other U.S. climate.
          </p>
          <p class="font-body text-charcoal-50 text-lg leading-relaxed mb-5">
            Phoenix's 4-month peak cooling season (June–September) regularly exceeds 110°F. Your AC works harder than anywhere else. That's why we recommend minimum SEER2 15 for budget installs, SEER2 18–22 for most homes, and variable-speed systems (SEER2 20+) for homes with premium comfort requirements or high electric bills.
          </p>
          <p class="font-body text-charcoal-50 text-lg leading-relaxed">
            Variable-speed systems also do something single-stage units can't: dehumidify effectively during Phoenix's July–September monsoon season. Better humidity control means real comfort, not just lower temperatures.
          </p>
        </div>
        <div class="space-y-4">
          {[
            { tier: 'Budget', seer: 'SEER2 14–15', note: 'Meets code minimum. Lower upfront cost. Best for limited budgets or short-term plans.', color: 'border-neutral-400' },
            { tier: 'Standard', seer: 'SEER2 16–18', note: 'Most popular for Phoenix. Good efficiency, reliable single-speed or two-stage operation.', color: 'border-sky' },
            { tier: 'Premium', seer: 'SEER2 19–24+', note: 'Variable-speed compressor. Quietest, most efficient, best humidity control. Highest upfront, lowest monthly bills.', color: 'border-sky' },
          ].map(tier => (
            <div class={`bg-charcoal-light/40 rounded-xl p-5 border-l-4 ${tier.color} border border-white/10`}>
              <div class="flex items-center justify-between mb-2">
                <span class="font-display font-bold text-white text-sm">{tier.tier}</span>
                <span class="font-display font-bold text-sky text-sm">{tier.seer}</span>
              </div>
              <p class="font-body text-charcoal-50 text-sm leading-relaxed">{tier.note}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- Brands -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">Brands we install</h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">We're not tied to one brand. You get options across tiers so you can choose the system that fits your budget and goals.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {brands.map(brand => (
          <div class="bg-charcoal-50 rounded-xl p-5 border border-charcoal/10">
            <h3 class="font-display font-bold text-charcoal text-base mb-1">{brand.name}</h3>
            <p class="font-body text-neutral-600 text-sm">{brand.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Process -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">Our installation process</h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">From first call to a cool house — clear steps, no surprises.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { num: '01', h: 'Free In-Home Consultation', b: 'We visit your home, assess your current system and ductwork, and discuss your comfort priorities and budget.' },
          { num: '02', h: 'Manual J Load Calculation', b: 'Real heat-gain math using your home\'s insulation, windows, orientation, and square footage. No guessing.' },
          { num: '03', h: 'Equipment Options & Quote', b: 'Three options: good / better / best. Side-by-side comparison of SEER2, warranties, operating cost, and price. One flat-rate number per option.' },
          { num: '04', h: 'Permit & Scheduling', b: 'We pull the permit and schedule the inspection. You pick the install date — usually within a week of approval.' },
          { num: '05', h: 'Installation Day', b: 'EPA-certified tech installs your new system. Old unit removed and disposed of. Refrigerant handled legally and safely.' },
          { num: '06', h: 'Commissioning & Warranty', b: 'System fully tested before we leave. 10-year manufacturer warranty registered. 1-year workmanship warranty issued.' },
        ].map(step => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-100 hover:shadow-lg transition-shadow">
            <div class="font-display font-extrabold text-sky text-3xl mb-3">{step.num}</div>
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{step.h}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed">{step.b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Pricing + Financing Strip -->
  <section class="bg-sky py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-charcoal text-3xl sm:text-4xl mb-4">
        Finance your new AC over time
      </h2>
      <p class="font-body text-charcoal/80 text-lg mb-4 max-w-xl mx-auto">
        Most Phoenix Valley AC replacements run $4,500–$9,500 depending on system size and efficiency tier. 0% APR financing options available through GoodLeap and Synchrony for qualified buyers.
      </p>
      <p class="font-body text-charcoal/70 text-base mb-8 max-w-xl mx-auto">
        Installing a qualifying heat pump instead? Stack the federal 30% IRA tax credit (up to $2,000) on top of financing to significantly reduce out-of-pocket costs.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/financing" class="inline-flex items-center gap-2 bg-charcoal hover:bg-charcoal-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          See Financing Options →
        </a>
        <a href="/residential/heat-pump-installation" class="inline-flex items-center gap-2 border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Explore Heat Pumps →
        </a>
      </div>
    </div>
  </section>


  <!-- Reviews -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-10">What homeowners say</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4" aria-label="5 stars">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
            ))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "Two other contractors quoted us a 5-ton unit based on the old equipment. Skyhooked did a Manual J and said 3.5 tons was right for our house. The new Carrier variable-speed unit runs quieter, the house is more comfortable, and our electric bill is noticeably lower. Correct sizing matters."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">LH</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Lauren H.</cite>
              <p class="font-body text-neutral-500 text-xs">Chandler · Carrier Variable-Speed Install</p>
            </div>
          </footer>
        </blockquote>

        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4" aria-label="5 stars">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
            ))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "Our 16-year-old Goodman finally gave out in May. Skyhooked had a new Trane XR17 installed within three days of our call — permit, inspection, everything. Marcus's crew was professional, cleaned up completely, and walked me through the new thermostat before leaving."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">BP</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Brian P.</cite>
              <p class="font-body text-neutral-500 text-xs">Gilbert · Trane XR17 Installation</p>
            </div>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>


  <!-- FAQ -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-10">
        AC installation — common questions
      </h2>
      <div class="space-y-3 mb-10">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button
              class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors"
              aria-expanded="false"
              data-index={i}
            >
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5">
              <p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Related + CTA -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-8 text-center">Related services</h2>
      <div class="grid sm:grid-cols-3 gap-4 mb-12">
        {[
          { href: '/residential/heat-pump-installation', name: 'Heat Pump Installation', desc: 'One system for heating and cooling. 30% federal tax credit available.' },
          { href: '/residential/ac-repair', name: 'AC Repair', desc: 'Same-day diagnostic and flat-rate repair on any brand.' },
          { href: '/residential/smart-thermostats', name: 'Smart Thermostats', desc: 'Maximize efficiency with Nest, ecobee, or Honeywell Home.' },
        ].map(s => (
          <a href={s.href} class="group bg-charcoal-50 hover:bg-charcoal rounded-xl p-5 border border-charcoal/10 hover:border-charcoal transition-colors">
            <h3 class="font-display font-bold text-charcoal group-hover:text-white text-sm mb-1 transition-colors">{s.name}</h3>
            <p class="font-body text-neutral-500 group-hover:text-charcoal-50 text-xs transition-colors">{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-6">
        Ready for a new AC? Let's start with a free consultation.
      </h2>
      <p class="font-body text-charcoal-50 text-lg mb-8">
        In-home visit, Manual J load calculation, three equipment options with flat-rate pricing. No pressure, no sales tactics.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Request a Quote →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) {
        panel.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
