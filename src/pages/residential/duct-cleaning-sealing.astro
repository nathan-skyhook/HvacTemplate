---
import BaseLayout from '../../layouts/BaseLayout.astro';

const signs = [
  'Dust accumulates on surfaces within days of cleaning',
  'Some rooms are significantly hotter or colder than others',
  'Energy bills have crept up with no other explanation',
  'You can see visible debris or mold near vent registers',
  'Musty smell when the system runs — especially after monsoon season',
  'The home is 15+ years old and ducts have never been inspected',
  'Recent renovation kicked up significant construction dust',
];

const faqs = [
  { q: 'How often should ducts be cleaned in Phoenix?', a: 'Every 5–7 years as a baseline — more frequently if you have pets, allergies, visible mold, recent construction, or significant haboob exposure. Annual duct inspections during your tune-up let us flag problems early.' },
  { q: 'What is Aeroseal and how does it work?', a: 'Aeroseal is a patented duct sealing process where an aerosol sealant is injected into the pressurized duct system. The sealant particles seek out and bond to leak sites from the inside — gaps and holes that would be physically impossible to reach and seal manually. Most residential duct systems lose 20–30% of conditioned air through leaks; Aeroseal can cut that to under 5%.' },
  { q: 'Will duct cleaning help my allergies?', a: 'It can — particularly if you have visible debris, mold, or significant dust accumulation in the duct system. We always do a before/after comparison so you can see what was removed. Combine with a MERV-13 filtration upgrade for best results.' },
  { q: 'How long does duct cleaning take?', a: 'A standard residential duct cleaning takes 3–5 hours for a typical Phoenix home. Aeroseal sealing adds 2–3 hours. We protect your floors and furniture during the process and leave the area clean.' },
];
---

<BaseLayout
  title="Duct Cleaning & Sealing in Phoenix, AZ | Skyhooked on Comfort"
  description="Professional duct cleaning and Aeroseal sealing in Phoenix. Leaky ducts waste 20–30% of conditioned air — we find and fix them. Call (480) 123-4567."
>
  <script type="application/ld+json" is:inline>
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Duct Cleaning and Sealing", "provider": { "@type": "HVACBusiness", "name": "Skyhooked on Comfort", "telephone": "(480) 123-4567", "address": { "@type": "PostalAddress", "addressLocality": "Phoenix", "addressRegion": "AZ" } }, "areaServed": "Phoenix Valley, AZ" }
  </script>

  <section class="relative py-24 lg:py-32 overflow-hidden" style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 60%, oklch(0.30 0.025 253) 100%);">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">Inspection · Cleaning · Aeroseal</div>
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">Duct Cleaning & Sealing in <span class="text-sky">Phoenix, AZ</span></h1>
      <p class="font-body text-neutral-300 text-lg sm:text-xl max-w-2xl mx-auto mb-10">Phoenix attic temperatures hit 150°F+ in summer. Leaky ducts running through that heat can lose 25–30% of your conditioned air before it reaches the living space. We clean and seal them.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Request a Quote →</a>
      </div>
    </div>
  </section>

  <!-- Signs -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-6">Signs your ducts need attention</h2>
          <ul class="space-y-3">
            {signs.map(s => (
              <li class="flex items-start gap-3 font-body text-neutral-700">
                <svg class="w-5 h-5 text-sky flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
                {s}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-charcoal-50 rounded-2xl p-8 border border-neutral-200">
          <h3 class="font-display font-bold text-charcoal text-xl mb-4">The Phoenix duct problem</h3>
          <p class="font-body text-neutral-600 leading-relaxed mb-4">Most Phoenix homes have ductwork running through unconditioned attic space. Summer attic temps regularly exceed 150°F. Every gap in a duct joint, every unsealed collar, every crushed flex duct — each one dumps conditioned air into that 150° space instead of your living room.</p>
          <p class="font-body text-neutral-600 leading-relaxed">The average Valley home loses 20–30% of HVAC output to duct leakage. At typical Phoenix energy rates, that's $300–$600 in wasted cooling every summer. Sealing pays for itself.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-12">What's included</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        {[
          { title: 'Duct Inspection', items: ['Video inspection of main trunk lines and branches', 'Blower door duct leakage test (before and after)', 'Assessment of insulation levels and damage', 'Identification of crimped, crushed, or disconnected flex runs'] },
          { title: 'Professional Cleaning', items: ['Negative-pressure HEPA vacuum connected at the main trunk', 'Agitation of all supply and return runs', 'Register and grille cleaning', 'Air handler coil and cabinet inspection'] },
          { title: 'Aeroseal Duct Sealing', items: ['Pressurize the duct system', 'Inject Aeroseal polymer sealant particles', 'Particles seek and bond to leak sites from inside', 'Before/after leakage report provided — measurable results'] },
        ].map(col => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-200">
            <h3 class="font-display font-bold text-charcoal text-lg mb-4">{col.title}</h3>
            <ul class="space-y-2">
              {col.items.map(item => (
                <li class="flex items-start gap-2 font-body text-neutral-600 text-sm">
                  <svg class="w-4 h-4 text-sky flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Review -->
  <section class="bg-white py-20">
    <div class="max-w-3xl mx-auto px-4">
      <blockquote class="bg-charcoal-50 rounded-2xl p-8 border border-neutral-200">
        <div class="flex gap-1 mb-4">{Array(5).fill(null).map(() => <svg class="w-5 h-5 text-sky" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>)}</div>
        <p class="font-body text-neutral-700 text-lg leading-relaxed mb-5">"Our 1998 home had the original flex ductwork — we could feel hot air leaking around every duct collar in the attic. Skyhooked ran the Aeroseal process and showed us a before/after test: duct leakage dropped from 28% to 4%. Our APS bill dropped $120 the first full month after. Paid for itself in one summer."</p>
        <footer class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">TW</div>
          <div><cite class="font-body font-semibold text-charcoal not-italic text-sm">Tom W.</cite><p class="font-body text-neutral-500 text-xs">Glendale · Aeroseal Duct Sealing</p></div>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl text-center mb-10">Duct FAQ</h2>
      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors" aria-expanded="false" data-index={i}>
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5"><p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related + CTA -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-6 text-center">Related services</h2>
      <div class="grid sm:grid-cols-3 gap-4 mb-12">
        {[
          { title: 'Indoor Air Quality', href: '/residential/indoor-air-quality', desc: 'Filtration and purification upgrades.' },
          { title: 'AC Installation', href: '/residential/ac-installation', desc: 'Pair a new system with sealed ducts.' },
          { title: 'Tune-Ups & Maintenance', href: '/residential/tune-ups-maintenance', desc: 'Annual duct inspection included.' },
        ].map(r => (
          <a href={r.href} class="bg-charcoal-50 rounded-xl p-5 border border-neutral-200 hover:shadow-md transition-shadow">
            <h3 class="font-display font-bold text-charcoal text-base mb-1">{r.title}</h3>
            <p class="font-body text-neutral-500 text-sm">{r.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-4">Stop paying to heat your attic.</h2>
      <p class="font-body text-neutral-300 text-lg mb-8">We'll inspect your duct system and show you exactly where the leaks are — measurable results, flat-rate pricing.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Request a Quote →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) { panel.classList.remove('hidden'); chevron?.classList.add('rotate-180'); btn.setAttribute('aria-expanded', 'true'); }
    });
  });
</script>
