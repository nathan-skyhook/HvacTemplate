---
import BaseLayout from '../../layouts/BaseLayout.astro';

const commonProblems = [
  {
    problem: 'Igniter or Pilot Light Failure',
    cause: 'The hot surface igniter is the most common furnace failure point. In Phoenix, furnaces sit idle for months in summer, and igniters can crack or degrade from heat cycling.',
    fix: 'Usually a same-day repair. We carry igniters for all major brands on every truck.',
  },
  {
    problem: 'Heat Exchanger Crack',
    cause: 'A cracked heat exchanger is a safety issue — it can allow combustion gases (including carbon monoxide) to enter your living space. Common in older furnaces and systems that have been short-cycling for years.',
    fix: 'If the heat exchanger is cracked, the furnace must be replaced. We\'ll document it clearly and give you replacement options.',
  },
  {
    problem: 'Flame Sensor Failure',
    cause: 'The flame sensor detects whether the burner is lit. A dirty or failed sensor causes the furnace to light briefly, then shut off — the classic "furnace runs for a minute then stops" pattern.',
    fix: 'Clean or replace the sensor. Inexpensive repair, usually completed in a single visit.',
  },
  {
    problem: 'Heat Pump Reversing Valve Failure',
    cause: 'The reversing valve switches the heat pump between heating and cooling mode. In Phoenix, where heat pumps run cooling mode most of the year, the valve can stick or fail, leaving you with cool air in heat mode.',
    fix: 'Reversing valve replacement — a more involved repair, typically 3–5 hours on a standard system.',
  },
  {
    problem: 'Heat Strips Tripping Breaker',
    cause: 'Many Phoenix homes use electric heat strips instead of gas furnaces. During cold snaps below 40°F, when the heat strips run hard, an aging strip or wiring issue can trip the breaker or fail entirely.',
    fix: 'Electrical inspection, breaker test, heat strip replacement if needed. We stock common heat strip kits for fast-response repair.',
  },
  {
    problem: 'Blower Motor Failure',
    cause: 'The blower motor moves heated air through your ductwork. A seized or failed motor means heat builds up in the unit and safety switches shut it down — no airflow, no heat.',
    fix: 'Motor replacement. We carry a wide range of replacement motors and ECM blower modules for modern systems.',
  },
];

const faqs = [
  {
    q: 'Do you repair gas furnaces, heat pumps, and electric heat strips?',
    a: 'Yes, all three — plus boilers, fan coil units, and hybrid dual-fuel systems. Our EPA-certified technicians are trained on every residential heating system type we encounter in the Phoenix Valley.',
  },
  {
    q: 'Phoenix winters aren\'t that cold — is heating repair really urgent?',
    a: 'It depends. Phoenix overnight lows in December and January regularly drop to 34–38°F, and cold snaps can push single digits in far-east and north Valley homes. A broken heat system overnight is genuinely cold. More urgently, a cracked heat exchanger on a gas furnace is a CO risk regardless of outdoor temperature.',
  },
  {
    q: 'Should I repair my old furnace or replace it?',
    a: 'If your furnace is under 12 years old and the repair is under 50% of replacement cost, repair usually makes financial sense. Over 15 years old, multiple recent repairs, or R-22 system — replacement math typically wins. We\'ll lay out both options clearly with no pressure.',
  },
  {
    q: 'What brands do you repair?',
    a: 'All major brands: Carrier, Trane, Lennox, Goodman, Rheem, American Standard, York, Bryant, Ruud, Amana, Heil, and more. We service both gas furnaces and heat pumps from all manufacturers.',
  },
];
---

<BaseLayout
  title="Heating Repair in Phoenix, AZ | Skyhooked on Comfort"
  description="Furnace, heat pump, and heat strip repair across the Phoenix Valley. All brands, flat-rate pricing, same-day service. EPA-certified techs. Call (480) 123-4567."
>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Heating Repair",
    "provider": {
      "@type": "HVACBusiness",
      "name": "Skyhooked on Comfort",
      "telephone": "(480) 123-4567",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Phoenix",
        "addressRegion": "AZ",
        "addressCountry": "US"
      }
    },
    "areaServed": {
      "@type": "Place",
      "name": "Phoenix Valley, AZ"
    },
    "description": "Residential heating repair across the Phoenix Valley. Gas furnaces, heat pumps, electric heat strips, all brands. Same-day service, flat-rate pricing."
  }
  </script>

  <!-- Hero -->
  <section
    class="relative min-h-[55vh] flex flex-col justify-center overflow-hidden"
    style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 60%, oklch(0.24 0.025 253) 100%);"
  >
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full opacity-10" style="background: radial-gradient(circle, oklch(0.58 0.13 233), transparent);"></div>
    </div>
    <div class="relative max-w-5xl mx-auto px-4 py-24 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">
        Same-Day Service · All Brands · Flat-Rate Pricing
      </div>
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        Heating Repair in Phoenix, AZ
      </h1>
      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        Furnaces, heat pumps, electric heat strips, and boilers — all brands, all systems. Same-day service available across the Phoenix Valley. Written flat-rate quote before any work starts.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Request a Quote →
        </a>
      </div>
    </div>
  </section>


  <!-- What's Included -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-6">What's included in every heating repair</h2>
          <ul class="space-y-3">
            {[
              'Complete heating system diagnostic — every component inspected',
              'Gas furnaces, heat pumps, electric heat strips, fan coil units, boilers',
              'All brands: Carrier, Trane, Lennox, Goodman, Rheem, Daikin, Mitsubishi, and more',
              'Written flat-rate quote before any work starts',
              'Common parts stocked on every truck for same-visit repairs',
              'CO detector check and safety inspection on every gas furnace visit',
              '1-year workmanship warranty on all repairs',
              'Dispatch fee waived when you approve the repair',
            ].map(item => (
              <li class="flex items-start gap-3 font-body text-neutral-700">
                <svg class="w-5 h-5 text-sky flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-charcoal-50 rounded-2xl p-8 border border-charcoal/10">
          <h3 class="font-display font-bold text-charcoal text-xl mb-5">Phoenix winter context</h3>
          <p class="font-body text-neutral-600 leading-relaxed mb-4">
            Phoenix isn't Minnesota, but it gets cold enough to matter. Winter nights regularly drop to 35–40°F in the Valley and can dip into the mid-20s in far-east suburbs and higher elevations.
          </p>
          <p class="font-body text-neutral-600 leading-relaxed mb-4">
            Many Phoenix homes rely on electric heat strips rather than gas furnaces — and those strips are largely untested from April through October. When a cold snap hits, we see a surge of heat strip failures and heat pump reversing valve issues. Being on our Comfort Plan means your system gets a fall tune-up before the first cold night.
          </p>
          <a href="/residential/tune-ups-maintenance" class="font-display font-bold text-sky text-sm hover:underline">
            See our fall heating tune-up →
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- Common Problems -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">Common heating problems we fix</h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">Phoenix heating systems have their own failure patterns. Here's what we see most often.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-5">
        {commonProblems.map(item => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-100 hover:shadow-lg transition-shadow">
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{item.problem}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed mb-3"><strong>Why it happens:</strong> {item.cause}</p>
            <p class="font-body text-sky text-sm font-semibold">{item.fix}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Process -->
  <section class="bg-charcoal py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-white text-3xl sm:text-4xl mb-3">Our repair process</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { num: '01', h: 'Call & Schedule', b: 'Real human answers 24/7. Same-day slots on most Phoenix Valley heating calls.' },
          { num: '02', h: 'Arrive & Diagnose', b: 'Full system diagnostic — every component, including safety systems and heat exchanger.' },
          { num: '03', h: 'Quote & Approve', b: 'Written flat-rate quote, explained clearly. No work until you say yes.' },
          { num: '04', h: 'Repair & Test', b: 'Repair completed, system tested for safe and correct operation. Warranty issued.' },
        ].map(step => (
          <div class="bg-charcoal-light/40 rounded-2xl p-6 border border-white/10">
            <div class="font-display font-extrabold text-sky text-3xl mb-3">{step.num}</div>
            <h3 class="font-display font-bold text-white text-base mb-2">{step.h}</h3>
            <p class="font-body text-charcoal-50 text-sm leading-relaxed">{step.b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Reviews -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-10">What homeowners say</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4" aria-label="5 stars">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
            ))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "Our heat pump stopped heating on a 37°F January night. Called Skyhooked at 7am, tech arrived by 9:30, diagnosed a stuck reversing valve. Had the part on the truck. House was warm before noon. Professional, honest, no games."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">AW</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Angela W.</cite>
              <p class="font-body text-neutral-500 text-xs">Scottsdale · Heat Pump Repair</p>
            </div>
          </footer>
        </blockquote>

        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4" aria-label="5 stars">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
            ))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "Furnace stopped igniting in December. The tech found a cracked heat exchanger and showed me photos. He didn't pressure me to replace — he showed me the repair cost vs replacement math and let me decide. I replaced it. Good experience even in a tough situation."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">CF</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Carlos F.</cite>
              <p class="font-body text-neutral-500 text-xs">Peoria · Furnace Diagnostic</p>
            </div>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>


  <!-- FAQ -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-10">Common questions</h2>
      <div class="space-y-3 mb-10">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button
              class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors"
              aria-expanded="false"
              data-index={i}
            >
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5">
              <p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Related + CTA -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-8 text-center">Related services</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          { href: '/residential/heating-installation', name: 'Heating Installation', desc: 'New furnace, heat pump, or hybrid system installs.' },
          { href: '/residential/tune-ups-maintenance', name: 'Tune-Ups & Maintenance', desc: 'Fall heating tune-up before the first cold snap.' },
          { href: '/residential/emergency-hvac', name: 'Emergency HVAC', desc: '24/7 emergency heating repair, no overtime fees.' },
        ].map(s => (
          <a href={s.href} class="group bg-charcoal-50 hover:bg-charcoal rounded-xl p-5 border border-charcoal/10 hover:border-charcoal transition-colors">
            <h3 class="font-display font-bold text-charcoal group-hover:text-white text-sm mb-1 transition-colors">{s.name}</h3>
            <p class="font-body text-neutral-500 group-hover:text-charcoal-50 text-xs transition-colors">{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-6">
        Heating not working? Let's fix it today.
      </h2>
      <p class="font-body text-charcoal-50 text-lg mb-8">
        Same-day service available. Flat-rate quote before we lift a tool. Real humans answer 24/7.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Request a Quote →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) {
        panel.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
