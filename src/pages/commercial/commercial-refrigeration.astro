---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Commercial Refrigeration",
  "name": "Commercial Refrigeration Repair & Maintenance Phoenix AZ",
  "provider": {
    "@type": "HVACBusiness",
    "name": "Skyhooked on Comfort",
    "telephone": "(480) 123-4567",
    "address": { "@type": "PostalAddress", "addressLocality": "Phoenix", "addressRegion": "AZ" }
  },
  "areaServed": { "@type": "State", "name": "Phoenix Valley, AZ" }
};

const systems = [
  { name: 'Walk-In Coolers', desc: 'Restaurant, grocery, convenience store, and food-service walk-in cooler repair, maintenance, and replacement. Condensing unit service, evaporator coil cleaning, door gasket replacement, and temperature verification.' },
  { name: 'Walk-In Freezers', desc: 'Walk-in freezer repair and maintenance for commercial food service. Defrost cycle verification, drain heater inspection, door heater function, and temperature logging for food safety compliance.' },
  { name: 'Reach-In Refrigerators & Freezers', desc: 'Commercial reach-in case service for restaurants, convenience stores, and food service operations. Condensing unit cleaning, refrigerant leak checks, gasket replacement.' },
  { name: 'Open & Glass-Door Display Cases', desc: 'Grocery and convenience store display case service. Coil cleaning, anti-sweat heater verification, case temperature logging, and refrigerant circuit inspection. Hussmann, Tyler, and Kysor Warren case expertise.' },
];

const industries = [
  { name: 'Restaurants & Food Service', desc: 'Walk-in coolers, walk-in freezers, reach-ins, and bar refrigeration. Service scheduled around dinner service to minimize operational impact. We understand health department temperature requirements.' },
  { name: 'Grocery & Supermarket', desc: 'Display case fleets, multi-compressor rack systems, walk-in produce coolers, and frozen food cases. Experience with centralized refrigeration rack systems and distributed case arrangements.' },
  { name: 'Convenience Stores', desc: 'Reach-in beverage cases, walk-in beer coolers, and frozen food cases. Fast response is critical — convenience store refrigeration failures are direct revenue losses.' },
  { name: 'Commercial Food Processing', desc: 'Process refrigeration, blast chillers, and specialized cooling for commercial food production facilities in the Phoenix Valley industrial corridor.' },
];

const faqs = [
  {
    q: 'Do you provide temperature logs for health department compliance?',
    a: 'Yes. Temperature logging documentation is included as standard on all commercial refrigeration maintenance contracts. Digital temperature logs showing walk-in and display case temperatures over time are provided after every service visit.',
  },
  {
    q: 'What refrigerants do you handle in commercial refrigeration?',
    a: 'R-404A, R-134a, R-448A, R-449A, R-507A, R-22 (legacy), and HFO refrigerants including R-448A and R-449A used in newer commercial refrigeration systems. All handled by EPA Section 608 Universal certified technicians with refrigerant logs maintained per EPA requirements.',
  },
  {
    q: 'How quickly can you respond to a walk-in cooler failure?',
    a: 'For contract clients, front-of-queue dispatch 24/7/365. Most Phoenix Valley commercial refrigeration emergencies are on-site within 60–90 minutes. We stock common commercial refrigeration parts — condensing units, evaporator fans, defrost timers, and refrigerant — for fast turnaround.',
  },
  {
    q: 'Can you service commercial rack refrigeration systems?',
    a: 'Yes. Centralized rack systems serving multiple display cases — the type common in grocery stores — require specialized training. Our commercial refrigeration technicians hold the certifications and experience for rack system service, including Hussmann and Tyler rack systems.',
  },
  {
    q: 'What brands of commercial refrigeration do you service?',
    a: 'Hussmann, Tyler, Kysor Warren, Copeland (Emerson), Bohn, Heatcraft, Welbilt, True Manufacturing, Beverage-Air, and others. Most commercial refrigeration condensing units use Copeland compressors, which we stock and replace.',
  },
];

const brands = ['Hussmann', 'Tyler', 'Kysor Warren', 'Copeland / Emerson', 'Bohn', 'Heatcraft', 'True Manufacturing', 'Beverage-Air', 'Welbilt'];
---

<BaseLayout
  title="Commercial Refrigeration in Phoenix, AZ | Skyhooked on Comfort"
  description="Commercial refrigeration repair and maintenance in Phoenix Valley. Walk-in coolers, freezers, display cases. EPA 608 certified. Temperature logs. Call (480) 123-4567."
>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <!-- Hero -->
  <section
    class="relative min-h-[60vh] flex flex-col justify-center overflow-hidden"
    style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 50%, oklch(0.30 0.025 253) 100%);"
  >
    <div class="relative max-w-5xl mx-auto px-4 py-24 text-center">
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        Commercial Refrigeration<br class="hidden sm:block"/>
        <span class="text-sky">in Phoenix, AZ</span>
      </h1>
      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        A walk-in cooler failure or display case breakdown means potential inventory loss, health department issues, and lost revenue — in that order. Skyhooked on Comfort provides commercial refrigeration repair, preventive maintenance, and installation for Phoenix Valley restaurants, grocery stores, convenience stores, and food service operations. EPA Section 608 certified. Temperature logs for food safety compliance standard.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Request a Bid →
        </a>
      </div>
    </div>
  </section>


  <!-- Systems Covered -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">Commercial Refrigeration Systems We Service</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {systems.map(s => (
          <div class="bg-charcoal-50 rounded-2xl p-7 border border-neutral-100">
            <h3 class="font-display font-bold text-charcoal text-lg mb-3">{s.name}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Industries -->
  <section class="bg-charcoal py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-white text-3xl sm:text-4xl mb-3">Industries We Serve</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {industries.map(ind => (
          <div class="bg-charcoal-light/40 rounded-2xl p-7 border border-white/10">
            <h3 class="font-display font-bold text-white text-lg mb-3">{ind.name}</h3>
            <p class="font-body text-charcoal-50 text-sm leading-relaxed">{ind.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Services -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl mb-3">What We Do</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { name: 'Repair', desc: 'Same-visit repair on most commercial refrigeration failures. Written quote before work begins. Parts stocked for common systems.' },
          { name: 'Installation', desc: 'Walk-in cooler and freezer installation, new display case installation, and system upgrades with proper refrigerant handling.' },
          { name: 'Preventive Maintenance', desc: 'Monthly or quarterly maintenance programs covering condenser cleaning, defrost verification, seal inspection, and temperature logging.' },
          { name: 'Temperature Logging', desc: 'Digital temperature logs for food safety compliance. Documentation ready for health department inspections or corporate audits.' },
        ].map(s => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-100 hover:shadow-lg transition-shadow">
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{s.name}</h3>
            <p class="font-body text-neutral-500 text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Brands -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-6">Brands We Service</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {brands.map(b => (
          <span class="bg-charcoal-50 border border-neutral-200 text-charcoal font-body font-semibold text-sm px-4 py-2 rounded-xl">{b}</span>
        ))}
      </div>
    </div>
  </section>


  <!-- EPA Compliance -->
  <section class="bg-charcoal py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display font-bold text-white text-3xl mb-4">Refrigerant Compliance — EPA Section 608</h2>
      <p class="font-body text-charcoal-50 text-lg leading-relaxed mb-6">
        Commercial refrigeration systems use substantial quantities of refrigerants regulated under EPA Section 608. All Skyhooked technicians working on commercial refrigeration carry EPA 608 Universal certification. We maintain complete refrigerant purchase, recovery, and reclaim records and provide refrigerant compliance documentation as part of every service report.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <span class="bg-sky/20 text-sky font-display font-bold text-sm px-4 py-2 rounded-full border border-sky/30">EPA 608 Universal</span>
        <span class="bg-sky/20 text-sky font-display font-bold text-sm px-4 py-2 rounded-full border border-sky/30">Refrigerant Recovery Logs</span>
        <span class="bg-sky/20 text-sky font-display font-bold text-sm px-4 py-2 rounded-full border border-sky/30">Temperature Log Documentation</span>
        <span class="bg-sky/20 text-sky font-display font-bold text-sm px-4 py-2 rounded-full border border-sky/30">AZ ROC-312489</span>
      </div>
    </div>
  </section>


  <!-- Reviews -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-charcoal text-3xl mb-2">What Commercial Clients Say</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4">
            {[...Array(5)].map(() => (<svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "Walk-in cooler failed on a Sunday morning — full of prep for the week. Called Skyhooked, tech was here in 75 minutes, found a failed condensing unit motor, had the replacement on the truck. Temperature was back down in three hours. They scheduled the service visit when we weren't in production, which I appreciated."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">FR</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Frank R.</cite>
              <p class="font-body text-neutral-500 text-xs">Executive Chef · Phoenix Restaurant</p>
            </div>
          </footer>
        </blockquote>
        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4">
            {[...Array(5)].map(() => (<svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "Monthly refrigeration maintenance across all four of our convenience store locations. Temperature logs are ready for our corporate food safety audits. Display case condenser coils cleaned on schedule. Haven't lost a case to mechanical failure in two years since switching to Skyhooked."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">LP</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Linda P.</cite>
              <p class="font-body text-neutral-500 text-xs">District Manager · Phoenix Convenience Group</p>
            </div>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>


  <!-- FAQ -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-charcoal text-3xl mb-3">Commercial Refrigeration FAQ</h2>
      </div>
      <div id="faq-list" class="space-y-3 mb-10">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors" aria-expanded="false" data-index={i}>
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5">
              <p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Related -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-6 text-center">Related Commercial Services</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          { href: '/commercial/emergency-hvac', name: 'Commercial Emergency HVAC', desc: '24/7 response for refrigeration failures.' },
          { href: '/commercial/preventive-maintenance', name: 'Preventive Maintenance', desc: 'Monthly refrigeration maintenance contracts.' },
          { href: '/commercial/industries-served', name: 'Industries Served', desc: 'Restaurant, grocery, and food service specialization.' },
        ].map(link => (
          <a href={link.href} class="bg-charcoal-50 rounded-xl p-5 hover:shadow-md transition-shadow border border-neutral-100">
            <h3 class="font-display font-bold text-charcoal text-sm mb-1">{link.name}</h3>
            <p class="font-body text-neutral-500 text-xs">{link.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- CTA -->
  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-6">Commercial refrigeration issue in Phoenix?</h2>
      <p class="font-body text-charcoal-50 text-lg mb-8">Walk-ins, reach-ins, display cases — EPA 608 certified, 24/7 emergency response, temperature logs included.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Request a Bid →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) {
        panel.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
