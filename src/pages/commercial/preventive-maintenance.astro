---
import BaseLayout from '../../layouts/BaseLayout.astro';

const planTiers = [
  {
    name: 'Essential',
    freq: 'Annual',
    price: 'From $299/unit/year',
    items: [
      'Annual inspection and tune-up per unit',
      'Filter replacement (standard)',
      'Coil cleaning (evaporator and condenser)',
      'Belt and bearing inspection',
      'Controls and thermostat check',
      'Written service report after each visit',
    ],
    best: 'Best for: lower-traffic facilities with newer equipment.',
  },
  {
    name: 'Standard',
    freq: 'Semi-Annual',
    price: 'From $499/unit/year',
    items: [
      'Spring and fall inspection visits per unit',
      'All Essential items (both visits)',
      'Priority scheduling — within 4 hours',
      'No overtime charges (24/7 response)',
      '15% discount on all repair labor',
      'Quarterly filter service available',
    ],
    best: 'Best for: restaurants, retail, medical offices.',
    highlight: true,
  },
  {
    name: 'Premium',
    freq: 'Quarterly',
    price: 'Custom quote',
    items: [
      'Quarterly visits per unit',
      'All Standard items',
      'Monthly filter service included',
      'Dedicated account manager',
      'Annual equipment performance report',
      'R&R labor warranty on covered repairs',
    ],
    best: 'Best for: data centers, 24/7 operations, large facility portfolios.',
  },
];

const checklist = [
  { category: 'Mechanical', items: ['Inspect and tighten all belts and pulleys', 'Lubricate all motor bearings', 'Check and record motor amp draws', 'Inspect compressor operation and staging'] },
  { category: 'Electrical', items: ['Inspect and torque all electrical connections', 'Test and log capacitor ratings', 'Test contactors and relays', 'Check all safety controls and limits'] },
  { category: 'Refrigerant', items: ['Log suction/discharge pressures', 'Check subcooling and superheat', 'Inspect accessible refrigerant lines for leaks', 'Document refrigerant type and system charge'] },
  { category: 'Coils & Airflow', items: ['Clean evaporator coil', 'Clean condenser coil (chemical if needed)', 'Measure supply and return static pressure', 'Replace or inspect air filters'] },
  { category: 'Controls', items: ['Test thermostat calibration', 'Test BAS/DDC integration points', 'Review and optimize scheduling', 'Document setpoints'] },
  { category: 'Documentation', items: ['Complete written service report', 'Flag items needing repair with cost estimate', 'Update equipment log', 'Photos of any concerning findings'] },
];

const faqs = [
  { q: 'How many units does a commercial PM agreement cover?', a: 'Agreements can cover anywhere from a single rooftop unit to an entire portfolio of properties. We structure pricing per unit-visit and can consolidate billing for multi-property accounts. Volume discounts apply for 10+ units.' },
  { q: 'What is the response time under a PM agreement?', a: 'Standard plan: next business day priority. Standard plan and above: 4-hour response, 24/7, with no overtime surcharge. Premium: dedicated 2-hour response commitment.' },
  { q: 'Can you take over maintenance from another contractor?', a: 'Yes. We inspect and document the existing state of equipment at onboarding, establish an equipment baseline, and flag any deferred maintenance items. You start with a clear picture of where things stand.' },
  { q: 'Do you service equipment under active manufacturer warranties?', a: 'Yes. We are authorized service providers for Carrier, Trane, Daikin, and other major commercial brands. Our service reports satisfy manufacturer PM documentation requirements to maintain warranty coverage.' },
  { q: 'How does billing work for multi-location accounts?', a: 'We offer consolidated monthly or annual invoicing, with a single point of contact for scheduling coordination. Net-30 terms standard for established accounts with 5+ units.' },
];
---

<BaseLayout
  title="Commercial HVAC Preventive Maintenance in Phoenix, AZ | Skyhooked on Comfort"
  description="Commercial HVAC preventive maintenance agreements for Phoenix Valley businesses. Semi-annual inspections, 24/7 priority response, no overtime fees. Custom plans for any facility size."
>
  <script type="application/ld+json" is:inline>
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Commercial HVAC Preventive Maintenance", "provider": { "@type": "HVACBusiness", "name": "Skyhooked on Comfort", "telephone": "(480) 123-4567", "address": { "@type": "PostalAddress", "addressLocality": "Phoenix", "addressRegion": "AZ" } }, "areaServed": "Phoenix Valley, AZ" }
  </script>

  <section class="relative py-24 lg:py-32 overflow-hidden" style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 60%, oklch(0.30 0.025 253) 100%);">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">PM Agreements · Priority Response · Portfolio Accounts</div>
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">Commercial HVAC Preventive Maintenance in <span class="text-sky">Phoenix, AZ</span></h1>
      <p class="font-body text-neutral-300 text-lg sm:text-xl max-w-2xl mx-auto mb-10">Phoenix commercial HVAC equipment works harder than almost anywhere in the country — 100°F+ ambient temps for 4+ months. Planned maintenance prevents the emergency service calls that cost 3x more and happen at the worst possible time.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Request a PM Proposal →</a>
      </div>
    </div>
  </section>

  <!-- Plan tiers -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-4">Maintenance plan tiers</h2>
      <p class="font-body text-neutral-600 text-center max-w-2xl mx-auto mb-12">All plans include written service reports, equipment documentation, and a dedicated service coordinator for your account.</p>
      <div class="grid sm:grid-cols-3 gap-6">
        {planTiers.map(tier => (
          <div class={`rounded-2xl p-7 border-2 flex flex-col ${tier.highlight ? 'border-sky bg-sky/5' : 'border-neutral-200 bg-charcoal-50'}`}>
            {tier.highlight && <div class="text-xs font-display font-bold text-sky uppercase tracking-wider mb-3">Most Popular</div>}
            <h3 class="font-display font-bold text-charcoal text-xl mb-1">{tier.name}</h3>
            <div class="font-body text-neutral-500 text-sm mb-1">{tier.freq} visits</div>
            <div class="font-display font-extrabold text-charcoal text-lg mb-5">{tier.price}</div>
            <ul class="space-y-2 mb-6 flex-1">
              {tier.items.map(item => (
                <li class="flex items-start gap-2 font-body text-neutral-700 text-sm">
                  <svg class="w-4 h-4 text-sky flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  {item}
                </li>
              ))}
            </ul>
            <p class="font-body text-neutral-500 text-xs italic">{tier.best}</p>
          </div>
        ))}
      </div>
      <p class="font-body text-neutral-500 text-center text-sm mt-8">All pricing is per unit. Multi-unit and multi-property accounts receive volume pricing. Contact us for a custom proposal.</p>
    </div>
  </section>

  <!-- Inspection checklist -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-4">What we inspect every visit</h2>
      <p class="font-body text-neutral-600 text-center max-w-2xl mx-auto mb-12">Every PM visit follows a documented, category-by-category checklist. You receive a written report with pass/fail status on every item and priority-flagged repair recommendations with cost estimates.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {checklist.map(cat => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-200">
            <h3 class="font-display font-bold text-charcoal text-base mb-3 flex items-center gap-2">
              <span class="w-2 h-2 bg-sky rounded-full flex-shrink-0"></span>
              {cat.category}
            </h3>
            <ul class="space-y-1.5">
              {cat.items.map(item => (
                <li class="font-body text-neutral-600 text-sm">{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Phoenix context -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-6">Why Phoenix commercial HVAC fails more</h2>
          <div class="space-y-4 font-body text-neutral-600 leading-relaxed">
            <p>Phoenix rooftop units run at or near capacity for 4–5 months every year. Condenser coils experience significantly higher heat rejection loads than in mild climates. Compressors cycle more frequently. Capacitors and contactors degrade faster.</p>
            <p>The result: commercial HVAC equipment in Phoenix has a shorter practical lifespan than the same equipment in a cooler climate — and failure events cluster during the peak summer stretch when demand for service is highest and response times are longest.</p>
            <p>Preventive maintenance catches the components that are trending toward failure before they take down the whole system — before July 4th weekend, before the biggest trade show of the year, before a health inspection.</p>
          </div>
        </div>
        <div class="space-y-4">
          {[
            { stat: '3–5x', label: 'Cost difference between planned maintenance and emergency repair' },
            { stat: '4–6 hrs', label: 'Typical PM response advantage over standard scheduling in peak summer' },
            { stat: '15–20%', label: 'Energy efficiency improvement after professional coil cleaning on a dirty RTU' },
            { stat: '2–4 yrs', label: 'Extended equipment life with consistent preventive maintenance' },
          ].map(s => (
            <div class="bg-charcoal-50 rounded-xl p-5 border border-neutral-200 flex items-center gap-5">
              <div class="font-display font-extrabold text-sky text-3xl flex-shrink-0">{s.stat}</div>
              <p class="font-body text-neutral-700 text-sm">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Review -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-3xl mx-auto px-4">
      <blockquote class="bg-white rounded-2xl p-8 border border-neutral-200">
        <div class="flex gap-1 mb-4">{Array(5).fill(null).map(() => <svg class="w-5 h-5 text-sky" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>)}</div>
        <p class="font-body text-neutral-700 text-lg leading-relaxed mb-5">"We manage 14 commercial properties across the Valley — office buildings, retail centers, a couple of warehouses. Skyhooked handles all of them under one PM agreement. Single invoice, single point of contact, consistent documentation across every property. We had our first summer with zero emergency HVAC calls. That's not an accident."</p>
        <footer class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">RP</div>
          <div><cite class="font-body font-semibold text-charcoal not-italic text-sm">Rob P., Property Manager</cite><p class="font-body text-neutral-500 text-xs">Scottsdale · 14-Property Portfolio PM Agreement</p></div>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl text-center mb-10">Commercial PM FAQ</h2>
      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-charcoal-50">
            <button class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-neutral-100 transition-colors" aria-expanded="false" data-index={i}>
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5 bg-white"><p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-4">Get ahead of summer before it gets ahead of you.</h2>
      <p class="font-body text-neutral-300 text-lg mb-8">We'll walk your facility, document your equipment, and build a maintenance plan that fits your budget and timeline.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Request a PM Proposal →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) { panel.classList.remove('hidden'); chevron?.classList.add('rotate-180'); btn.setAttribute('aria-expanded', 'true'); }
    });
  });
</script>
