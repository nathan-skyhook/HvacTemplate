---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  { name: 'New Commercial Construction', desc: 'Design-build HVAC for ground-up commercial projects. We work from architectural drawings to engineer system layout, equipment selection, duct design, and controls — coordinated with the GC schedule through rough-in, trim-out, and startup.' },
  { name: 'Tenant Improvement (TI) Buildouts', desc: 'HVAC for office, retail, medical, and restaurant tenant improvements. We pull our own permits, handle coordination with the building\'s base-building mechanical systems, and deliver a punch-list-ready installation.' },
  { name: 'HVAC System Design & Engineering', desc: 'Manual J load calculations, duct design, equipment selection, and energy modeling. We produce stamped drawings for permit when required and collaborate with MEP engineers of record.' },
  { name: 'Controls & BAS Integration', desc: 'BACnet, Modbus, and proprietary DDC integration with building automation systems. We configure setpoints, sequences of operation, and remote monitoring dashboards for facilities teams.' },
  { name: 'LEED & Energy Code Compliance', desc: 'IECC 2021 compliance, LEED HVAC prerequisites, and Title 24 documentation. We track required efficiencies, commissioning requirements, and energy modeling inputs throughout the project.' },
  { name: 'Commissioning & Startup', desc: 'Functional performance testing, TAB (test, adjust, balance), and O&M training for building staff. We provide documentation packages for owner turnover.' },
];

const process = [
  { step: '01', title: 'Pre-Construction Review', desc: 'Review architectural and structural drawings. Identify MEP coordination requirements, equipment placement constraints, and code path early.' },
  { step: '02', title: 'Load Calculation & Design', desc: 'Manual J/Manual D for residential-scale; ASHRAE/energy modeling for commercial. Equipment selection based on design conditions, not rule of thumb.' },
  { step: '03', title: 'Permitting', desc: 'We pull our own mechanical permits, submit stamped drawings when required, and manage the inspection process through final sign-off.' },
  { step: '04', title: 'Installation', desc: 'Coordinated with GC schedule. Rough-in concurrent with framing and other trades; equipment set and trim-out per construction timeline.' },
  { step: '05', title: 'Startup & TAB', desc: 'Factory startup for major equipment. Test, adjust, and balance all supply and return air to design CFM. Document final readings.' },
  { step: '06', title: 'Turnover & Warranty', desc: 'O&M documentation package, owner/staff training, and warranty registration. We remain available as the ongoing service provider for the life of the equipment.' },
];

const faqs = [
  { q: 'What size commercial projects do you handle?', a: 'We handle projects from single-suite tenant improvements (500 SF) up to full commercial new construction in the 20,000–50,000 SF range. For larger projects, we work as a HVAC subcontractor alongside the GC. We are licensed in Arizona (ROC-312489) for commercial HVAC work.' },
  { q: 'Can you work with our architect or MEP engineer?', a: 'Yes. We regularly coordinate with architects, structural engineers, and MEP engineers of record. We can provide stamped HVAC drawings, load calculations, and equipment cut sheets to support the design package. For projects requiring an engineer of record, we can refer licensed MEP engineering firms we work with regularly in the Valley.' },
  { q: 'How do you handle phased or occupied TI work?', a: 'We plan shutdowns during off-hours when existing tenant operations are affected. For phased buildouts, we sequence rough-in and trim-out to minimize impact on occupied spaces. We\'ve done multi-phase TI work in occupied medical buildings and multi-tenant retail centers.' },
  { q: 'Do you provide energy compliance documentation?', a: 'Yes. We prepare IECC 2021 and Title 24 compliance documentation for permit submittal. For LEED projects, we provide the HVAC prerequisites documentation including EAc6 (enhanced commissioning) and IEQp1 (minimum IAQ performance). Commissioning reports are provided for all projects that require them under the energy code.' },
];
---

<BaseLayout
  title="Commercial HVAC New Construction & Tenant Improvement in Phoenix, AZ | Skyhooked on Comfort"
  description="Commercial HVAC design-build for new construction and tenant improvements in Phoenix Valley. Permitting, installation, TAB, and commissioning. ROC-licensed. Call (480) 123-4567."
>
  <script type="application/ld+json" is:inline>
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Commercial HVAC New Construction and Tenant Improvement", "provider": { "@type": "HVACBusiness", "name": "Skyhooked on Comfort", "telephone": "(480) 123-4567", "address": { "@type": "PostalAddress", "addressLocality": "Phoenix", "addressRegion": "AZ" } }, "areaServed": "Phoenix Valley, AZ" }
  </script>

  <section class="relative py-24 lg:py-32 overflow-hidden" style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 60%, oklch(0.30 0.025 253) 100%);">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">New Construction · Tenant Improvement · Design-Build</div>
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">Commercial HVAC for <span class="text-sky">New Construction & TI</span></h1>
      <p class="font-body text-neutral-300 text-lg sm:text-xl max-w-2xl mx-auto mb-10">From design through commissioning — we manage the full mechanical scope on commercial new construction and tenant improvements across the Phoenix Valley. Licensed, permitted, and documented.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Request a Bid →</a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-12">What we do</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map(s => (
          <div class="bg-charcoal-50 rounded-2xl p-6 border border-neutral-200">
            <h3 class="font-display font-bold text-charcoal text-lg mb-3">{s.name}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-12">Our process</h2>
      <div class="space-y-4">
        {process.map(p => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-200 flex gap-6 items-start">
            <div class="font-display font-extrabold text-sky text-2xl flex-shrink-0 w-10">{p.step}</div>
            <div>
              <h3 class="font-display font-bold text-charcoal text-lg mb-1">{p.title}</h3>
              <p class="font-body text-neutral-600 text-sm leading-relaxed">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Credentials strip -->
  <section class="bg-charcoal py-14">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-extrabold text-white text-2xl text-center mb-8">Credentials & qualifications</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { label: 'AZ ROC-312489', desc: 'Licensed C-39 HVAC contractor' },
          { label: 'NATE Certified', desc: 'Technicians on all commercial work' },
          { label: 'Carrier Factory Auth.', desc: 'Commercial equipment authorization' },
          { label: 'IECC 2021 Compliant', desc: 'Energy code documentation capability' },
        ].map(c => (
          <div class="bg-white/10 rounded-xl p-4 text-center border border-white/20">
            <div class="font-display font-bold text-sky text-sm mb-1">{c.label}</div>
            <div class="font-body text-neutral-300 text-xs">{c.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Review -->
  <section class="bg-white py-20">
    <div class="max-w-3xl mx-auto px-4">
      <blockquote class="bg-charcoal-50 rounded-2xl p-8 border border-neutral-200">
        <div class="flex gap-1 mb-4">{Array(5).fill(null).map(() => <svg class="w-5 h-5 text-sky" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>)}</div>
        <p class="font-body text-neutral-700 text-lg leading-relaxed mb-5">"We've used Skyhooked on 6 tenant improvement projects across our retail centers. They show up on schedule, pull their own permits, coordinate with the GC without drama, and don't give me call backs asking obvious questions. The commissioning documentation is clean and the inspections pass. That's the job."</p>
        <footer class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">MV</div>
          <div><cite class="font-body font-semibold text-charcoal not-italic text-sm">Mike V., Development Manager</cite><p class="font-body text-neutral-500 text-xs">Phoenix · Retail TI Portfolio</p></div>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl text-center mb-10">Construction HVAC FAQ</h2>
      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors" aria-expanded="false" data-index={i}>
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5"><p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-4">Ready to bid your project?</h2>
      <p class="font-body text-neutral-300 text-lg mb-8">Send us your drawings or project summary and we'll turn a bid around within 3 business days.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Submit Project Details →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) { panel.classList.remove('hidden'); chevron?.classList.add('rotate-180'); btn.setAttribute('aria-expanded', 'true'); }
    });
  });
</script>
