---
import BaseLayout from '../../layouts/BaseLayout.astro';

const solutions = [
  { name: 'High-MERV Commercial Filtration', desc: 'MERV-13 to MERV-15 filtration for commercial air handlers and rooftop units. Removes fine particulates — PM2.5 from Phoenix dust events, wildfire smoke, and vehicle exhaust — without over-restricting airflow on commercial equipment.' },
  { name: 'UV-C Germicidal Systems', desc: 'Commercial-grade UV-C lamp systems installed in AHUs and RTUs. Destroys bacteria, viruses, and mold at the coil — where biofilm accumulation is most common and damaging to efficiency.' },
  { name: 'Dedicated Outdoor Air Systems (DOAS)', desc: 'Standalone ventilation units that handle 100% outdoor air with heat recovery. Separates fresh air from sensible cooling — the ASHRAE 62.1-compliant approach for healthcare, restaurants, and high-occupancy spaces.' },
  { name: 'Energy Recovery Ventilators (ERVs)', desc: 'Recover 70–80% of conditioned air energy while introducing fresh outside air. Critical for LEED-targeted buildings and tight commercial envelopes where natural infiltration is minimal.' },
  { name: 'Bipolar Ionization', desc: 'In-duct ionization units generate positive and negative ions that neutralize airborne pathogens and cause fine particles to agglomerate and fall out of the breathing zone or be captured by filters.' },
  { name: 'Commercial Humidification', desc: 'Steam and evaporative humidification systems for data centers, printing facilities, healthcare, and any commercial space where humidity control is operationally critical.' },
];

const verticals = [
  { name: 'Medical & Dental', desc: 'HEPA filtration, pressure relationships, and ASHRAE 170 compliance for patient safety.' },
  { name: 'Restaurants & Food Service', desc: 'Grease-laden air, kitchen exhaust balance, and HACCP-compliant supply air.' },
  { name: 'Office & Coworking', desc: 'ASHRAE 62.1 minimum ventilation, demand-controlled ventilation (DCV) with CO₂ sensors.' },
  { name: 'Retail', desc: 'Entrance air curtains, high-occupancy load management, and customer comfort.' },
  { name: 'Warehouses & Industrial', desc: 'Dust management, chemical vapor control, makeup air for large exhaust systems.' },
  { name: 'Data Centers', desc: 'Precision humidity control, contamination management, hot-aisle/cold-aisle strategies.' },
];

const faqs = [
  { q: 'What is ASHRAE 62.1 and does my building need to comply?', a: 'ASHRAE 62.1 sets minimum ventilation rates per occupant and per square foot for commercial spaces. It is the reference standard for most commercial building codes in Arizona. Most Phoenix commercial buildings are required to meet it through building permit and certificate of occupancy. We assess compliance during any commercial IAQ evaluation.' },
  { q: 'What is demand-controlled ventilation (DCV)?', a: 'DCV uses CO₂ sensors to modulate outdoor air intake based on actual occupancy. When the space is empty or sparsely occupied, the system reduces outdoor air — saving conditioning energy. When occupancy rises, it increases fresh air to maintain ASHRAE minimums. It is particularly valuable for conference rooms, event spaces, and restaurants.' },
  { q: 'Can IAQ improvements help with employee productivity and retention?', a: 'Research consistently links improved IAQ — particularly ventilation rates and CO₂ levels — with measurable improvements in cognitive function and reduced sick days. ASHRAE and the EPA both cite indoor air quality as a top-5 factor in occupant health and performance. We can quantify your current conditions with before/after air testing.' },
  { q: 'How does Phoenix\'s desert climate affect commercial IAQ?', a: 'Haboob season (April–September) drives particulate loading — fine PM2.5 and PM10 — at levels that overwhelm standard MERV-8 filters. Commercial buildings with leaky envelopes and standard filtration can see measurable indoor PM2.5 spikes during dust events. Higher MERV filtration and building envelope sealing are the two primary mitigations.' },
];
---

<BaseLayout
  title="Commercial Indoor Air Quality in Phoenix, AZ | Skyhooked on Comfort"
  description="ASHRAE 62.1 compliant indoor air quality solutions for Phoenix commercial buildings. DOAS, ERVs, UV-C, MERV filtration, and DCV. Medical, office, restaurant, and industrial."
>
  <script type="application/ld+json" is:inline>
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Commercial Indoor Air Quality", "provider": { "@type": "HVACBusiness", "name": "Skyhooked on Comfort", "telephone": "(480) 123-4567", "address": { "@type": "PostalAddress", "addressLocality": "Phoenix", "addressRegion": "AZ" } }, "areaServed": "Phoenix Valley, AZ" }
  </script>

  <section class="relative py-24 lg:py-32 overflow-hidden" style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 60%, oklch(0.30 0.025 253) 100%);">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">ASHRAE 62.1 · DOAS · ERVs · UV-C</div>
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">Commercial Indoor Air Quality in <span class="text-sky">Phoenix, AZ</span></h1>
      <p class="font-body text-neutral-300 text-lg sm:text-xl max-w-2xl mx-auto mb-10">Poor commercial IAQ isn't just uncomfortable — it's a liability. Inadequate ventilation affects occupant health and productivity; non-compliant filtration fails inspections; mold-laden AHUs create legal exposure. We assess, design, and install compliant solutions.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Request an IAQ Assessment →</a>
      </div>
    </div>
  </section>

  <!-- Solutions -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-12">Commercial IAQ solutions</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {solutions.map(s => (
          <div class="bg-charcoal-50 rounded-2xl p-6 border border-neutral-200 hover:shadow-lg transition-shadow">
            <div class="w-11 h-11 bg-sky/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>
            </div>
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{s.name}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Verticals -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl text-center mb-4">Industries we serve</h2>
      <p class="font-body text-neutral-600 text-center max-w-2xl mx-auto mb-12">Different commercial environments have different IAQ requirements, codes, and priorities. We have experience across the range.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {verticals.map(v => (
          <div class="bg-white rounded-xl p-5 border border-neutral-200">
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{v.name}</h3>
            <p class="font-body text-neutral-600 text-sm">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ASHRAE callout -->
  <section class="bg-sky py-14">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-2xl sm:text-3xl mb-3">ASHRAE 62.1 Compliance Assessment</h2>
      <p class="font-body text-white/90 text-lg mb-6">We perform documented ventilation compliance assessments — useful for new tenant buildouts, lease renewals, health department inspections, and LEED/WELL certification documentation. We provide a written compliance summary you can use in permitting or audit situations.</p>
      <a href="/contact" class="inline-flex items-center gap-2 bg-white hover:bg-neutral-100 text-charcoal font-display font-bold px-7 py-3.5 rounded-xl transition-colors">Schedule an Assessment →</a>
    </div>
  </section>

  <!-- Review -->
  <section class="bg-white py-20">
    <div class="max-w-3xl mx-auto px-4">
      <blockquote class="bg-charcoal-50 rounded-2xl p-8 border border-neutral-200">
        <div class="flex gap-1 mb-4">{Array(5).fill(null).map(() => <svg class="w-5 h-5 text-sky" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>)}</div>
        <p class="font-body text-neutral-700 text-lg leading-relaxed mb-5">"Our dental practice was cited for ventilation deficiencies during a facility inspection. Skyhooked came in, performed an ASHRAE 62.1 assessment, and designed a DOAS upgrade that addressed every line item in the report. They handled the documentation for our architect and passed the re-inspection on the first visit. Exactly what we needed."</p>
        <footer class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">SC</div>
          <div><cite class="font-body font-semibold text-charcoal not-italic text-sm">Dr. Sandra C.</cite><p class="font-body text-neutral-500 text-xs">Tempe · Dental Practice DOAS Upgrade</p></div>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl text-center mb-10">Commercial IAQ FAQ</h2>
      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors" aria-expanded="false" data-index={i}>
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5"><p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-4">Compliant air. Healthy occupants. Protected business.</h2>
      <p class="font-body text-neutral-300 text-lg mb-8">We assess your current conditions against code requirements and recommend only what's actually needed.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Call (480) 123-4567</a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">Request a Quote →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) { panel.classList.remove('hidden'); chevron?.classList.add('rotate-180'); btn.setAttribute('aria-expanded', 'true'); }
    });
  });
</script>
