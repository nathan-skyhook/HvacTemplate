---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "VRF VRV System Installation and Service",
  "name": "VRF / VRV Systems Phoenix AZ",
  "provider": {
    "@type": "HVACBusiness",
    "name": "Skyhooked on Comfort",
    "telephone": "(480) 123-4567",
    "address": { "@type": "PostalAddress", "addressLocality": "Phoenix", "addressRegion": "AZ" }
  },
  "areaServed": { "@type": "State", "name": "Phoenix Valley, AZ" }
};

const benefits = [
  { heading: 'Individual Zone Control', body: 'Every zone is independently controlled. A south-facing conference room can cool while a shaded interior office heats — simultaneously. No compromises, no complaints from occupants.' },
  { heading: 'Energy Efficiency', body: 'VRF systems run on variable-speed compressors that modulate refrigerant flow to exactly what each zone needs. Part-load efficiency is dramatically better than constant-volume RTU systems, which is particularly valuable in Phoenix\'s long shoulder seasons.' },
  { heading: 'Simultaneous Heating & Cooling', body: 'Heat-recovery VRF systems can heat some zones while cooling others, using rejected heat instead of wasting it. Ideal for Phoenix mixed-use buildings with server rooms needing cooling year-round alongside occupied spaces.' },
  { heading: 'Minimal Ductwork', body: 'VRF systems connect indoor units to outdoor condensers via small refrigerant lines — no large duct shafts required. Ideal for tenant improvement projects, historic buildings, and spaces where ductwork is impractical.' },
  { heading: 'Quiet Operation', body: 'Variable-speed inverter compressors at part load are nearly silent. Indoor cassette units and wall mounts are substantially quieter than comparable RTU delivery through ductwork. Important for hotels, libraries, and healthcare spaces.' },
];

const applications = [
  { name: 'Hotels & Extended-Stay', desc: 'Guest rooms on individual zone control, simultaneous heating and cooling across different exposures. Quiet operation critical for guest satisfaction. VRF fleet management and monitoring available.' },
  { name: 'Mixed-Use & Multitenant Office', desc: 'Tenant metering capability, individual zone control without duct modifications between suites, and energy reporting per tenant. Ideal for Phoenix Valley suburban office parks.' },
  { name: 'Historic & Boutique Commercial', desc: 'Buildings where running large ductwork is impractical or would compromise architecture. Refrigerant lines route easily through existing wall and ceiling cavities.' },
  { name: 'Retail & Restaurant Chains', desc: 'Consistent brand standards across multiple locations with remote monitoring and fault alerting. Skyhooked services multi-location VRF fleets across the Phoenix Valley.' },
];

const brands = [
  { name: 'Daikin VRV', desc: 'The VRV brand inventor. Industry-leading reliability, widest product range, strong technical support.' },
  { name: 'Mitsubishi VRF', desc: 'City Multi and R2-series. Exceptional cold-climate performance even for Phoenix winter nights. Excellent parts availability.' },
  { name: 'LG Multi-V', desc: 'Competitive efficiency ratings, strong warranty, growing Phoenix Valley dealer network.' },
  { name: 'Fujitsu VRF', desc: 'Halcyon series with excellent efficiency and quiet operation. Good value at the mid-market tier.' },
];

const faqs = [
  {
    q: 'What is the difference between VRF and VRV?',
    a: 'VRV (Variable Refrigerant Volume) is Daikin\'s trademarked term for the technology. VRF (Variable Refrigerant Flow) is the generic industry term used by all other manufacturers. The technology is the same: a variable-speed compressor modulates refrigerant flow to multiple indoor units independently.',
  },
  {
    q: 'Is VRF suitable for Phoenix\'s extreme heat?',
    a: 'Yes, with proper equipment selection. High-ambient-rated VRF systems from Daikin, Mitsubishi, and LG are available for operating conditions up to 122°F outdoor ambient. Phoenix installers must select high-ambient equipment — standard equipment rated to 115°F can fail in Phoenix peak summer conditions. We specify the correct equipment every time.',
  },
  {
    q: 'How do you service VRF systems once installed?',
    a: 'VRF systems require technicians trained on the specific manufacturer\'s refrigerant circuits, electronic controls, and fault-code diagnosis. Our technicians hold manufacturer training certifications for Daikin, Mitsubishi, and LG systems. We offer VRF-specific maintenance contracts covering refrigerant checks, controls verification, filter cleaning, and annual system reporting.',
  },
  {
    q: 'What is a heat-recovery VRF system?',
    a: 'Heat-recovery VRF (also called 3-pipe or simultaneous heating/cooling VRF) allows some indoor units to heat while others cool simultaneously. The system captures rejected heat from cooling zones and redistributes it to heating zones rather than exhausting it outdoors. Ideal for buildings with server rooms (always cooling) alongside occupied spaces (heating needed in winter).',
  },
  {
    q: 'How long does a commercial VRF installation take?',
    a: 'A typical 20-30 zone VRF system in a 10,000–20,000 SF office or hotel takes 3–5 days for refrigerant line installation, 1–2 days for indoor unit mounting, and 1 day for commissioning and controls programming. Larger projects are phased around tenant occupancy.',
  },
];
---

<BaseLayout
  title="VRF / VRV Systems in Phoenix, AZ | Skyhooked on Comfort"
  description="VRF and VRV system design, installation, and service in Phoenix Valley. Daikin VRV, Mitsubishi, LG, Fujitsu. Hotels, offices, mixed-use. Call (480) 123-4567."
>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <!-- Hero -->
  <section
    class="relative min-h-[60vh] flex flex-col justify-center overflow-hidden"
    style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 50%, oklch(0.30 0.025 253) 100%);"
  >
    <div class="relative max-w-5xl mx-auto px-4 py-24 text-center">
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        VRF &amp; VRV Systems<br class="hidden sm:block"/>
        <span class="text-sky">in Phoenix, AZ</span>
      </h1>
      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        Variable refrigerant flow systems deliver individual zone control, simultaneous heating and cooling, and significantly better part-load efficiency than traditional RTU systems. Skyhooked on Comfort designs, installs, and services VRF and VRV systems for Phoenix Valley hotels, offices, mixed-use buildings, and retail facilities. Daikin VRV, Mitsubishi VRF, LG Multi-V, and Fujitsu — all covered.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Request a Bid →
        </a>
      </div>
    </div>
  </section>


  <!-- What VRF Is -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-6 text-center">What VRF / VRV Is and How It Works</h2>
      <p class="font-body text-neutral-600 text-lg leading-relaxed mb-5">
        A VRF (Variable Refrigerant Flow) system replaces traditional ductwork with a network of small refrigerant lines connecting one or more outdoor condensing units to dozens of individual indoor fan coil units. Each indoor unit — wall mount, ceiling cassette, ducted handler — receives precisely the refrigerant flow it needs at any given moment, independently of every other zone.
      </p>
      <p class="font-body text-neutral-600 text-lg leading-relaxed mb-5">
        The outdoor condenser runs a variable-speed inverter compressor that continuously modulates total system capacity from roughly 15% to 100% of rated output. At 7 AM with only a few zones occupied, the compressor runs slowly and quietly. At 2 PM with a full building in Phoenix July heat, it runs at full capacity. This modulation is why VRF systems achieve dramatically better seasonal efficiency than constant-speed equipment.
      </p>
      <p class="font-body text-neutral-600 text-lg leading-relaxed">
        Heat-recovery (3-pipe) VRF systems add a third circuit that allows rejected heat from cooling zones to be redistributed to zones calling for heat simultaneously — a significant energy advantage in Phoenix's mild winters when perimeter offices need heat while server rooms and south-facing spaces still need cooling.
      </p>
    </div>
  </section>


  <!-- Benefits -->
  <section class="bg-charcoal py-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-white text-3xl sm:text-4xl mb-3">Benefits of VRF for Phoenix Commercial Buildings</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map(b => (
          <div class="bg-charcoal-light/40 rounded-2xl p-6 border border-white/10">
            <h3 class="font-display font-bold text-white text-base mb-2">{b.heading}</h3>
            <p class="font-body text-charcoal-50 text-sm leading-relaxed">{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Applications -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">VRF Applications</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {applications.map(a => (
          <div class="bg-white rounded-2xl p-7 border border-neutral-100 hover:shadow-lg transition-shadow">
            <h3 class="font-display font-bold text-charcoal text-lg mb-3">{a.name}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Brands -->
  <section class="bg-white py-16">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-8 text-center">VRF Brands We Design, Install & Service</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {brands.map(b => (
          <div class="bg-charcoal-50 rounded-xl p-5 border border-neutral-100">
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{b.name}</h3>
            <p class="font-body text-neutral-500 text-sm">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Design + Install + Commission -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl mb-3">Design · Installation · Commissioning</h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">Full-scope VRF project delivery from load calculation through commissioning and staff training.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { n: '01', heading: 'Load Calculation & Design', body: 'Zone-by-zone load calculations, indoor unit selection, outdoor unit sizing, refrigerant line design, and electrical requirements. Manufacturer system design software used on every project.' },
          { n: '02', heading: 'Permit & Approval', body: 'Mechanical permit drawings, equipment cut sheets, and AHJ submissions. We handle all permit correspondence for Phoenix and surrounding jurisdictions.' },
          { n: '03', heading: 'Installation', body: 'Refrigerant line installation, indoor unit mounting, controls wiring, outdoor unit placement. Scheduled around building operations and tenant occupancy.' },
          { n: '04', heading: 'Commissioning & Training', body: 'Full system commissioning per manufacturer procedure. Controls programming, zone scheduling, fault monitoring setup. Staff training on system operation and filter maintenance.' },
        ].map(step => (
          <div>
            <div class="text-6xl font-display font-extrabold text-sky/20 leading-none mb-3">{step.n}</div>
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{step.heading}</h3>
            <p class="font-body text-neutral-500 text-sm leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Reviews -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-charcoal text-3xl mb-2">What Commercial Clients Say</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4">
            {[...Array(5)].map(() => (<svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "120-room hotel VRF system — Daikin VRV across all guest rooms and corridors. Skyhooked did the zone-by-zone load calc, managed all permits, and phased the install floor by floor so we only closed sections at a time. Guest noise complaints dropped significantly compared to our old fan coil units. Professional from design through commissioning."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">CH</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Chris H.</cite>
              <p class="font-body text-neutral-500 text-xs">General Manager · Scottsdale Boutique Hotel</p>
            </div>
          </footer>
        </blockquote>
        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4">
            {[...Array(5)].map(() => (<svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "TI build-out for a 35-person tech office in Phoenix. Old building, no way to run ductwork. Skyhooked designed a Mitsubishi VRF system with ceiling cassettes in every zone. Individual controls per room, quiet enough that nobody complains, and our energy bills are lower than the previous tenant's with a traditional RTU system."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">MK</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Melissa K.</cite>
              <p class="font-body text-neutral-500 text-xs">Office Manager · Phoenix Tech Company</p>
            </div>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>


  <!-- FAQ -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-charcoal text-3xl mb-3">VRF / VRV Systems FAQ</h2>
      </div>
      <div id="faq-list" class="space-y-3 mb-10">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors" aria-expanded="false" data-index={i}>
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5">
              <p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Related -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-6 text-center">Related Commercial Services</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          { href: '/commercial/commercial-ac-systems', name: 'Commercial AC Systems', desc: 'RTUs and package units for traditional builds.' },
          { href: '/commercial/new-construction-tenant-improvement', name: 'New Construction & TI', desc: 'VRF design through commissioning.' },
          { href: '/commercial/preventive-maintenance', name: 'Preventive Maintenance', desc: 'VRF-specific maintenance contracts.' },
        ].map(link => (
          <a href={link.href} class="bg-charcoal-50 rounded-xl p-5 hover:shadow-md transition-shadow border border-neutral-100">
            <h3 class="font-display font-bold text-charcoal text-sm mb-1">{link.name}</h3>
            <p class="font-body text-neutral-500 text-xs">{link.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- CTA -->
  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-6">VRF system project in Phoenix?</h2>
      <p class="font-body text-charcoal-50 text-lg mb-8">Design, permitting, installation, and commissioning. All brands. Site walk within 48 hours.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Request a Bid →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) {
        panel.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
