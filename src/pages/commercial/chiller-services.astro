---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Commercial Chiller Services",
  "name": "Chiller Repair, Maintenance & Replacement Phoenix AZ",
  "provider": {
    "@type": "HVACBusiness",
    "name": "Skyhooked on Comfort",
    "telephone": "(480) 123-4567",
    "address": { "@type": "PostalAddress", "addressLocality": "Phoenix", "addressRegion": "AZ" }
  },
  "areaServed": { "@type": "State", "name": "Phoenix Valley, AZ" }
};

const services = [
  { name: 'Chiller Repair', desc: 'Diagnosis and repair of all chiller types. Compressor, evaporator, condenser, controls, refrigerant circuits. We carry common chiller parts and can source critical components fast across Phoenix Valley suppliers.' },
  { name: 'Preventive Maintenance', desc: 'Scheduled maintenance programs covering condenser tube cleaning, refrigerant leak inspection, oil sampling, controls calibration, and electrical inspection. Service reports after every visit.' },
  { name: 'Chiller Replacement', desc: 'Full project management from load calculation through commissioning. Craned roof access, rigging, curb modification, electrical, controls, and refrigerant management. EPA 608 certified refrigerant handling.' },
  { name: 'Retrofit & Modernization', desc: 'Aging chiller plants consuming too much energy? We evaluate retrofit options — VFD upgrades, refrigerant conversion, controls modernization — and provide ROI projections before capital decisions.' },
];

const chillerTypes = [
  {
    name: 'Air-Cooled Chillers',
    body: 'The dominant chiller type in Phoenix Valley commercial buildings. No cooling tower required — simpler infrastructure, lower maintenance overhead. Air-cooled chillers face demanding conditions with Phoenix\'s extreme ambient temperatures, requiring high-ambient-rated equipment and proper condenser airflow clearances.',
  },
  {
    name: 'Water-Cooled Chillers',
    body: 'Higher efficiency than air-cooled, used in larger buildings where cooling tower infrastructure is present. Water-cooled chillers in Phoenix require careful water treatment programs to manage scale and algae in the tower. We assess cooling tower condition as part of every chiller service.',
  },
];

const applications = [
  { name: 'Large Office Buildings', desc: 'Central chiller plants serving multi-zone air handlers across multiple floors. Controls integration and monitoring.' },
  { name: 'Hospitals & Healthcare', desc: 'Mission-critical uptime requirements. Redundant systems, scheduled downtime coordination, and 24/7 monitoring.' },
  { name: 'Hotels & Resorts', desc: 'Guest comfort requires reliable chiller operation across every zone. VFD-equipped chillers for part-load efficiency during low occupancy.' },
  { name: 'Industrial & Data Centers', desc: 'Process cooling loads and precision temperature requirements. Chiller control sequences written to your process specifications.' },
];

const faqs = [
  {
    q: 'How often should commercial chillers be serviced in Phoenix?',
    a: 'Quarterly inspections are standard, with a full annual shutdown service including tube bundle cleaning, oil analysis, refrigerant leak testing, and controls calibration. Air-cooled condensers in Phoenix need more frequent coil cleaning due to dust storm activity.',
  },
  {
    q: 'Do you service all chiller brands?',
    a: 'Yes — Carrier, Trane, York, Daikin, McQuay, Multistack, and others. We work with each manufacturer\'s recommended service procedures and refrigerant specifications.',
  },
  {
    q: 'What refrigerants do your technicians handle?',
    a: 'EPA Section 608 Universal certified technicians handle R-134a, R-410A, R-22, R-407C, R-1234ze, and other commercial refrigerants. All refrigerant handling is documented per EPA 608 requirements.',
  },
  {
    q: 'Can you replace a chiller without shutting down the building?',
    a: 'For buildings with redundant cooling capacity, yes — we can sequence the replacement to maintain partial cooling. For single-chiller buildings, we plan the replacement for the lowest-load window (typically winter or shoulder season) and coordinate with your facilities team.',
  },
];

const brands = ['Carrier', 'Trane', 'York', 'Daikin', 'McQuay', 'Multistack', 'Dunham-Bush', 'Baltimore Aircoil'];
---

<BaseLayout
  title="Chiller Services in Phoenix, AZ | Skyhooked on Comfort"
  description="Commercial chiller repair, maintenance, and replacement in Phoenix Valley. Air-cooled and water-cooled. EPA 608 certified. All brands. Call (480) 123-4567."
>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <!-- Hero -->
  <section
    class="relative min-h-[60vh] flex flex-col justify-center overflow-hidden"
    style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 50%, oklch(0.30 0.025 253) 100%);"
  >
    <div class="relative max-w-5xl mx-auto px-4 py-24 text-center">
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        Commercial Chiller Services<br class="hidden sm:block"/>
        <span class="text-sky">in Phoenix, AZ</span>
      </h1>
      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        Large-building cooling in Phoenix runs through chiller plants — and Phoenix's extreme summer heat pushes chillers harder than nearly any climate in the country. Skyhooked on Comfort provides expert chiller repair, preventive maintenance, replacement, and retrofit for Phoenix Valley office buildings, hospitals, hotels, and industrial facilities. EPA Section 608 certified on all refrigerant handling.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Request a Bid →
        </a>
      </div>
    </div>
  </section>


  <!-- Chiller Types -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">Air-Cooled vs Water-Cooled Chillers</h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">Both types are common in Phoenix Valley commercial buildings. Each has different maintenance requirements in the desert climate.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {chillerTypes.map(t => (
          <div class="bg-charcoal-50 rounded-2xl p-8 border border-neutral-100">
            <h3 class="font-display font-bold text-charcoal text-xl mb-4">{t.name}</h3>
            <p class="font-body text-neutral-600 leading-relaxed">{t.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Services -->
  <section class="bg-charcoal py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-white text-3xl sm:text-4xl mb-3">Chiller Services We Provide</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {services.map(s => (
          <div class="bg-charcoal-light/40 rounded-2xl p-7 border border-white/10">
            <h3 class="font-display font-bold text-white text-lg mb-3">{s.name}</h3>
            <p class="font-body text-charcoal-50 text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Applications -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">Applications</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {applications.map(a => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-100 hover:shadow-lg transition-shadow">
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{a.name}</h3>
            <p class="font-body text-neutral-500 text-sm leading-relaxed">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Brands -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-6">Chiller Brands We Service</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {brands.map(b => (
          <span class="bg-charcoal-50 border border-neutral-200 text-charcoal font-body font-semibold text-sm px-4 py-2 rounded-xl">{b}</span>
        ))}
      </div>
    </div>
  </section>


  <!-- Process -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl mb-3">Our Chiller Service Process</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { n: '01', heading: 'Assessment', body: 'Chiller inspection: compressor condition, refrigerant charge, controls, evaporator and condenser condition, operating logs review.' },
          { n: '02', heading: 'Proposal', body: 'Written scope with repair vs. replacement analysis, ROI projections, equipment options, and project timeline.' },
          { n: '03', heading: 'Service or Install', body: 'EPA 608 certified refrigerant handling. Permits pulled. Work scheduled around building operations. Rigging and crane coordination for replacements.' },
          { n: '04', heading: 'Documentation', body: 'Refrigerant logs, commissioning report, service records, and warranty registration. All compliance documentation in your customer portal.' },
        ].map(step => (
          <div>
            <div class="text-6xl font-display font-extrabold text-sky/20 leading-none mb-3">{step.n}</div>
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{step.heading}</h3>
            <p class="font-body text-neutral-500 text-sm leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- EPA Compliance -->
  <section class="bg-charcoal py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display font-bold text-white text-3xl mb-4">EPA 608 Refrigerant Compliance</h2>
      <p class="font-body text-charcoal-50 text-lg leading-relaxed mb-6">
        Commercial chiller refrigerant handling requires EPA Section 608 Universal certification — the highest certification level. Every Skyhooked technician working on chiller refrigerant circuits carries EPA 608 Universal. We maintain complete refrigerant purchase and recovery logs per EPA requirements, and provide refrigerant records as part of every service report. No shortcuts on compliance.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <span class="bg-sky/20 text-sky font-display font-bold text-sm px-4 py-2 rounded-full border border-sky/30">EPA 608 Universal Certified</span>
        <span class="bg-sky/20 text-sky font-display font-bold text-sm px-4 py-2 rounded-full border border-sky/30">Refrigerant Logs Provided</span>
        <span class="bg-sky/20 text-sky font-display font-bold text-sm px-4 py-2 rounded-full border border-sky/30">AZ ROC-312489</span>
      </div>
    </div>
  </section>


  <!-- Reviews -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-charcoal text-3xl mb-2">What Commercial Clients Say</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4">
            {[...Array(5)].map(() => (<svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "450-ton air-cooled chiller replacement on our Phoenix office tower. Skyhooked managed the entire project — craned removal, curb modification for the new equipment, electrical and controls work, commissioning. Complete refrigerant logs provided for our EPA compliance file. Came in on schedule and on budget."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">BW</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Brian W.</cite>
              <p class="font-body text-neutral-500 text-xs">VP Facilities · Phoenix Office Tower</p>
            </div>
          </footer>
        </blockquote>
        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4">
            {[...Array(5)].map(() => (<svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "Quarterly chiller maintenance on two water-cooled York units. Service reports are detailed and accurate — oil samples sent to the lab, tube bundle inspections documented with photos, refrigerant logs ready for our environmental auditor. This is what professional chiller service looks like."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">SL</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Sandra L.</cite>
              <p class="font-body text-neutral-500 text-xs">Director of Facilities · Scottsdale Resort</p>
            </div>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>


  <!-- FAQ -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-charcoal text-3xl mb-3">Chiller Services FAQ</h2>
      </div>
      <div id="faq-list" class="space-y-3 mb-10">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors" aria-expanded="false" data-index={i}>
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5">
              <p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Related -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-6 text-center">Related Commercial Services</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          { href: '/commercial/commercial-ac-systems', name: 'Commercial AC Systems', desc: 'RTUs, split systems, and AHUs.' },
          { href: '/commercial/preventive-maintenance', name: 'Preventive Maintenance', desc: 'Quarterly chiller maintenance contracts.' },
          { href: '/commercial/vrf-vrv-systems', name: 'VRF / VRV Systems', desc: 'Distributed cooling without a chiller plant.' },
        ].map(link => (
          <a href={link.href} class="bg-charcoal-50 rounded-xl p-5 hover:shadow-md transition-shadow border border-neutral-100">
            <h3 class="font-display font-bold text-charcoal text-sm mb-1">{link.name}</h3>
            <p class="font-body text-neutral-500 text-xs">{link.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- CTA -->
  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-6">Commercial chiller project in Phoenix?</h2>
      <p class="font-body text-charcoal-50 text-lg mb-8">Repair, maintenance, or replacement — EPA 608 certified, all brands. Site walk within 48 hours.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Request a Bid →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) {
        panel.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
