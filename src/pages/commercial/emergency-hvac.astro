---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Commercial Emergency HVAC",
  "name": "24/7 Commercial Emergency HVAC Phoenix",
  "provider": {
    "@type": "HVACBusiness",
    "name": "Skyhooked on Comfort",
    "telephone": "(480) 123-4567",
    "address": { "@type": "PostalAddress", "addressLocality": "Phoenix", "addressRegion": "AZ" }
  },
  "areaServed": { "@type": "State", "name": "Phoenix Valley, AZ" },
  "availableChannel": { "@type": "ServiceChannel", "serviceUrl": "https://skyhookedoncomfort.com/commercial/emergency-hvac" }
};

const scenarios = [
  {
    heading: 'Restaurant During Dinner Rush',
    body: 'A failed RTU at 5:30 PM on a Friday is a full ticket night lost. Contract clients get front-of-queue dispatch — our team understands revenue-critical windows.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/>`,
  },
  {
    heading: 'Medical Office & Clinical Spaces',
    body: 'Patient care cannot happen when operatories are too warm or ventilation fails. We coordinate with facility managers and respond on a timeline that protects patient safety.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>`,
  },
  {
    heading: 'Grocery & Cold Storage',
    body: 'A refrigeration system failure over a holiday weekend can mean tens of thousands in lost inventory. We carry common commercial refrigeration parts and respond 24/7/365.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/>`,
  },
];

const faqs = [
  {
    q: 'How fast does Skyhooked respond to commercial emergencies?',
    a: 'Contract clients get front-of-queue dispatch. Most Phoenix Valley commercial emergency calls are on-site within 60–90 minutes, 24/7/365 including holidays.',
  },
  {
    q: 'Are there overtime or after-hours fees on commercial emergency calls?',
    a: 'No. Skyhooked charges flat-rate pricing on all commercial work, including nights, weekends, and holidays. You get a written quote before any work begins.',
  },
  {
    q: 'Do contract clients get priority over non-contract clients?',
    a: 'Yes. Preventive maintenance contract clients get priority dispatch on every emergency call — front of the queue, every time.',
  },
  {
    q: 'Can you handle large commercial refrigeration emergencies, not just HVAC?',
    a: 'Yes. We service walk-in coolers, walk-in freezers, reach-in cases, and commercial display cases alongside commercial HVAC. One call covers your building.',
  },
  {
    q: 'What commercial systems do you work on for emergency calls?',
    a: 'RTUs, split systems, package units, AHUs, chillers, VRF/VRV systems, boilers, commercial furnaces, and commercial refrigeration — all major brands, all Phoenix Valley.',
  },
];
---

<BaseLayout
  title="Commercial Emergency HVAC in Phoenix, AZ | Skyhooked on Comfort"
  description="24/7 commercial HVAC emergency response in Phoenix Valley. No overtime fees. Priority dispatch for contract clients. RTUs, chillers, refrigeration. Call (480) 123-4567."
>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <!-- Hero -->
  <section
    class="relative min-h-[60vh] flex flex-col justify-center overflow-hidden"
    style="background: linear-gradient(135deg, oklch(0.44 0.21 23) 0%, oklch(0.54 0.22 23) 60%, oklch(0.30 0.025 253) 100%);"
  >
    <div class="relative max-w-5xl mx-auto px-4 py-24 text-center">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-white"></span>
        </span>
        24/7 Commercial Emergency Response
      </div>

      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        Commercial HVAC Emergency<br class="hidden sm:block"/>
        <span class="text-sky">Phoenix Valley — We're On the Way</span>
      </h1>

      <p class="font-body text-white/80 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        Commercial HVAC failures don't wait for business hours. Skyhooked on Comfort runs 24/7 emergency response for the Phoenix Valley's commercial operators — restaurants, healthcare, office buildings, and grocery. No overtime fees. No call centers. Real technicians, dispatched fast.
      </p>

      <a
        href="tel:4801234567"
        class="inline-flex items-center gap-3 bg-sky hover:bg-sky-dark text-charcoal font-display font-extrabold text-2xl px-10 py-5 rounded-2xl transition-colors shadow-xl mb-4"
      >
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Call (480) 123-4567 Now
      </a>
      <p class="font-body text-white/70 text-sm">No overtime fees · Real humans answer · AZ ROC-312489</p>
    </div>
  </section>


  <!-- What Counts as a Commercial Emergency -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-6 text-center">What Counts as a Commercial HVAC Emergency</h2>
      <p class="font-body text-neutral-600 text-lg text-center mb-10 max-w-2xl mx-auto">If your operation is at risk, it's an emergency. Call us if:</p>

      <ul class="space-y-3 mb-10">
        {[
          'RTU or package unit completely down during operating hours',
          'Building temperature exceeding 85°F with guests, patients, or staff present',
          'Walk-in cooler or freezer above safe temperature thresholds',
          'Refrigerant leak detected — visible ice, hissing, or pressure alarms',
          'Boiler or commercial heating failure in occupied buildings',
          'Chiller offline with server rooms, data closets, or medical equipment at risk',
          'Fire, water, or electrical damage to HVAC equipment',
          'Ventilation failure in healthcare, lab, or food-service spaces',
          'Kitchen makeup air system down during a service period',
          'VRF or VRV system throwing fault codes with zones offline',
        ].map(item => (
          <li class="flex items-start gap-3 bg-charcoal-50 rounded-xl px-5 py-4">
            <svg class="w-5 h-5 text-emergency flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
            <span class="font-body text-charcoal text-base">{item}</span>
          </li>
        ))}
      </ul>

      <p class="font-body text-neutral-600 text-center italic">Not on this list but you're concerned? Call. We'd rather diagnose it than have you guess.</p>
    </div>
  </section>


  <!-- Priority Response for Contract Clients -->
  <section class="bg-charcoal py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display font-bold text-white text-3xl sm:text-4xl mb-5">Priority Response for Contract Clients</h2>
          <p class="font-body text-charcoal-50 text-lg leading-relaxed mb-6">
            Preventive maintenance contract clients get front-of-queue dispatch on every emergency call — no exceptions, no call-center triage. Your account manager knows your buildings, your equipment, and your operating schedule before the phone rings.
          </p>
          <ul class="space-y-3 mb-8">
            {[
              'Front-of-queue dispatch, 24/7/365',
              'Account manager who knows your property',
              'Equipment history on file — faster diagnosis',
              'Discounted emergency labor rates',
              'Priority parts sourcing across Phoenix',
            ].map(item => (
              <li class="flex items-center gap-3 font-body text-charcoal-50">
                <svg class="w-5 h-5 text-sky flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/commercial/preventive-maintenance" class="inline-flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold px-6 py-3 rounded-lg transition-colors">
            Learn About Maintenance Contracts →
          </a>
        </div>
        <div class="bg-charcoal-light/40 rounded-2xl p-8 border border-white/10">
          <h3 class="font-display font-bold text-white text-xl mb-4">Response Time Commitment</h3>
          <div class="space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-sky/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <span class="font-display font-extrabold text-sky text-lg">60</span>
              </div>
              <div>
                <p class="font-display font-bold text-white text-sm">Minutes</p>
                <p class="font-body text-charcoal-50 text-sm">Typical on-site for contract clients in Phoenix</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-sky/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <span class="font-display font-extrabold text-sky text-lg">24/7</span>
              </div>
              <div>
                <p class="font-display font-bold text-white text-sm">Always Available</p>
                <p class="font-body text-charcoal-50 text-sm">Including holidays, weekends, and peak season</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-sky/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <span class="font-display font-extrabold text-sky text-lg">$0</span>
              </div>
              <div>
                <p class="font-display font-bold text-white text-sm">Overtime Fee</p>
                <p class="font-body text-charcoal-50 text-sm">Flat-rate pricing, no after-hours surcharges — ever</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Commercial-Specific Scenarios -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">Commercial Emergencies We Handle Every Week</h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">Phoenix's extreme heat creates unique pressure on commercial systems. We've seen it all.</p>
      </div>

      <div class="grid sm:grid-cols-3 gap-6">
        {scenarios.map(s => (
          <div class="bg-white rounded-2xl p-7 border border-neutral-100 hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 bg-emergency/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-emergency" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true" set:html={s.icon}></svg>
            </div>
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{s.heading}</h3>
            <p class="font-body text-neutral-500 text-sm leading-relaxed">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Reviews -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-2">What Commercial Clients Say</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
            ))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "Rooftop unit went down at 4 PM on a Friday — packed dining room, 108° outside. Skyhooked had a tech on-site in under 90 minutes. Capacitor and contactor replaced, back running before the dinner rush peaked. No overtime charge. These guys understand what a restaurant emergency actually means."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">JR</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">James R.</cite>
              <p class="font-body text-neutral-500 text-xs">Operations Manager · Scottsdale Restaurant Group</p>
            </div>
          </footer>
        </blockquote>

        <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
          <div class="flex items-center gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
            ))}
          </div>
          <p class="font-body text-neutral-700 text-base leading-relaxed mb-5">
            "Walk-in cooler temperature climbed over the Fourth of July weekend. Called at 7 AM Saturday — tech was here by 8:30. Refrigerant leak found and repaired before we lost the inventory. They're on our maintenance contract now and we haven't had an unplanned failure since."
          </p>
          <footer class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-sm">PM</div>
            <div>
              <cite class="font-body font-semibold text-charcoal not-italic text-sm">Patricia M.</cite>
              <p class="font-body text-neutral-500 text-xs">General Manager · Phoenix-area Grocery</p>
            </div>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>


  <!-- FAQ -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">Commercial Emergency FAQ</h2>
      </div>

      <div id="faq-list" class="space-y-3 mb-10">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button
              class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors"
              aria-expanded="false"
              data-index={i}
            >
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5">
              <p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Related -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-2xl mb-6 text-center">Related Commercial Services</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          { href: '/commercial/preventive-maintenance', name: 'Preventive Maintenance Contracts', desc: 'Prevent the emergency before it happens.' },
          { href: '/commercial/commercial-ac-systems', name: 'Commercial AC Systems', desc: 'RTUs, split systems, package units, AHUs.' },
          { href: '/commercial/commercial-refrigeration', name: 'Commercial Refrigeration', desc: 'Walk-in coolers, freezers, and display cases.' },
        ].map(link => (
          <a href={link.href} class="bg-charcoal-50 rounded-xl p-5 hover:shadow-md transition-shadow border border-neutral-100">
            <h3 class="font-display font-bold text-charcoal text-sm mb-1">{link.name}</h3>
            <p class="font-body text-neutral-500 text-xs">{link.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- Bottom CTA -->
  <section class="bg-emergency py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl lg:text-5xl mb-6 leading-tight">
        Commercial HVAC emergency<br/>
        <span class="text-sky">in Phoenix? Call now.</span>
      </h2>
      <a
        href="tel:4801234567"
        class="inline-flex items-center gap-3 bg-sky hover:bg-sky-dark text-charcoal font-display font-extrabold text-2xl px-10 py-5 rounded-2xl transition-colors shadow-xl mb-6"
      >
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Call (480) 123-4567 Now
      </a>
      <p class="font-body text-white/80 text-base">
        24/7 · No overtime fees · Contract clients front of queue
      </p>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) {
        panel.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
