---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  {
    href: '/commercial/emergency-hvac',
    name: 'Emergency Commercial HVAC',
    desc: '24/7 priority response for contract clients.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>`,
  },
  {
    href: '/commercial/commercial-ac-systems',
    name: 'Commercial AC Systems',
    desc: 'RTUs, split systems, package units, AHUs.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>`,
  },
  {
    href: '/commercial/commercial-heating-boilers',
    name: 'Commercial Heating & Boilers',
    desc: 'Boilers, commercial furnaces, heat pumps.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/>`,
  },
  {
    href: '/commercial/chiller-services',
    name: 'Chiller Services',
    desc: 'Air-cooled and water-cooled chiller repair & replacement.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>`,
  },
  {
    href: '/commercial/vrf-vrv-systems',
    name: 'VRF / VRV Systems',
    desc: 'Daikin VRV, Mitsubishi VRF, design + install.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>`,
  },
  {
    href: '/commercial/commercial-refrigeration',
    name: 'Commercial Refrigeration',
    desc: 'Walk-in coolers, freezers, reach-in cases.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/>`,
  },
  {
    href: '/commercial/preventive-maintenance',
    name: 'Preventive Maintenance Contracts',
    desc: 'Custom plans for property managers and operators.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
  {
    href: '/commercial/indoor-air-quality-commercial',
    name: 'Commercial Indoor Air Quality',
    desc: 'ASHRAE 62.1 ventilation, filtration upgrades.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>`,
  },
  {
    href: '/commercial/new-construction-tenant-improvement',
    name: 'New Construction & Tenant Improvement',
    desc: 'HVAC scope from design through punch list.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/>`,
  },
  {
    href: '/commercial/industries-served',
    name: 'Industries Served',
    desc: 'Specialized expertise across 7 commercial verticals.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/>`,
  },
];

const whyUs = [
  {
    heading: 'Insured & Bonded for Commercial Work',
    body: '$2M general liability insurance certificate available before work begins. Fully bonded. Qualified for projects of every scale across the Phoenix Valley.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>`,
  },
  {
    heading: 'EPA Section 608 Universal Certified',
    body: 'Every technician carries EPA 608 Universal certification — required for all commercial refrigerant handling. No shortcuts on compliance.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/>`,
  },
  {
    heading: 'AZ Code & Permit Expertise',
    body: 'We pull permits, schedule inspections, and handle all AHJ correspondence. Familiar with Arizona mechanical code and Phoenix Valley jurisdiction requirements.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"/>`,
  },
  {
    heading: 'Dedicated Account Managers',
    body: 'Every contract gets a single point of contact — not a call center. Your account manager knows your equipment, your buildings, and your operational schedule.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>`,
  },
  {
    heading: 'Scheduling Around Your Operations',
    body: 'Restaurants get nights and early mornings. Offices get weekends. Healthcare gets coordinated downtime windows. We work around your business — not the other way around.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
];

const industries = [
  { name: 'Property Management & HOA', desc: 'Multifamily, commercial portfolios, bundled contracts', href: '/commercial/industries-served#property-management' },
  { name: 'Restaurants & Food Service', desc: 'Kitchen exhaust, makeup air, walk-in refrigeration', href: '/commercial/industries-served#restaurants' },
  { name: 'Healthcare', desc: 'ASHRAE 170 ventilation, coordinated downtime, infection control', href: '/commercial/industries-served#healthcare' },
  { name: 'Retail & Hospitality', desc: 'Hotels, fitness centers, shopping centers', href: '/commercial/industries-served#retail' },
  { name: 'Offices & Mixed-Use', desc: 'RTU service, controls, IAQ, tenant improvement', href: '/commercial/industries-served#offices' },
  { name: 'Education', desc: 'Summer scheduling, HEPA filtration, budget cycles', href: '/commercial/industries-served#education' },
  { name: 'Industrial & Manufacturing', desc: 'Process cooling, makeup air, ventilation exhaust', href: '/commercial/industries-served#industrial' },
];

const bidSteps = [
  { n: '01', heading: 'Tell Us About the Project', body: 'Scope, square footage, timeline, property type, and drawings if available. The more detail, the faster the bid.' },
  { n: '02', heading: 'Site Walk Within 48 Hours', body: 'Account manager and lead technician survey the property together. No charge for the site walk on projects we bid.' },
  { n: '03', heading: 'Detailed Written Bid', body: 'Line-item pricing, project schedule, permit handling, equipment cut sheets, and clear inclusions/exclusions.' },
  { n: '04', heading: 'Project Kickoff', body: 'Single point of contact, daily updates during work, zero surprises at closeout. AZ ROC-312489.' },
];
---

<BaseLayout
  title="Commercial HVAC Services in Phoenix, AZ | Skyhooked on Comfort"
  description="Commercial HVAC for Phoenix Valley property managers, restaurants, healthcare, retail. RTUs, chillers, VRF, refrigeration. Maintenance contracts. Call (480) 123-4567."
>

  <!-- Hero -->
  <section
    class="relative min-h-[70vh] flex flex-col justify-center bg-charcoal-dark overflow-hidden"
    style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 50%, oklch(0.30 0.025 253) 100%);"
  >
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full opacity-10" style="background: radial-gradient(circle, oklch(0.58 0.13 233), transparent);"></div>
      <div class="absolute bottom-0 -left-20 w-80 h-80 rounded-full opacity-5" style="background: radial-gradient(circle, oklch(0.58 0.13 233), transparent);"></div>
    </div>

    <div class="relative max-w-5xl mx-auto px-4 py-24 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-sky"></span>
        </span>
        Licensed Commercial HVAC · AZ ROC-312489
      </div>

      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        Commercial HVAC Your<br class="hidden sm:block"/>
        <span class="text-sky">Phoenix Valley Operation</span><br class="hidden sm:block"/>
        Can Rely On
      </h1>

      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        From a rooftop unit down on a 110° Phoenix day to a full chiller replacement, Skyhooked on Comfort handles commercial HVAC across the Phoenix Valley — code-compliant, on schedule, and under budget. Licensed for projects of every size, with contracts that prevent emergencies before they happen.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="tel:4801234567"
          class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a
          href="/contact"
          class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors"
        >
          Request a Bid →
        </a>
      </div>
    </div>
  </section>


  <!-- Services Grid -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">Commercial HVAC Services</h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">Every commercial HVAC service the Phoenix Valley needs, backed by our license and satisfaction guarantee.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {services.map(service => (
          <a
            href={service.href}
            class="group bg-neutral-50 hover:bg-charcoal rounded-2xl p-6 transition-colors border border-neutral-100 hover:border-charcoal"
          >
            <div class="w-11 h-11 bg-sky/15 group-hover:bg-sky/20 rounded-xl flex items-center justify-center mb-4 transition-colors">
              <svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true" set:html={service.icon}></svg>
            </div>
            <h3 class="font-display font-bold text-charcoal group-hover:text-white text-base mb-1.5 transition-colors">{service.name}</h3>
            <p class="font-body text-neutral-500 group-hover:text-charcoal-50 text-sm mb-3 transition-colors">{service.desc}</p>
            <span class="font-body text-sky text-sm font-semibold">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- Why Commercial Operators Choose Us -->
  <section class="bg-charcoal py-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-white text-3xl sm:text-4xl mb-3">
          Why commercial operators across Phoenix choose Skyhooked on Comfort.
        </h2>
        <p class="font-body text-charcoal-50 text-lg max-w-2xl mx-auto">
          Five non-negotiables that separate commercial HVAC providers from commercial HVAC partners.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {whyUs.map(item => (
          <div class="bg-charcoal-light/40 rounded-2xl p-6 border border-white/10">
            <div class="w-12 h-12 bg-sky/20 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true" set:html={item.icon}></svg>
            </div>
            <h3 class="font-display font-bold text-white text-base mb-2">{item.heading}</h3>
            <p class="font-body text-charcoal-50 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Industries Served -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">Industries We Serve</h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">Specialized HVAC experience across the commercial verticals that drive the Phoenix Valley economy.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
        {industries.map(ind => (
          <a
            href={ind.href}
            class="group bg-white rounded-2xl p-6 border border-neutral-100 hover:shadow-lg hover:border-sky transition-all"
          >
            <h3 class="font-display font-bold text-charcoal text-base mb-2 group-hover:text-sky transition-colors">{ind.name}</h3>
            <p class="font-body text-neutral-500 text-sm leading-relaxed">{ind.desc}</p>
          </a>
        ))}
      </div>

      <div class="text-center">
        <a href="/commercial/industries-served" class="inline-flex items-center gap-2 bg-charcoal hover:bg-charcoal-light text-white font-display font-bold px-6 py-3 rounded-lg transition-colors">
          See industry-specific capabilities →
        </a>
      </div>
    </div>
  </section>


  <!-- Maintenance Contracts Callout -->
  <section class="bg-sky py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-charcoal text-3xl sm:text-4xl mb-4">
        Stop reacting. Start preventing.
      </h2>
      <p class="font-body text-charcoal/80 text-lg mb-6 max-w-2xl mx-auto leading-relaxed">
        Commercial HVAC failures cost orders of magnitude more than the maintenance that prevents them. A restaurant losing AC during Saturday dinner service. A medical office turning patients away because operatories are too warm. A grocer losing a walk-in cooler over a holiday weekend. Skyhooked builds custom preventive maintenance plans for Phoenix Valley properties of every size — quarterly tune-ups, filter changes, coil cleaning, refrigerant checks, and priority emergency dispatch. Bundled plans typically run 20–30% less than à la carte service.
      </p>
      <a href="/commercial/preventive-maintenance" class="inline-flex items-center gap-2 bg-charcoal hover:bg-charcoal-dark text-white font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
        Build a Maintenance Plan →
      </a>
    </div>
  </section>


  <!-- Bid Process -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">How the Bid Process Works</h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">No surprises, no runaround. From your first call to project closeout.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {bidSteps.map(step => (
          <div class="relative">
            <div class="text-6xl font-display font-extrabold text-sky/20 leading-none mb-3">{step.n}</div>
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{step.heading}</h3>
            <p class="font-body text-neutral-500 text-sm leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Bottom CTA -->
  <section class="bg-charcoal py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl lg:text-5xl mb-6 leading-tight">
        Get a commercial HVAC bid<br/>
        <span class="text-sky">this week.</span>
      </h2>
      <p class="font-body text-charcoal-50 text-lg mb-8 max-w-lg mx-auto">
        Site walks typically within 48 hours. Detailed written bid with line-item pricing, schedule, and permit plan. No obligation.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="tel:4801234567"
          class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a
          href="/contact"
          class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors"
        >
          Request a Bid →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
