---
import BaseLayout from '../layouts/BaseLayout.astro';

const covers = [
  'AC system replacement (central split, heat pump, or package unit)',
  'Heating system replacement (furnace, boiler, electric heat)',
  'Heat pump installation — often stackable with the 30% federal tax credit and utility rebates',
  'Ductless mini-split installs (single-zone and multi-zone)',
  'Whole-home indoor air quality upgrades (filtration, UV, purifiers)',
  'Duct replacement or major duct repair',
  'Any single project over $500',
];

const plans = [
  {
    term: '0% APR — 12 Months',
    desc: 'Qualified buyers. Projects over $1,000.',
    detail: 'Break your project into 12 equal payments with zero interest. Ideal for smaller repairs or AC tune-up upgrades.',
    popular: false,
  },
  {
    term: '0% APR — 18 Months',
    desc: 'Qualified buyers. Projects over $2,500.',
    detail: 'More runway on mid-size projects like AC or furnace replacements. 18 equal payments, no interest.',
    popular: false,
  },
  {
    term: '0% APR — 60 Months',
    desc: 'Qualified buyers. Projects over $5,000.',
    detail: 'The most popular option for full system replacements and heat pump conversions. Five years of interest-free payments.',
    popular: true,
  },
  {
    term: 'Low-APR — 60 to 84 Months',
    desc: 'For larger projects and budget-conscious buyers.',
    detail: 'Extended terms for full heat pump conversions, commercial installs, or multi-system replacements. Flexible APR based on credit profile.',
    popular: false,
  },
];

const steps = [
  { step: '1', title: 'Get your flat-rate quote.', body: 'Our technician diagnoses the issue or evaluates the install, then gives you a written, all-in flat-rate quote. No hidden fees, no after-the-fact surprises.' },
  { step: '2', title: 'Choose your financing partner.', body: 'We work with GoodLeap and Synchrony — two of the largest home improvement lenders. You pick whichever fits your situation.' },
  { step: '3', title: 'Apply in 90 seconds.', body: 'Apply right on the technician\'s tablet. Soft credit pull only — no impact on your credit score to check your options.' },
  { step: '4', title: 'Decision in minutes. Work starts.', body: 'Most approvals come back in under 2 minutes. Once you approve the terms and the quote, we start the work. Monthly payments go directly to the lender.' },
];

const faqs = [
  {
    q: 'Will applying for financing hurt my credit score?',
    a: 'Pre-qualification uses a soft pull — no impact on your credit. A hard pull only happens if you accept the loan offer. You can check your rate without any credit consequence.',
  },
  {
    q: 'Can I pay off the loan early?',
    a: 'Yes. Both GoodLeap and Synchrony allow early payoff with no prepayment penalty. Pay it off whenever you\'re ready.',
  },
  {
    q: 'Do I have to finance the entire project?',
    a: 'No. You can put any amount down and finance the remainder. Some customers put down the tax credit they expect to receive and finance the rest.',
  },
  {
    q: 'Does financing combine with the federal 25C heat pump tax credit?',
    a: 'Yes. Finance the install now; the 30% federal tax credit (up to $2,000) comes back to you separately when you file your taxes. You get the tax credit regardless of how you paid.',
  },
  {
    q: 'Does financing combine with SRP or APS utility rebates?',
    a: 'Yes. Most utility rebates are applied after installation regardless of payment method. We help you file the rebate paperwork.',
  },
  {
    q: 'What\'s the minimum project size to qualify?',
    a: 'Projects over $500 qualify. The 0% APR 60-month option requires a minimum of $5,000 (most full system replacements qualify).',
  },
];
---

<BaseLayout
  title="HVAC Financing in Phoenix, AZ | 0% APR Available | Skyhooked on Comfort"
  description="Finance your new AC, heat pump, or furnace with Skyhooked on Comfort. 0% APR options, soft credit check, decisions in minutes. GoodLeap and Synchrony partners."
>

  <!-- Hero -->
  <section class="bg-charcoal py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl leading-tight mb-6">
        New system today.<br/>Pay over time.
      </h1>
      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed mb-10">
        AC and heating replacements are major investments. We've partnered with GoodLeap and Synchrony so you can break the project into monthly payments — soft credit pull, no impact on your score, decision in under 90 seconds.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://www.goodleap.com" target="_blank" rel="noopener" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold px-7 py-4 rounded-xl transition-colors shadow-lg">
          Apply with GoodLeap →
        </a>
        <a href="https://www.synchrony.com" target="_blank" rel="noopener" class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold px-7 py-4 rounded-xl transition-colors">
          Apply with Synchrony →
        </a>
      </div>
    </div>
  </section>


  <!-- What Financing Covers -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-4">What financing covers.</h2>
        <p class="font-body text-neutral-600 text-lg">Any of these projects can be financed through our partners.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {covers.map(item => (
          <div class="flex items-start gap-3 bg-charcoal-50 rounded-xl p-4 border border-charcoal/10">
            <svg class="w-5 h-5 text-sky flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span class="font-body text-neutral-700 text-sm leading-relaxed">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Plan Tiers -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-4">Financing plan options.</h2>
        <p class="font-body text-neutral-600 text-lg max-w-xl mx-auto">Multiple terms available through GoodLeap and Synchrony. Choose what fits your project and budget.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {plans.map(plan => (
          <div class={`relative rounded-2xl p-6 border-2 ${plan.popular ? 'border-sky bg-charcoal text-white' : 'border-neutral-200 bg-white'}`}>
            {plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-sky text-charcoal text-xs font-display font-bold px-4 py-1 rounded-full whitespace-nowrap">
                Most Popular
              </div>
            )}
            <div class={`font-display font-extrabold text-xl mb-1 ${plan.popular ? 'text-sky' : 'text-charcoal'}`}>{plan.term}</div>
            <div class={`font-body text-xs font-semibold mb-4 ${plan.popular ? 'text-sky/80' : 'text-neutral-500'}`}>{plan.desc}</div>
            <p class={`font-body text-sm leading-relaxed ${plan.popular ? 'text-charcoal-50' : 'text-neutral-600'}`}>{plan.detail}</p>
          </div>
        ))}
      </div>
      <p class="font-body text-neutral-500 text-sm text-center mt-6">Rates and terms subject to credit approval. Not all customers will qualify for 0% APR. See lender terms for details.</p>
    </div>
  </section>


  <!-- How It Works -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-4">How it works.</h2>
        <p class="font-body text-neutral-600 text-lg">Start to funded in minutes, not days.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {steps.map(step => (
          <div class="text-center">
            <div class="w-14 h-14 bg-sky/15 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <span class="font-display font-extrabold text-sky text-2xl">{step.step}</span>
            </div>
            <h3 class="font-display font-bold text-charcoal text-base mb-2">{step.title}</h3>
            <p class="font-body text-neutral-600 text-sm leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- FAQ -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-charcoal text-3xl text-center mb-10">Financing FAQs.</h2>
      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
            <button
              class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors"
              aria-expanded="false"
              data-index={i}
            >
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5">
              <p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Bottom CTA -->
  <section class="bg-charcoal py-16">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-bold text-white text-3xl mb-4">Ready to start your project?</h2>
      <p class="font-body text-charcoal-50 text-lg mb-8">Apply above with GoodLeap or Synchrony, or call us and we'll walk you through the options on-site.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:4801234567" class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors">
          Request a Quote →
        </a>
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-sm font-body">
        <a href="/promotions" class="text-charcoal-50 hover:text-white transition-colors">Current Promotions</a>
        <a href="/residential/heat-pump-installation" class="text-charcoal-50 hover:text-white transition-colors">Heat Pump Install</a>
        <a href="/residential/ac-installation" class="text-charcoal-50 hover:text-white transition-colors">AC Installation</a>
        <a href="/maintenance-plans" class="text-charcoal-50 hover:text-white transition-colors">Maintenance Plans</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) {
        panel.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
