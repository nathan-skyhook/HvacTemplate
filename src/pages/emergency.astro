---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="24/7 Emergency HVAC in Phoenix, AZ | Skyhooked on Comfort"
  description="No heat, no cool, gas smell, CO alarm? Skyhooked on Comfort is available 24/7 across the Phoenix Valley. Real humans answer. Typical response under 60 minutes. Call (480) 123-4567."
>

  <div data-emergency="true">

    <!-- Hero: Emergency Mode — Giant Phone Button -->
    <section class="bg-emergency py-16 sm:py-24">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <div class="inline-flex items-center gap-2 bg-white/20 text-white text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-white"></span>
          </span>
          Emergency Crews On Call Right Now
        </div>
        <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
          24/7 Emergency HVAC in Phoenix — We're On the Way.
        </h1>
        <p class="font-body text-white/90 text-xl mb-10 leading-relaxed">
          Real humans answer the phone 24 hours a day.<br/>
          Typical response time across the Phoenix Valley: <strong class="font-bold">under 60 minutes.</strong>
        </p>
        <a
          href="tel:4801234567"
          class="inline-flex items-center gap-3 bg-white hover:bg-charcoal-50 text-emergency font-display font-extrabold text-3xl sm:text-4xl px-10 py-6 rounded-2xl transition-colors shadow-2xl mb-6"
          aria-label="Call (480) 123-4567 for emergency HVAC service"
        >
          <svg class="w-9 h-9" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          (480) 123-4567
        </a>
        <p class="font-body text-white/80 text-base">
          No overtime fees · No holiday surcharges · Flat-rate pricing on every emergency call
        </p>
      </div>
    </section>


    <!-- Trust Strip -->
    <section class="bg-charcoal py-6">
      <div class="max-w-4xl mx-auto px-4">
        <ul class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-charcoal-50 text-sm font-body" role="list">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            AZ ROC-312489 Licensed
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            EPA 608 Certified Technicians
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            No Overtime Fees — Ever
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            4.9★ · 500+ Reviews
          </li>
        </ul>
      </div>
    </section>


    <!-- What We Consider an Emergency -->
    <section class="bg-white py-16">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-8 text-center">
          What counts as an emergency.
        </h2>
        <div class="grid sm:grid-cols-2 gap-4 mb-8">
          {[
            { serious: true, label: 'No AC during extreme heat — especially with seniors, children, or pets at home. Phoenix Valley summers can be dangerous fast.' },
            { serious: true, label: 'Gas smell anywhere in the house — leave immediately and call your gas utility, then us.' },
            { serious: true, label: 'CO detector triggered — leave the house, call 911, then call us.' },
            { serious: true, label: 'No heat during extreme cold — risk of frozen pipes or unsafe indoor temperatures.' },
            { serious: false, label: 'Water leaking from the indoor unit or actively flooding around equipment.' },
            { serious: false, label: 'Loud grinding, banging, or screeching — or a burning smell from any unit.' },
            { serious: false, label: 'Ice covering the outdoor coil, refrigerant lines, or indoor evaporator coil.' },
            { serious: false, label: 'Furnace short-cycling rapidly or clicking without igniting.' },
          ].map(item => (
            <div class={`flex items-start gap-3 rounded-xl p-4 ${item.serious ? 'bg-emergency/10 border border-emergency/20' : 'bg-charcoal-50 border border-charcoal/10'}`}>
              <svg class={`w-5 h-5 flex-shrink-0 mt-0.5 ${item.serious ? 'text-emergency' : 'text-charcoal'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                {item.serious
                  ? <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
                  : <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                }
              </svg>
              <p class="font-body text-sm text-neutral-700 leading-relaxed">{item.label}</p>
            </div>
          ))}
        </div>
        <div class="bg-charcoal rounded-xl p-5 text-center">
          <p class="font-body text-charcoal-50 text-sm leading-relaxed">
            <strong class="text-white">Not on this list but still worried?</strong> Call us. We'd rather diagnose it for free and tell you it's fine than have you wait and have it turn into something expensive.
          </p>
        </div>
      </div>
    </section>


    <!-- While You Wait -->
    <section class="bg-charcoal-50 py-16">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-8 text-center">
          While you wait for the tech.
        </h2>
        <div class="space-y-4">
          {[
            { step: '1', title: 'Gas smell or CO alarm?', body: 'Leave the house immediately. Call 911 or your gas utility first. Call us second. Do not flip light switches or open garage doors on the way out.' },
            { step: '2', title: 'Turn the thermostat off.', body: 'Let the system rest. Running a damaged system can make the failure worse and potentially more expensive to repair.' },
            { step: '3', title: 'Water leaking?', body: 'Turn the system off at the thermostat and place a towel or bucket under the drip. If it\'s near electrical equipment, shut off the circuit breaker.' },
            { step: '4', title: 'Take a quick photo.', body: 'Snap photos of the thermostat display, the outdoor unit, and any error codes or ice visible. It helps the tech diagnose faster when they arrive.' },
            { step: '5', title: 'Stay comfortable while you wait.', body: 'Move to the coolest or warmest room in the house. Close blinds to block heat. Use fans to circulate air. Keep pets and children in the most comfortable space available.' },
          ].map(item => (
            <div class="flex items-start gap-4 bg-white rounded-xl p-5 border border-charcoal/10">
              <div class="w-8 h-8 bg-emergency text-white font-display font-bold text-sm rounded-full flex items-center justify-center flex-shrink-0">{item.step}</div>
              <div>
                <h3 class="font-display font-bold text-charcoal text-base mb-1">{item.title}</h3>
                <p class="font-body text-neutral-600 text-sm leading-relaxed">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- No Overtime Fees -->
    <section class="bg-charcoal py-14">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="font-display font-bold text-white text-2xl sm:text-3xl mb-4">Emergency calls are flat-rate — same as every call.</h2>
        <p class="font-body text-charcoal-50 text-lg leading-relaxed max-w-2xl mx-auto">
          No overtime multipliers. No holiday surcharges. No "after-hours premium." If you call us at 3am on Christmas, your bill looks the same as a Tuesday afternoon. We quote it, you approve it, we fix it.
        </p>
      </div>
    </section>


    <!-- Emergency Reviews -->
    <section class="bg-white py-16">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-10 text-center">What customers say after an emergency call.</h2>
        <div class="grid sm:grid-cols-2 gap-6 mb-8">
          {[
            {
              quote: "AC died on the 4th of July with family in town. I called five HVAC companies. Skyhooked was the only one that picked up. Tech here in under an hour, capacitor replaced, back in business by lunch. No holiday markup, no upsell. I've been on their Comfort Plan ever since.",
              name: "Karen T.",
              location: "Phoenix",
              service: "Emergency AC — July 4th",
              initials: "KT",
            },
            {
              quote: "Furnace failed on a 22° morning. Got an answer at 6am, tech here by 8, new ignitor installed by 9. House was warming up by the time my kids got up for school. The tech explained exactly what failed and why. Could've cost us a lot more if we'd waited and pipes had frozen.",
              name: "David B.",
              location: "Mesa",
              service: "Emergency Furnace — Winter Freeze",
              initials: "DB",
            },
          ].map(review => (
            <blockquote class="bg-charcoal-50 rounded-2xl p-7 border border-charcoal/10">
              <div class="flex items-center gap-1 mb-4" aria-label="5 stars">
                {[...Array(5)].map(() => (
                  <svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
                ))}
              </div>
              <p class="font-body text-neutral-700 leading-relaxed mb-5 text-sm">"{review.quote}"</p>
              <footer class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-charcoal flex items-center justify-center text-white font-display font-bold text-xs">{review.initials}</div>
                <div>
                  <cite class="font-body font-semibold text-charcoal not-italic text-sm">{review.name}</cite>
                  <p class="font-body text-neutral-500 text-xs">{review.location} · {review.service}</p>
                </div>
              </footer>
            </blockquote>
          ))}
        </div>
        <div class="text-center">
          <a href="/reviews" class="font-display font-bold text-charcoal hover:text-charcoal-light transition-colors">Read all 500+ reviews →</a>
        </div>
      </div>
    </section>


    <!-- FAQ -->
    <section class="bg-charcoal-50 py-16">
      <div class="max-w-2xl mx-auto px-4">
        <h2 class="font-display font-bold text-charcoal text-3xl text-center mb-8">Emergency FAQs.</h2>
        <div id="emergency-faq" class="space-y-3">
          {[
            { q: 'How fast can you really be here?', a: 'Most Phoenix Valley emergency calls are on-site in under 60 minutes. We run dedicated emergency crews 24/7, every day of the year including holidays. Your call goes to a real dispatcher who immediately alerts the nearest available tech.' },
            { q: 'Is there really no extra charge after hours?', a: 'Correct. Flat-rate pricing applies day, night, weekend, and holiday. No overtime fees, no surcharges, ever. You\'ll receive a written quote before any work starts.' },
            { q: 'Do you really answer at 3am?', a: 'Yes. A real person in Arizona answers every call, every hour of every day. You will not get voicemail, a call center in another state, or an answering service.' },
            { q: 'Can I file the repair with homeowner\'s insurance?', a: 'In most cases yes — particularly for sudden failures or damage. We provide detailed invoices documenting the failure and source. Check with your carrier; most HVAC failures qualify as covered perils.' },
          ].map((faq, i) => (
            <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden bg-white">
              <button
                class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors"
                aria-expanded="false"
                data-index={i}
              >
                <span>{faq.q}</span>
                <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-emergency transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="faq-panel hidden px-5 pb-5">
                <p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- Bottom Giant Phone Button -->
    <section class="bg-emergency py-20">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-6">
          Still no AC or heat?<br/>Don't wait — call now.
        </h2>
        <a
          href="tel:4801234567"
          class="inline-flex items-center gap-3 bg-white hover:bg-charcoal-50 text-emergency font-display font-extrabold text-3xl sm:text-4xl px-10 py-6 rounded-2xl transition-colors shadow-2xl mb-6"
          aria-label="Call (480) 123-4567 for emergency HVAC service"
        >
          <svg class="w-9 h-9" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          (480) 123-4567
        </a>
        <p class="font-body text-white/80 text-base mt-2">
          Available 24 hours · 7 days · 365 days — including every holiday
        </p>
        <p class="font-body text-white/60 text-sm mt-3">
          Or <a href="/contact" class="underline hover:text-white transition-colors">request emergency service online →</a>
        </p>
      </div>
    </section>

  </div>

</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');
      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
      if (!isOpen) {
        panel.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
