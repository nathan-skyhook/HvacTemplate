---
import BaseLayout from '../../layouts/BaseLayout.astro';

const cities = [
  { name: 'Phoenix', slug: 'phoenix', response: '30 min', desc: 'Headquarters — fastest dispatch' },
  { name: 'Scottsdale', slug: 'scottsdale', response: '45 min', desc: 'Scottsdale-based crew on standby' },
  { name: 'Mesa', slug: 'mesa', response: '45 min', desc: 'East Valley team' },
  { name: 'Tempe', slug: 'tempe', response: '30 min', desc: 'Tempe-based crew' },
  { name: 'Chandler', slug: 'chandler', response: '45 min', desc: 'South East Valley team' },
  { name: 'Gilbert', slug: 'gilbert', response: '45 min', desc: 'Gilbert & Queen Creek area' },
  { name: 'Glendale', slug: 'glendale', response: '50 min', desc: 'West Valley team' },
  { name: 'Peoria', slug: 'peoria', response: '50 min', desc: 'North West Valley team' },
  { name: 'Surprise', slug: 'surprise', response: '60 min', desc: 'Far West Valley coverage' },
  { name: 'Avondale', slug: 'avondale', response: '55 min', desc: 'Southwest Valley coverage' },
  { name: 'Fountain Hills', slug: 'fountain-hills', response: '60 min', desc: 'East Valley foothills' },
  { name: 'Queen Creek', slug: 'queen-creek', response: '65 min', desc: 'Southeast Valley coverage' },
];
---

<BaseLayout
  title="HVAC Service Areas in Phoenix Valley | Skyhooked on Comfort"
  description="Skyhooked on Comfort serves the entire Phoenix Valley with licensed HVAC technicians in every city we list. Find your city for local response times and same-day service."
>

  <!-- Hero -->
  <section
    class="relative bg-charcoal-dark py-20 lg:py-28 overflow-hidden"
    style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 50%, oklch(0.30 0.025 253) 100%);"
  >
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full opacity-10" style="background: radial-gradient(circle, oklch(0.58 0.13 233), transparent);"></div>
      <div class="absolute bottom-0 -left-20 w-80 h-80 rounded-full opacity-5" style="background: radial-gradient(circle, oklch(0.58 0.13 233), transparent);"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        12 Cities Covered
      </div>
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        Local HVAC Technicians<br class="hidden sm:block"/>
        <span class="text-sky">Across the Phoenix Valley</span>
      </h1>
      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        Skyhooked on Comfort dispatches from Phoenix and covers every city below. Tap your city for local response times, neighborhood coverage, and the technicians you'll see at your door.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="tel:4801234567"
          class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a
          href="/contact"
          class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors"
        >
          Request a Quote →
        </a>
      </div>
    </div>
  </section>


  <!-- City Grid -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-4">
          Find your city
        </h2>
        <p class="font-body text-neutral-600 text-lg max-w-2xl mx-auto">
          Every city below has dedicated technicians familiar with local housing stock, climate conditions, and permit requirements. Typical response times shown for emergencies dispatched from our Phoenix headquarters.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
        {cities.map(city => (
          <a
            href={`/service-areas/${city.slug}`}
            class="group bg-white hover:bg-charcoal rounded-2xl p-6 border border-neutral-100 hover:border-charcoal transition-colors shadow-sm hover:shadow-lg"
          >
            <div class="flex items-start justify-between mb-3">
              <h3 class="font-display font-bold text-charcoal group-hover:text-white text-xl transition-colors">
                {city.name}
              </h3>
              <span class="inline-flex items-center gap-1 bg-sky/15 group-hover:bg-sky/25 text-sky text-xs font-body font-semibold px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                ~{city.response}
              </span>
            </div>
            <p class="font-body text-neutral-500 group-hover:text-charcoal-50 text-sm mb-4 transition-colors">{city.desc}</p>
            <span class="font-body text-sky text-sm font-semibold group-hover:text-sky-light transition-colors">
              See {city.name} service →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- Why Local Section -->
  <section class="bg-charcoal py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-white text-3xl sm:text-4xl mb-4">
          Why local technicians matter in Phoenix
        </h2>
        <p class="font-body text-charcoal-50 text-lg max-w-2xl mx-auto">
          Valley HVAC isn't generic. Climate, housing stock age, and utility programs vary significantly from Fountain Hills to Avondale. Our technicians know the territory.
        </p>
      </div>
      <div class="grid sm:grid-cols-3 gap-6">
        {[
          {
            heading: 'Phoenix Heat is Different',
            body: 'With summer highs routinely topping 115°F and monsoon humidity spikes in July–September, Valley HVAC systems work harder than almost anywhere in the US. Our techs are trained for these extremes.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>`
          },
          {
            heading: 'Parts on the Truck',
            body: 'We stock the capacitors, contactors, and common failure parts for the brands and system ages prevalent in each sub-market — less waiting, more same-day fixes.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l5.653-4.655m5.585-5.586l3.497-3.497a.525.525 0 01.743.743l-3.497 3.497"/>`
          },
          {
            heading: 'Local Permit Knowledge',
            body: 'Permit requirements vary by city and job type across the Valley. Our team knows Maricopa County and city-specific mechanical permit requirements cold, so your install is code-compliant from day one.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>`
          }
        ].map(item => (
          <div class="bg-charcoal-light/40 rounded-2xl p-6 border border-white/10">
            <div class="w-12 h-12 bg-sky/20 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true" set:html={item.icon}></svg>
            </div>
            <h3 class="font-display font-bold text-white text-base mb-2">{item.heading}</h3>
            <p class="font-body text-charcoal-50 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Don't See Your City Callout -->
  <section class="bg-white py-20">
    <div class="max-w-3xl mx-auto px-4">
      <div class="bg-charcoal-50 rounded-2xl p-8 sm:p-12 text-center border border-charcoal/10">
        <div class="w-14 h-14 bg-charcoal rounded-xl flex items-center justify-center mx-auto mb-6">
          <svg class="w-7 h-7 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h2 class="font-display font-bold text-charcoal text-2xl sm:text-3xl mb-4">
          Don't see your city?
        </h2>
        <p class="font-body text-neutral-600 text-lg mb-8 leading-relaxed max-w-xl mx-auto">
          If you're within about 30 miles of Phoenix, we probably still serve you. Call us and we'll let you know — most calls we can have a tech out same day regardless of whether your city is on this list.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="tel:4801234567"
            class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold px-7 py-3.5 rounded-xl transition-colors shadow-md"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Call (480) 123-4567
          </a>
          <a
            href="/contact"
            class="flex items-center gap-2 bg-charcoal hover:bg-charcoal-light text-white font-display font-bold px-7 py-3.5 rounded-xl transition-colors"
          >
            Request a Quote →
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- Bottom Emergency CTA -->
  <section class="bg-emergency py-16">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl mb-4">
        HVAC emergency in the Valley?
      </h2>
      <p class="font-body text-white/80 text-lg mb-8">
        We dispatch 24/7, every day of the year. No overtime fees, no holiday surcharges.
      </p>
      <a
        href="tel:4801234567"
        class="inline-flex items-center gap-3 bg-sky hover:bg-sky-dark text-charcoal font-display font-extrabold text-xl px-10 py-5 rounded-2xl transition-colors shadow-xl"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Call (480) 123-4567 Now
      </a>
      <p class="font-body text-white/60 text-sm mt-4">
        Available 24/7 · No overtime fees · Real humans answer
      </p>
    </div>
  </section>

</BaseLayout>
