  { name: `Heat Pump Installation in ${name}`, href: '/residential/heat-pump-installation', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z"/>` },
  { name: `Heating Repair in ${name}`, href: '/residential/heating-repair', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/>` },
  { name: `Indoor Air Quality in ${name}`, href: '/residential/indoor-air-quality', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>` },
  { name: `Commercial HVAC in ${name}`, href: '/commercial', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/>` },
];

const localBusinessSchema = {
  name: "Skyhooked on Comfort",
  "@type": "HVACBusiness",
  telephone: "(480) 123-4567",
  url: "https://skyhookedoncomfort.com",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Phoenix",
    addressRegion: "AZ",
    addressCountry: "US",
  },
  areaServed: {
    "@type": "City",
    name: name,
    containedInPlace: {
      "@type": "State",
      name: "Arizona"
    }
  },
  openingHours: ["Mo-Fr 07:00-19:00", "Sa 08:00-16:00"],
  description: `Licensed HVAC contractor serving ${name}, AZ. AC repair, installation, heat pumps, heating, and commercial HVAC. 24/7 emergency service.`,
};
---

<BaseLayout
  title={`HVAC Contractor in ${name}, AZ | AC, Heating, Heat Pumps | Skyhooked on Comfort`}
  description={`Local HVAC technicians in ${name} serving ${neighborhoods.slice(0, 3).join(', ')} and surrounding neighborhoods. ~${response} typical response, EPA-certified, upfront pricing. Call (480) 123-4567.`}
>

  <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", ...localBusinessSchema })} />

  <!-- Hero -->
  <section
    class="relative bg-charcoal-dark py-20 lg:py-28 overflow-hidden"
    style="background: linear-gradient(135deg, oklch(0.12 0.02 253) 0%, oklch(0.18 0.025 253) 50%, oklch(0.30 0.025 253) 100%);"
  >
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full opacity-10" style="background: radial-gradient(circle, oklch(0.58 0.13 233), transparent);"></div>
      <div class="absolute bottom-0 -left-20 w-80 h-80 rounded-full opacity-5" style="background: radial-gradient(circle, oklch(0.58 0.13 233), transparent);"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-sky/20 text-sky text-sm font-semibold px-4 py-1.5 rounded-full mb-6 font-body">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Typical Response: ~{response}
      </div>
      <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        HVAC Contractor in {name}<br class="hidden sm:block"/>
        <span class="text-sky">Local, Licensed, Available 24/7</span>
      </h1>
      <p class="font-body text-charcoal-50 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        Skyhooked on Comfort serves {name} and the surrounding neighborhoods of {neighborhoods.slice(0, 3).join(', ')}, and more. Same-day service on most calls, upfront flat-rate pricing, no overtime fees. License AZ ROC-312489.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="tel:4801234567"
          class="flex items-center gap-2 bg-sky hover:bg-sky-dark text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a
          href="/contact"
          class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors"
        >
          Request a Quote →
        </a>
      </div>
    </div>
  </section>


  <!-- Local Intro -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid lg:grid-cols-3 gap-10 items-start">
        <div class="lg:col-span-2">
          <h2 class="font-display font-bold text-charcoal text-2xl sm:text-3xl mb-5">
            HVAC service built for {name}
          </h2>
          <p class="font-body text-neutral-600 text-lg leading-relaxed mb-6">{climate}</p>
          <p class="font-body text-neutral-600 leading-relaxed">
            Skyhooked on Comfort has served {name} since 2010. We're family-owned, fully licensed (AZ ROC-312489), EPA Section 608 Universal certified, and insured. Every technician passes a background check before they step into your home or business, and every job comes with upfront flat-rate pricing and our 100% satisfaction guarantee.
          </p>
        </div>
        <div class="bg-charcoal-50 rounded-2xl p-6 border border-charcoal/10">
          <h3 class="font-display font-bold text-charcoal text-base mb-4">Quick facts</h3>
          <ul class="space-y-3 font-body text-sm text-neutral-700">
            {[
              { label: 'Typical response', value: `~${response}` },
              { label: 'Service hours', value: '24/7 emergency' },
              { label: 'License', value: 'AZ ROC-312489' },
              { label: 'Certifications', value: 'EPA Section 608 Universal' },
              { label: 'Founded', value: '2010' },
              { label: 'Guarantee', value: '100% satisfaction' },
            ].map(item => (
              <li class="flex justify-between items-center border-b border-charcoal/10 pb-2 last:border-0 last:pb-0">
                <span class="text-neutral-500">{item.label}</span>
                <span class="font-semibold text-charcoal">{item.value}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>


  <!-- Services Grid -->
  <section class="bg-charcoal-50 py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">
          Services available in {name}
        </h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">
          Full-service HVAC — residential and commercial — backed by our satisfaction guarantee.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map(service => (
          <a
            href={service.href}
            class="group bg-white hover:bg-charcoal rounded-2xl p-6 transition-colors border border-neutral-100 hover:border-charcoal shadow-sm hover:shadow-md"
          >
            <div class="w-11 h-11 bg-sky/15 group-hover:bg-sky/20 rounded-xl flex items-center justify-center mb-4 transition-colors">
              <svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true" set:html={service.icon}></svg>
            </div>
            <h3 class="font-display font-bold text-charcoal group-hover:text-white text-base mb-1.5 transition-colors">{service.name}</h3>
            <span class="font-body text-sky text-sm font-semibold">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- Neighborhoods -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">
          Neighborhoods we serve in {name}
        </h2>
        <p class="font-body text-neutral-500 text-lg max-w-xl mx-auto">
          We know these neighborhoods — the housing stock, the common system types, and the local permit requirements.
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        {neighborhoods.map(neighborhood => (
          <span class="inline-flex items-center gap-2 bg-charcoal-50 text-charcoal font-body font-semibold text-sm px-4 py-2.5 rounded-xl border border-charcoal/10">
            <svg class="w-3.5 h-3.5 text-sky flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            {neighborhood}
          </span>
        ))}
        <span class="inline-flex items-center bg-sky/10 text-sky font-body font-semibold text-sm px-4 py-2.5 rounded-xl border border-sky/20">
          + surrounding areas
        </span>
      </div>
      <p class="font-body text-neutral-500 text-center text-sm">
        Don't see your neighborhood listed? <a href="tel:4801234567" class="text-sky font-semibold hover:underline">Call us</a> — we likely serve your area.
      </p>
    </div>
  </section>


  <!-- Local Review -->
  <section class="bg-charcoal py-20">
    <div class="max-w-3xl mx-auto px-4">
      <div class="text-center mb-10">
        <div class="flex items-center justify-center gap-1 mb-3" aria-label="5 stars">
          {[...Array(5)].map(() => (
            <svg class="w-6 h-6 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
          ))}
        </div>
        <h2 class="font-display font-bold text-white text-2xl sm:text-3xl mb-2">
          What {name} customers say
        </h2>
        <p class="font-body text-charcoal-50 text-base">4.9★ Google rating · 500+ reviews</p>
      </div>
      <blockquote class="bg-charcoal-light/40 rounded-2xl p-8 border border-white/10">
        <div class="flex items-center gap-1 mb-5" aria-label="5 stars">
          {[...Array(5)].map(() => (
            <svg class="w-4 h-4 text-sky" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
          ))}
        </div>
        <p class="font-body text-charcoal-50 text-lg leading-relaxed mb-6">{review.text}</p>
        <footer class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-sky/20 flex items-center justify-center text-sky font-display font-bold text-sm">
            {review.author.split(' ').map((n: string) => n[0]).join('')}
          </div>
          <div>
            <cite class="font-body font-semibold text-white not-italic text-sm">{review.author}</cite>
            <p class="font-body text-charcoal-50 text-xs">{review.location} · {review.service}</p>
          </div>
        </footer>
      </blockquote>
      <div class="text-center mt-8">
        <a href="/reviews" class="font-display font-bold text-sky hover:text-sky-light transition-colors text-sm">
          Read all {name} area reviews →
        </a>
      </div>
    </div>
  </section>


  <!-- City FAQs -->
  <section class="bg-white py-20">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-charcoal text-3xl sm:text-4xl mb-3">
          {name} HVAC questions
        </h2>
        <p class="font-body text-neutral-500">Common questions from our {name} customers.</p>
      </div>
      <div id="faq-list" class="space-y-3 mb-10">
        {faqs.map((faq: { q: string; a: string }, i: number) => (
          <div class="faq-item border border-neutral-200 rounded-xl overflow-hidden">
            <button
              class="faq-btn w-full text-left flex items-center justify-between gap-4 p-5 font-display font-semibold text-charcoal hover:bg-charcoal-50 transition-colors"
              aria-expanded="false"
              data-index={i}
            >
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 flex-shrink-0 text-sky transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq-panel hidden px-5 pb-5">
              <p class="font-body text-neutral-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Bottom CTA -->
  <section class="bg-emergency py-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-extrabold text-white text-3xl sm:text-4xl lg:text-5xl mb-6 leading-tight">
        Need HVAC service in {name}?<br/>
        <span class="text-sky">We're ready to dispatch.</span>
      </h2>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6">
        <a
          href="tel:4801234567"
          class="flex items-center gap-3 bg-sky hover:bg-sky-dark text-charcoal font-display font-extrabold text-xl px-10 py-5 rounded-2xl transition-colors shadow-xl"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (480) 123-4567
        </a>
        <a
          href="/contact"
          class="flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-charcoal font-display font-bold text-lg px-8 py-4 rounded-xl transition-colors"
        >
          Request a Quote →
        </a>
      </div>
      <p class="font-body text-white/80 text-base">
        Available 24/7 · No overtime fees · License AZ ROC-312489
      </p>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as SVGElement;
      const isOpen = !panel.classList.contains('hidden');

      document.querySelectorAll('.faq-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        panel.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
