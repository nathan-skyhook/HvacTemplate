---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    title: 'Residential Services',
    links: [
      { label: 'Residential HVAC Overview', href: '/residential' },
      { label: 'AC Repair', href: '/residential/ac-repair' },
      { label: 'AC Installation & Replacement', href: '/residential/ac-installation' },
      { label: 'Heating Repair', href: '/residential/heating-repair' },
      { label: 'Heating Installation', href: '/residential/heating-installation' },
      { label: 'Heat Pump Installation', href: '/residential/heat-pump-installation' },
      { label: 'Ductless Mini-Splits', href: '/residential/ductless-mini-splits' },
      { label: 'Indoor Air Quality', href: '/residential/indoor-air-quality' },
      { label: 'Duct Cleaning & Sealing', href: '/residential/duct-cleaning-sealing' },
      { label: 'Smart Thermostats', href: '/residential/smart-thermostats' },
      { label: 'Tune-Ups & Maintenance', href: '/residential/tune-ups-maintenance' },
      { label: 'Zoning Controls', href: '/residential/zoning-controls' },
      { label: 'Emergency HVAC (Residential)', href: '/residential/emergency-hvac' },
