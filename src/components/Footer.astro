---
const residentialServices = [
  { label: 'AC Repair', href: '/residential/ac-repair' },
  { label: 'AC Installation', href: '/residential/ac-installation' },
  { label: 'Heat Pump Installation', href: '/residential/heat-pump-installation' },
  { label: 'Heating Repair', href: '/residential/heating-repair' },
  { label: 'Mini-Splits', href: '/residential/mini-splits' },
  { label: 'Indoor Air Quality', href: '/residential/indoor-air-quality' },
];

const commercialServices = [
  { label: 'Commercial AC', href: '/commercial/ac-systems' },
  { label: 'Preventive Maintenance', href: '/commercial/maintenance' },
  { label: 'Chiller Services', href: '/commercial/chillers' },
  { label: 'VRF/VRV Systems', href: '/commercial/vrf-vrv' },
  { label: 'Commercial Refrigeration', href: '/commercial/refrigeration' },
  { label: 'Industries Served', href: '/commercial/industries' },
];

const quickLinks = [
  { label: 'About', href: '/about' },
  { label: 'Emergency', href: '/emergency' },
  { label: 'Promotions', href: '/promotions' },
  { label: 'Financing', href: '/financing' },
  { label: 'Maintenance Plans', href: '/maintenance-plans' },
  { label: 'Careers', href: '/careers' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="bg-charcoal-dark font-body">
  <div class="max-w-7xl mx-auto px-4 py-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

    <!-- Column 1: Company -->
    <div>
      <a href="/" class="flex items-center gap-3 mb-5" aria-label="Skyhooked on Comfort — Home">
        <svg width="34" height="34" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="20" cy="20" r="20" fill="oklch(0.58 0.13 233)"/>
          <path d="M20 8 C16 12 13 15 13 20 C13 24.4 16.1 27 19 28 C18 26 17.5 24.5 18.5 22.5 C19.5 24 19.8 25.5 19.5 27.5 C21.5 26.5 23.5 24 23.5 21 C23.5 18.5 22 16.5 20 15 C20.5 17 20 18.5 19 19.5 C19.5 16 20 12 20 8Z" fill="oklch(0.18 0.025 253)" clip-path="inset(0 50% 0 0)"/>
          <g stroke="oklch(0.18 0.025 253)" stroke-width="1.5" stroke-linecap="round" clip-path="inset(0 0 0 50%)">
            <line x1="20" y1="11" x2="20" y2="29"/>
            <line x1="12.2" y1="15.5" x2="27.8" y2="24.5"/>
            <line x1="12.2" y1="24.5" x2="27.8" y2="15.5"/>
            <line x1="20" y1="11" x2="18" y2="14"/>
            <line x1="20" y1="11" x2="22" y2="14"/>
            <line x1="20" y1="29" x2="18" y2="26"/>
            <line x1="20" y1="29" x2="22" y2="26"/>
          </g>
        </svg>
        <div class="font-display leading-tight">
          <div class="text-white font-bold text-sm tracking-wide">SKYHOOKED</div>
          <div class="text-sky text-xs font-medium">on Comfort</div>
        </div>
      </a>

      <address class="not-italic text-neutral-300 text-sm space-y-1 mb-4">
        <p class="font-semibold text-white">Skyhooked on Comfort</p>
        <p>Phoenix, AZ</p>
        <a href="tel:4801234567" class="hover:text-sky transition-colors">(480) 123-4567</a>
      </address>

      <div class="text-neutral-400 text-xs space-y-1 mb-5">
        <p>Mon–Fri 7am–7pm · Sat 8am–4pm</p>
        <p>Emergency Service: 24/7</p>
        <p>AZ ROC-312489 · EPA 608 Certified</p>
      </div>

      <!-- Social icons -->
      <div class="flex items-center gap-3">
        <a href="#" aria-label="Facebook" class="text-neutral-400 hover:text-sky transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="#" aria-label="Instagram" class="text-neutral-400 hover:text-sky transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="#" aria-label="Google" class="text-neutral-400 hover:text-sky transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.545 10.239v3.821h5.445c-.712 2.315-2.647 3.972-5.445 3.972a6.033 6.033 0 110-12.064c1.498 0 2.866.549 3.921 1.453l2.814-2.814A9.969 9.969 0 0012.545 2C7.021 2 2.543 6.477 2.543 12s4.478 10 10.002 10c8.396 0 10.249-7.85 9.426-11.748l-9.426-.013z"/></svg>
        </a>
        <a href="#" aria-label="Yelp" class="text-neutral-400 hover:text-sky transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.16 12.594l-4.995 1.452c-.96.279-1.69-.9-1.032-1.676l3.42-3.988a.838.838 0 011.177-.075 9.495 9.495 0 012.102 3.138.836.836 0 01-.672 1.149zm-7.477 5.401l1.1 4.909a.838.838 0 01-1.069.975 9.498 9.498 0 01-3.405-1.7.836.836 0 01-.14-1.175l3.009-3.942c.597-.78 1.805-.394 1.505.933zm-5.039-1.148l-4.915 1.254a.838.838 0 01-1.016-.87 9.498 9.498 0 01.636-3.695.837.837 0 011.109-.44l4.571 2.013c.907.4.73 1.717-.385 1.738zm-.537-6.553l-4.36-2.532a.838.838 0 01-.25-1.209 9.498 9.498 0 012.537-2.568.837.837 0 011.18.2l2.844 4.17c.564.827-.283 1.916-1.281 1.34l-.67-.401zM13.5 0C6.045 0 0 6.045 0 13.5 0 20.955 6.045 27 13.5 27S27 20.955 27 13.5C27 6.045 20.955 0 13.5 0zm1.5 10.74V5.25a.838.838 0 00-.92-.834 9.497 9.497 0 00-3.69 1.26.837.837 0 00-.215 1.183l2.902 4.115c.578.819 1.923.432 1.923-.234z"/></svg>
        </a>
        <a href="#" aria-label="LinkedIn" class="text-neutral-400 hover:text-sky transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>

    <!-- Column 2: Residential Services -->
    <div>
      <h3 class="font-display font-bold text-white text-sm uppercase tracking-wider mb-4">Residential Services</h3>
      <ul class="space-y-2">
        {residentialServices.map(s => (
          <li>
            <a href={s.href} class="text-neutral-300 hover:text-sky text-sm transition-colors">{s.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Column 3: Commercial Services -->
    <div>
      <h3 class="font-display font-bold text-white text-sm uppercase tracking-wider mb-4">Commercial Services</h3>
      <ul class="space-y-2">
        {commercialServices.map(s => (
          <li>
            <a href={s.href} class="text-neutral-300 hover:text-sky text-sm transition-colors">{s.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Column 4: Quick Links -->
    <div>
      <h3 class="font-display font-bold text-white text-sm uppercase tracking-wider mb-4">Quick Links</h3>
      <ul class="space-y-2">
        {quickLinks.map(l => (
          <li>
            <a href={l.href} class="text-neutral-300 hover:text-sky text-sm transition-colors">{l.label}</a>
          </li>
        ))}
      </ul>
    </div>

  </div>

  <!-- Bottom row -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-neutral-400 font-body">
      <p>© 2025 Skyhooked on Comfort · AZ ROC-312489</p>
      <nav class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1" aria-label="Legal links">
        <a href="/accessibility" class="hover:text-white transition-colors">Accessibility</a>
        <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy</a>
        <a href="/terms-of-service" class="hover:text-white transition-colors">Terms</a>
        <a href="/sitemap" class="hover:text-white transition-colors">Sitemap</a>
      </nav>
    </div>
  </div>
</footer>
